// zeta_src/tests/parser_impl_blocks.z
// Comprehensive impl block test suite for Zeta parser
// Tests both inherent impl blocks and trait impl blocks

// === Test 1: Basic Inherent Impl Block ===
struct Counter {
    count: i64,
}

impl Counter {
    fn new() -> Counter {
        Counter { count: 0 }
    }
    
    fn increment(&mut self) {
        self.count += 1
    }
    
    fn get(&self) -> i64 {
        self.count
    }
}

// === Test 2: Inherent Impl with Generics ===
struct Box<T> {
    value: T,
}

impl<T> Box<T> {
    fn new(value: T) -> Box<T> {
        Box { value }
    }
    
    fn get(&self) -> &T {
        &self.value
    }
    
    fn set(&mut self, value: T) {
        self.value = value
    }
}

// === Test 3: Trait Definition ===
trait Display {
    fn display(&self) -> string;
}

trait Clone {
    fn clone(&self) -> Self;
}

// === Test 4: Trait Impl Block ===
impl Display for Counter {
    fn display(&self) -> string {
        format!("Counter({})", self.count)
    }
}

impl Clone for Counter {
    fn clone(&self) -> Counter {
        Counter { count: self.count }
    }
}

// === Test 5: Mixed Example ===
struct Point {
    x: f64,
    y: f64,
}

// Inherent impl block
impl Point {
    fn new(x: f64, y: f64) -> Point {
        Point { x, y }
    }
    
    fn distance(&self, other: &Point) -> f64 {
        let dx = self.x - other.x;
        let dy = self.y - other.y;
        (dx * dx + dy * dy).sqrt()
    }
}

// Trait impl blocks
impl Display for Point {
    fn display(&self) -> string {
        format!("Point({:.2}, {:.2})", self.x, self.y)
    }
}

// === Test 6: Complex Generics ===
trait Container<T> {
    fn add(&mut self, item: T);
    fn get(&self, index: i64) -> Option<&T>;
    fn size(&self) -> i64;
}

struct VecContainer<T> {
    items: Vec<T>,
}

impl<T> VecContainer<T> {
    fn new() -> VecContainer<T> {
        VecContainer { items: vec![] }
    }
}

impl<T> Container<T> for VecContainer<T> {
    fn add(&mut self, item: T) {
        self.items.push(item)
    }
    
    fn get(&self, index: i64) -> Option<&T> {
        if index >= 0 && index < self.items.len() as i64 {
            Some(&self.items[index as usize])
        } else {
            None
        }
    }
    
    fn size(&self) -> i64 {
        self.items.len() as i64
    }
}

// === Test 7: Multiple Trait Impl ===
trait Debug {
    fn debug(&self) -> string;
}

impl Debug for Point {
    fn debug(&self) -> string {
        format!("Point {{ x: {}, y: {} }}", self.x, self.y)
    }
}

// === Test 8: Associated Types in Traits ===
trait Iterator {
    type Item;
    
    fn next(&mut self) -> Option<Self::Item>;
    fn count(self) -> i64;
}

struct Range {
    current: i64,
    end: i64,
}

impl Range {
    fn new(start: i64, end: i64) -> Range {
        Range { current: start, end }
    }
}

impl Iterator for Range {
    type Item = i64;
    
    fn next(&mut self) -> Option<i64> {
        if self.current < self.end {
            let val = self.current;
            self.current += 1;
            Some(val)
        } else {
            None
        }
    }
    
    fn count(self) -> i64 {
        self.end - self.current
    }
}

// === Main Test Function ===
fn test_impl_blocks() {
    println!("Testing impl blocks (inherent and trait)...");
    
    // Test inherent impl
    let mut counter = Counter::new();
    counter.increment();
    counter.increment();
    println!("Counter value: {}", counter.get());
    
    // Test trait impl
    println!("Counter display: {}", counter.display());
    let counter2 = counter.clone();
    println!("Cloned counter value: {}", counter2.get());
    
    // Test Point with both inherent and trait impls
    let p1 = Point::new(0.0, 0.0);
    let p2 = Point::new(3.0, 4.0);
    println!("Distance between points: {}", p1.distance(&p2));
    println!("Point display: {}", p1.display());
    println!("Point debug: {}", p1.debug());
    
    // Test generic container
    let mut container = VecContainer::new();
    container.add(42);
    container.add(100);
    println!("Container size: {}", container.size());
    println!("Container[0]: {}", container.get(0).unwrap_or(&-1));
    
    // Test iterator
    let range = Range::new(1, 5);
    println!("Range count: {}", range.count());
    
    println!("All impl block tests completed!");
}

fn main() {
    test_impl_blocks();
}