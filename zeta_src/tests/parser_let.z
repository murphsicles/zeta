// zeta_src/tests/parser_let.z
// Test suite for let statement parsing

use crate::frontend::parser::Parser;
use crate::frontend::ast::AstNode;

fn test_let_basic() {
    let code = "let x = 5;";
    let mut parser = Parser::new(code.to_string());
    let ast = parser.parse();
    
    // Should parse as a program with one let statement
    match ast {
        AstNode::Program(stmts) => {
            assert_eq!(stmts.len(), 1);
            match &stmts[0] {
                AstNode::Let { name, ty, value } => {
                    assert_eq!(name, "x");
                    assert!(ty.is_none());
                    match &**value {
                        AstNode::Lit(5) => (),
                        _ => panic!("Expected Lit(5), got {:?}", value),
                    }
                }
                _ => panic!("Expected Let statement, got {:?}", stmts[0]),
            }
        }
        _ => panic!("Expected Program, got {:?}", ast),
    }
    println!("✓ test_let_basic passed");
}

fn test_let_with_type() {
    let code = "let x: i32 = 5;";
    let mut parser = Parser::new(code.to_string());
    let ast = parser.parse();
    
    match ast {
        AstNode::Program(stmts) => {
            assert_eq!(stmts.len(), 1);
            match &stmts[0] {
                AstNode::Let { name, ty, value } => {
                    assert_eq!(name, "x");
                    assert_eq!(ty.as_deref(), Some("i32"));
                    match &**value {
                        AstNode::Lit(5) => (),
                        _ => panic!("Expected Lit(5), got {:?}", value),
                    }
                }
                _ => panic!("Expected Let statement, got {:?}", stmts[0]),
            }
        }
        _ => panic!("Expected Program, got {:?}", ast),
    }
    println!("✓ test_let_with_type passed");
}

fn test_let_with_expression() {
    let code = "let result = 2 + 3 * 4;";
    let mut parser = Parser::new(code.to_string());
    let ast = parser.parse();
    
    match ast {
        AstNode::Program(stmts) => {
            assert_eq!(stmts.len(), 1);
            match &stmts[0] {
                AstNode::Let { name, ty, value } => {
                    assert_eq!(name, "result");
                    assert!(ty.is_none());
                    // Should parse as binary expression: 2 + (3 * 4)
                    match &**value {
                        AstNode::BinaryOp { op, left, right } => {
                            assert_eq!(op, "+");
                            match &**left {
                                AstNode::Lit(2) => (),
                                _ => panic!("Expected Lit(2) in left operand"),
                            }
                            match &**right {
                                AstNode::BinaryOp { op: op2, left: left2, right: right2 } => {
                                    assert_eq!(op2, "*");
                                    match &**left2 {
                                        AstNode::Lit(3) => (),
                                        _ => panic!("Expected Lit(3) in multiplication left"),
                                    }
                                    match &**right2 {
                                        AstNode::Lit(4) => (),
                                        _ => panic!("Expected Lit(4) in multiplication right"),
                                    }
                                }
                                _ => panic!("Expected BinaryOp in right operand"),
                            }
                        }
                        _ => panic!("Expected BinaryOp, got {:?}", value),
                    }
                }
                _ => panic!("Expected Let statement, got {:?}", stmts[0]),
            }
        }
        _ => panic!("Expected Program, got {:?}", ast),
    }
    println!("✓ test_let_with_expression passed");
}

fn test_let_multiple() {
    let code = "let x = 1; let y = 2;";
    let mut parser = Parser::new(code.to_string());
    let ast = parser.parse();
    
    match ast {
        AstNode::Program(stmts) => {
            assert_eq!(stmts.len(), 2);
            
            // First let statement
            match &stmts[0] {
                AstNode::Let { name, ty, value } => {
                    assert_eq!(name, "x");
                    assert!(ty.is_none());
                    match &**value {
                        AstNode::Lit(1) => (),
                        _ => panic!("Expected Lit(1) in first let"),
                    }
                }
                _ => panic!("Expected Let statement at position 0"),
            }
            
            // Second let statement
            match &stmts[1] {
                AstNode::Let { name, ty, value } => {
                    assert_eq!(name, "y");
                    assert!(ty.is_none());
                    match &**value {
                        AstNode::Lit(2) => (),
                        _ => panic!("Expected Lit(2) in second let"),
                    }
                }
                _ => panic!("Expected Let statement at position 1"),
            }
        }
        _ => panic!("Expected Program, got {:?}", ast),
    }
    println!("✓ test_let_multiple passed");
}

fn test_let_in_block() {
    let code = "{ let x = 5; x }";
    let mut parser = Parser::new(code.to_string());
    let ast = parser.parse();
    
    // Should parse as a block with let statement and variable expression
    match ast {
        AstNode::Program(stmts) => {
            assert_eq!(stmts.len(), 1);
            match &stmts[0] {
                AstNode::ExprStmt { expr } => {
                    match &**expr {
                        AstNode::Block(block_stmts) => {
                            assert_eq!(block_stmts.len(), 2);
                            // First statement should be let
                            match &block_stmts[0] {
                                AstNode::Let { name, ty, value } => {
                                    assert_eq!(name, "x");
                                    assert!(ty.is_none());
                                    match &**value {
                                        AstNode::Lit(5) => (),
                                        _ => panic!("Expected Lit(5) in block let"),
                                    }
                                }
                                _ => panic!("Expected Let statement in block"),
                            }
                            // Second should be variable expression
                            match &block_stmts[1] {
                                AstNode::Var(var_name) => {
                                    assert_eq!(var_name, "x");
                                }
                                _ => panic!("Expected Var expression in block"),
                            }
                        }
                        _ => panic!("Expected Block, got {:?}", expr),
                    }
                }
                _ => panic!("Expected ExprStmt, got {:?}", stmts[0]),
            }
        }
        _ => panic!("Expected Program, got {:?}", ast),
    }
    println!("✓ test_let_in_block passed");
}

pub fn run_tests() {
    println!("Running let statement parser tests...");
    test_let_basic();
    test_let_with_type();
    test_let_with_expression();
    test_let_multiple();
    test_let_in_block();
    println!("All let statement parser tests passed!");
}