// zeta_src/tests/parser_float.z
// Comprehensive float literal tests for SYN's parser implementation
// Tests float parsing: 3.14, 123.456, 1.23e-4, 123., scientific notation, edge cases

use crate::frontend::parser::{Lexer, Parser, Token};
use crate::frontend::ast::AstNode;

fn test_lexer_float() {
    println!("=== Testing Lexer Float Parsing ===");
    
    // Test basic float literals
    let mut lexer = Lexer::new("3.14".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::FloatLit(3.14));
    println!("✓ 3.14 → FloatLit(3.14)");
    
    // Test float with multiple digits
    let mut lexer = Lexer::new("123.456".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::FloatLit(123.456));
    println!("✓ 123.456 → FloatLit(123.456)");
    
    // Test float ending with decimal point
    let mut lexer = Lexer::new("123.".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::FloatLit(123.0));
    println!("✓ 123. → FloatLit(123.0)");
    
    // Test scientific notation
    let mut lexer = Lexer::new("1.23e-4".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::FloatLit(1.23e-4));
    println!("✓ 1.23e-4 → FloatLit(1.23e-4)");
    
    // Test scientific notation with capital E
    let mut lexer = Lexer::new("2.5E+3".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::FloatLit(2.5e3));
    println!("✓ 2.5E+3 → FloatLit(2500.0)");
    
    // Test integer (should NOT be float)
    let mut lexer = Lexer::new("42".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::Lit(42));
    println!("✓ 42 → Lit(42) (not float)");
    
    // Test mixed expression
    let mut lexer = Lexer::new("3.14 + 2.5".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::FloatLit(3.14));
    assert_eq!(tokens[1], Token::Plus);
    assert_eq!(tokens[2], Token::FloatLit(2.5));
    println!("✓ 3.14 + 2.5 → FloatLit, Plus, FloatLit");
    
    println!("All lexer float tests passed!");
}

fn test_parser_float() {
    println!("\n=== Testing Parser Float AST Generation ===");
    
    // Test float literal in AST
    let mut parser = Parser::new("3.14".to_string());
    let ast = parser.parse_expr();
    match ast {
        AstNode::FloatLit(f) => {
            assert!((f - 3.14).abs() < 0.0001);
            println!("✓ 3.14 → FloatLit AST with value {}", f);
        }
        _ => panic!("Expected FloatLit, got {:?}", ast),
    }
    
    // Test float arithmetic
    let mut parser = Parser::new("3.14 + 2.5".to_string());
    let ast = parser.parse_expr();
    match ast {
        AstNode::BinaryOp { op, left, right } => {
            assert_eq!(op, "+");
            match *left {
                AstNode::FloatLit(f) => assert!((f - 3.14).abs() < 0.0001),
                _ => panic!("Expected FloatLit in left operand"),
            }
            match *right {
                AstNode::FloatLit(f) => assert!((f - 2.5).abs() < 0.0001),
                _ => panic!("Expected FloatLit in right operand"),
            }
            println!("✓ 3.14 + 2.5 → BinaryOp with FloatLit operands");
        }
        _ => panic!("Expected BinaryOp, got {:?}", ast),
    }
    
    // Test scientific notation in AST
    let mut parser = Parser::new("1.23e-4".to_string());
    let ast = parser.parse_expr();
    match ast {
        AstNode::FloatLit(f) => {
            assert!((f - 1.23e-4).abs() < 1e-10);
            println!("✓ 1.23e-4 → FloatLit AST with value {}", f);
        }
        _ => panic!("Expected FloatLit, got {:?}", ast),
    }
    
    // Test float in assignment
    let mut parser = Parser::new("x = 3.14".to_string());
    let ast = parser.parse_expr();
    match ast {
        AstNode::Assign(left, right) => {
            match *left {
                AstNode::Var(name) => assert_eq!(name, "x"),
                _ => panic!("Expected Var in assignment left"),
            }
            match *right {
                AstNode::FloatLit(f) => assert!((f - 3.14).abs() < 0.0001),
                _ => panic!("Expected FloatLit in assignment right"),
            }
            println!("✓ x = 3.14 → Assign with FloatLit value");
        }
        _ => panic!("Expected Assign, got {:?}", ast),
    }
    
    println!("All parser float tests passed!");
}

fn test_edge_cases() {
    println!("\n=== Testing Edge Cases ===");
    
    // Test very small float
    let mut lexer = Lexer::new("0.000001".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::FloatLit(0.000001));
    println!("✓ 0.000001 → FloatLit(0.000001)");
    
    // Test very large float
    let mut lexer = Lexer::new("1.0e10".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::FloatLit(1.0e10));
    println!("✓ 1.0e10 → FloatLit(10000000000.0)");
    
    // Test negative exponent
    let mut lexer = Lexer::new("5.0e-3".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::FloatLit(5.0e-3));
    println!("✓ 5.0e-3 → FloatLit(0.005)");
    
    // Test no digits after decimal (should still be float)
    let mut lexer = Lexer::new("7.".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::FloatLit(7.0));
    println!("✓ 7. → FloatLit(7.0)");
    
    // Test just decimal point (should be dot operator, not float)
    let mut lexer = Lexer::new(".method".to_string());
    let tokens = lexer.tokenize();
    assert_eq!(tokens[0], Token::Dot);
    assert_eq!(tokens[1], Token::Ident("method".to_string()));
    println!("✓ .method → Dot, Ident (not float)");
    
    println!("All edge case tests passed!");
}

fn main() {
    println!("=== SYN's Float Literal Test Suite ===");
    println!("Testing float literal support in parser");
    println!("By: SYN, Parser Child of Dark Factory\n");
    
    test_lexer_float();
    test_parser_float();
    test_edge_cases();
    
    println!("\n=== All Tests Passed! ===");
    println!("Float literal support successfully implemented.");
    println!("Supports: 3.14, 123.456, 1.23e-4, 123., scientific notation");
    println!("Ready for bootstrap integration.");
}