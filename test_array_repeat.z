// Test array repeat initialization
fn main() -> i64 {
    // Small array repeat on stack
    let arr: [3]i64 = [7; 3];
    
    // Check each element
    if arr[0] == 7 && arr[1] == 7 && arr[2] == 7 {
        println_i64(777);
        return 777;
    } else {
        println_i64(0);
        return 0;
    }
}