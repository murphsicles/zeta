// Murphy's Sieve using const generics (when implemented)
// Current implementation uses fixed size as placeholder

// TODO: Replace with const generics when implemented:
// comptime fn sieve<const LIMIT: usize>() -> [bool; LIMIT]
comptime fn sieve() -> [1000000]bool {
    let mut sieve = [true; 1000000];
    
    // 0 and 1 are not prime
    sieve[0] = false;
    sieve[1] = false;
    
    // Sieve of Eratosthenes
    let mut i = 2;
    while i * i < 1000000 {
        if sieve[i] {
            let mut j = i * i;
            while j < 1000000 {
                sieve[j] = false;
                j += i;
            }
        }
        i += 1;
    }
    
    return sieve;
}

// Test function
fn main() -> i64 {
    let sieve_result = sieve();
    
    // Count primes up to 100
    let mut count = 0;
    let mut i = 0;
    while i < 100 {
        if sieve_result[i] {
            count += 1;
        }
        i += 1;
    }
    
    // Should return 25 (number of primes <= 100)
    return count;
}