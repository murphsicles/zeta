// BASELINE TEST - What v0.3.7 CAN parse currently
// This file should ALWAYS compile with v0.3.7
// It represents the current capability baseline

// Simple function that v0.3.7 can handle
fn simple_function() -> i64 {
    return 42;
}

// Function with parameters
fn with_params(x: i64, y: i64) -> i64 {
    return x + y;
}

// Type alias (v0.3.7 supports this)
type MyType = i64;

// Using type alias
fn with_type_alias() -> MyType {
    return 42;
}

// What v0.3.7 CANNOT parse yet:
// fn with_generic() -> lt(Result, i64) {
//     return 0;
// }

// Main function - must exist for compilation
fn main() -> i64 {
    let a = simple_function();
    let b = with_params(10, 20);
    let c = with_type_alias();
    a + b + c
}