// div(zeta_src, frontend)/div(parser, parser).z
#[derive(Clone, Debug, PartialEq)]
enum Token {
    Ident(String),
    
    // v0.4.1 Keywords
    KeywordFn,
    KeywordConcept,
    KeywordImpl,
    KeywordStruct,
    KeywordEnum,
    KeywordReturn,
    KeywordIf,
    KeywordElse,
    KeywordDefer,
    KeywordSpawn,
    KeywordFor,
    
    // v0.5.0 New Keywords
    KeywordMatch,
    KeywordConst,
    KeywordAsync,
    KeywordAwait,
    KeywordPub,
    KeywordMod,
    KeywordTrait,  // Alias for Concept
    KeywordWhere,
    KeywordSelf,
    KeywordZorb,    // Equivalent to Rust's "crate"
    KeywordSuper,
    KeywordDyn,
    KeywordLoop,
    KeywordBreak,
    KeywordContinue,
    KeywordLet,
    KeywordMut,
    KeywordUse,
    KeywordType,
    KeywordUnsafe,
    KeywordExtern,
    KeywordCrate,   // Keep for compatibility, map to Zorb
    
    // Literals
    Lit(i64),
    FloatLit(f64),
    StringLit(String),
    
    // Punctuation
    LParen, RParen,
    LBrace, RBrace,
    LBracket, RBracket,
    Colon, Comma, Eq, Arrow,
    Plus, Minus, Star, Slash,
    Lt, Gt, Le, Ge, Ne, EqEq,  // Added comparison operators
    Dot, Question, Bang,
    Semi, ColonColon,
    At, Pound, Dollar,
    Underscore,
    Pipe, Amp, Caret, Tilde,
    Shl, Shr,  // << >>
    
    // v0.5.0: Range operators
    DotDot,        // ..
    DotDotEq,      // ..=
    
    // Compound assignment operators
    PlusEq,        // +=
    MinusEq,       // -=
    StarEq,        // *=
    SlashEq,       // /=
    AmpEq,         // &=
    PipeEq,        // |=
    CaretEq,       // ^=
    ShlEq,         // <<=
    ShrEq,         // >>=
    
    Eof,
}

struct Lexer {
    input: String,
    pos: i64,
    tokens: lt(Vec, Token)>,
}

impl Lexer {
    fn new(input: String) -> Self {
        Self { input, pos: 0, tokens: vec![] }
    }

    fn tokenize(&mut self) -> lt(Vec, Token)> {
        while self.lt(pos, self).input.len() as i64 {
            let ch = self.peek();
            if ch.is_whitespace() {
                self.skip_whitespace();
                continue;
            }
            if ch.is_alphabetic() || ch == '_' {
                self.lex_ident_or_keyword();
            } else if ch.is_digit(10) {
                self.lex_number();
            } else if ch == '"' {
                self.lex_string();
            } else {
                self.lex_symbol();
            }
        }
        self.tokens.push(Token::Eof);
        self.tokens.clone()
    }

    fn peek(&self) -> char {
        self.input.chars().nth(self.pos as usize).unwrap_or('\0')
    }

    fn peek_next(&self) -> char {
        self.input.chars().nth((self.add(pos, 1)) as usize).unwrap_or('\0')
    }

    fn advance(&mut self) {
        self.pos += 1;
    }

    fn skip_whitespace(&mut self) {
        while self.peek().is_whitespace() {
            self.advance();
        }
    }

    fn lex_ident_or_keyword(&mut self) {
        let mut word = String::new();
        while self.peek().is_alphanumeric() || self.peek() == '_' {
            word.push(self.peek());
            self.advance();
        }
        let tok = match word.as_str() {
            // v0.4.1 Keywords
            "fn" => Token::KeywordFn,
            "concept" => Token::KeywordConcept,
            "impl" => Token::KeywordImpl,
            "struct" => Token::KeywordStruct,
            "enum" => Token::KeywordEnum,
            "return" => Token::KeywordReturn,
            "if" => Token::KeywordIf,
            "else" => Token::KeywordElse,
            "defer" => Token::KeywordDefer,
            "spawn" => Token::KeywordSpawn,
            "for" => Token::KeywordFor,
            
            // v0.5.0 New Keywords
            "match" => Token::KeywordMatch,
            "const" => Token::KeywordConst,
            "async" => Token::KeywordAsync,
            "await" => Token::KeywordAwait,
            "pub" => Token::KeywordPub,
            "mod" => Token::KeywordMod,
            "trait" => Token::KeywordTrait,
            "where" => Token::KeywordWhere,
            "self" => Token::KeywordSelf,
            "zorb" => Token::KeywordZorb,
            "super" => Token::KeywordSuper,
            "dyn" => Token::KeywordDyn,
            "loop" => Token::KeywordLoop,
            "break" => Token::KeywordBreak,
            "continue" => Token::KeywordContinue,
            "let" => Token::KeywordLet,
            "mut" => Token::KeywordMut,
            "use" => Token::KeywordUse,
            "type" => Token::KeywordType,
            "unsafe" => Token::KeywordUnsafe,
            "extern" => Token::KeywordExtern,
            "crate" => Token::KeywordCrate,  // Map to Zorb internally
            
            _ => Token::Ident(word),
        };
        self.tokens.push(tok);
    }

    fn lex_number(&mut self) {
        let start_pos = self.pos;
        let mut is_float = false;
        
        // Parse integer part
        while self.peek().is_digit(10) {
            self.advance();
        }
        
        // Check for decimal point
        if self.peek() == '.' && self.peek_next().is_digit(10) {
            is_float = true;
            self.advance(); // consume '.'
            while self.peek().is_digit(10) {
                self.advance();
            }
        }
        
        // Check for exponent
        if self.peek() == 'e' || self.peek() == 'E' {
            is_float = true;
            self.advance(); // consume 'e' or 'E'
            
            // Optional sign
            if self.peek() == '+' || self.peek() == '-' {
                self.advance();
            }
            
            // Exponent digits
            while self.peek().is_digit(10) {
                self.advance();
            }
        }
        
        // Extract the number string
        let num_str = &self.input[start_pos as usize..self.pos as usize];
        
        if is_float {
            // Parse as float
            match num_str.parse::<f64>() {
                Ok(value) => self.tokens.push(Token::FloatLit(value)),
                Err(_) => {
                    // Fallback to integer if float parsing fails
                    if let Ok(int_val) = num_str.parse::<i64>() {
                        self.tokens.push(Token::Lit(int_val));
                    } else {
                        // Default to 0 if both fail
                        self.tokens.push(Token::Lit(0));
                    }
                }
            }
        } else {
            // Parse as integer
            match num_str.parse::<i64>() {
                Ok(value) => self.tokens.push(Token::Lit(value)),
                Err(_) => self.tokens.push(Token::Lit(0)),
            }
        }
    }

    fn lex_string(&mut self) {
        self.advance(); // opening "
        let mut s = String::new();
        while self.peek() != '"' && self.peek() != '\0' {
            if self.peek() == '\\' {
                self.advance(); // consume backslash
                s.push(self.parse_escape_sequence());
            } else {
                s.push(self.peek());
                self.advance();
            }
        }
        self.advance(); // closing "
        self.tokens.push(Token::StringLit(s));
    }
    
    fn parse_escape_sequence(&mut self) -> char {
        match self.peek() {
            'n' => { self.advance(); '\n' }
            't' => { self.advance(); '\t' }
            'r' => { self.advance(); '\r' }
            'b' => { self.advance(); '\x08' } // backspace
            'f' => { self.advance(); '\x0c' } // form feed
            '\\' => { self.advance(); '\\' }
            '"' => { self.advance(); '"' }
            '\'' => { self.advance(); '\'' }
            '0' => { self.advance(); '\0' }
            'x' => {
                self.advance(); // consume 'x'
                // Parse 2 hex digits
                let mut value = 0;
                for _ in 0..2 {
                    let ch = self.peek();
                    if ch.is_digit(16) {
                        let digit = ch.to_digit(16).unwrap_or(0);
                        value = value * 16 + digit;
                        self.advance();
                    }
                }
                // Convert to char (ASCII range)
                if value <= 0x7F {
                    value as u8 as char
                } else {
                    '?' // Fallback for non-ASCII
                }
            }
            'u' => {
                self.advance(); // consume 'u'
                if self.peek() == '{' {
                    self.advance(); // consume '{'
                    // Parse Unicode codepoint
                    let mut value = 0;
                    while self.peek().is_digit(16) {
                        let digit = self.peek().to_digit(16).unwrap_or(0);
                        value = value * 16 + digit;
                        self.advance();
                    }
                    if self.peek() == '}' {
                        self.advance(); // consume '}'
                    }
                    // Simple Unicode handling - for now just return placeholder
                    '�' // Unicode replacement character placeholder
                } else {
                    // Simple \uXXXX format (4 hex digits)
                    let mut value = 0;
                    for _ in 0..4 {
                        let ch = self.peek();
                        if ch.is_digit(16) {
                            let digit = ch.to_digit(16).unwrap_or(0);
                            value = value * 16 + digit;
                            self.advance();
                        }
                    }
                    '�' // Unicode replacement character placeholder
                }
            }
            _ => {
                // Unknown escape sequence, just include the character
                let c = self.peek();
                self.advance();
                c
            }
        }
    }
    


    fn lex_symbol(&mut self) {
        let ch = self.peek();
        let tok = match ch {
            '(' => Token::LParen,
            ')' => Token::RParen,
            '{' => Token::LBrace,
            '}' => Token::RBrace,
            '[' => Token::LBracket,
            ']' => Token::RBracket,
            
            ':' => {
                if self.peek_next() == ':' {
                    self.advance(); // consume first ':'
                    self.advance(); // consume second ':'
                    Token::ColonColon
                } else {
                    Token::Colon
                }
            },
            
            ',' => Token::Comma,
            
            '=' => {
                if self.peek_next() == '=' {
                    self.advance(); // consume first '='
                    self.advance(); // consume second '='
                    Token::EqEq
                } else {
                    Token::Eq
                }
            },
            
            '+' => {
                if self.peek_next() == '=' {
                    self.advance(); // consume '+'
                    self.advance(); // consume '='
                    Token::PlusEq
                } else {
                    Token::Plus
                }
            },
            
            '-' => {
                if self.peek_next() == '>' {
                    self.advance(); // consume '-'
                    self.advance(); // consume '>'
                    Token::Arrow
                } else if self.peek_next() == '=' {
                    self.advance(); // consume '-'
                    self.advance(); // consume '='
                    Token::MinusEq
                } else {
                    Token::Minus
                }
            },
            
            '*' => {
                if self.peek_next() == '=' {
                    self.advance(); // consume '*'
                    self.advance(); // consume '='
                    Token::StarEq
                } else {
                    Token::Star
                }
            },
            '/' => {
                if self.peek_next() == '=' {
                    self.advance(); // consume '/'
                    self.advance(); // consume '='
                    Token::SlashEq
                } else {
                    Token::Slash
                }
            },
            
            '<' => {
                if self.peek_next() == '<' {
                    self.advance(); // consume first '<'
                    if self.peek_next() == '=' {
                        self.advance(); // consume second '<'
                        self.advance(); // consume '='
                        Token::ShlEq
                    } else {
                        self.advance(); // consume second '<'
                        Token::Shl
                    }
                } else if self.peek_next() == '=' {
                    self.advance(); // consume '<'
                    self.advance(); // consume '='
                    Token::Le
                } else {
                    Token::Lt
                }
            },
            
            '>' => {
                if self.peek_next() == '>' {
                    self.advance(); // consume first '>'
                    if self.peek_next() == '=' {
                        self.advance(); // consume second '>'
                        self.advance(); // consume '='
                        Token::ShrEq
                    } else {
                        self.advance(); // consume second '>'
                        Token::Shr
                    }
                } else if self.peek_next() == '=' {
                    self.advance(); // consume '>'
                    self.advance(); // consume '='
                    Token::Ge
                } else {
                    Token::Gt
                }
            },
            
            '.' => {
                if self.peek_next() == '.' {
                    self.advance(); // consume first '.'
                    if self.peek_next() == '=' {
                        self.advance(); // consume second '.'
                        self.advance(); // consume '='
                        Token::DotDotEq
                    } else {
                        self.advance(); // consume second '.'
                        Token::DotDot
                    }
                } else {
                    Token::Dot
                }
            },
            
            '?' => Token::Question,
            '!' => Token::Bang,
            ';' => Token::Semi,
            '@' => Token::At,
            '#' => Token::Pound,
            '$' => Token::Dollar,
            '_' => Token::Underscore,
            '|' => {
                if self.peek_next() == '=' {
                    self.advance(); // consume '|'
                    self.advance(); // consume '='
                    Token::PipeEq
                } else {
                    Token::Pipe
                }
            },
            '&' => {
                if self.peek_next() == '=' {
                    self.advance(); // consume '&'
                    self.advance(); // consume '='
                    Token::AmpEq
                } else {
                    Token::Amp
                }
            },
            '^' => {
                if self.peek_next() == '=' {
                    self.advance(); // consume '^'
                    self.advance(); // consume '='
                    Token::CaretEq
                } else {
                    Token::Caret
                }
            },
            '~' => Token::Tilde,
            
            '!' => {
                if self.peek_next() == '=' {
                    self.advance(); // consume '!'
                    self.advance(); // consume '='
                    Token::Ne
                } else {
                    Token::Bang
                }
            },
            
            _ => Token::Eof,
        };
        
        if ne(tok, Token)::ColonColon && ne(tok, Token)::EqEq && ne(tok, Token)::Arrow && 
           ne(tok, Token)::Shl && ne(tok, Token)::Shr && ne(tok, Token)::Le && 
           ne(tok, Token)::Ge && ne(tok, Token)::DotDot && ne(tok, Token)::DotDotEq &&
           ne(tok, Token)::Ne && ne(tok, Token)::PlusEq && ne(tok, Token)::MinusEq &&
           ne(tok, Token)::StarEq && ne(tok, Token)::SlashEq && ne(tok, Token)::AmpEq &&
           ne(tok, Token)::PipeEq && ne(tok, Token)::CaretEq && ne(tok, Token)::ShlEq &&
           ne(tok, Token)::ShrEq {
            self.advance(); // Only advance if we didn't already consume multiple chars
        }
        
        self.tokens.push(tok);
    }
}
