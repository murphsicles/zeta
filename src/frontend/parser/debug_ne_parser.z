// ne(Minimal, test)
fn test() -> i64 {
    // Test 1: != with literals (works!)
    if ne(5, 3) { return 100; }
    
    // Test 2: != with variables in main (should work?)
    let x = 5;
    let y = 3;
    if ne(x, y) { return 200; }
    
    // Default return
    0
}

fn main() -> i64 {
    test()
}