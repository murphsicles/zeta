// zeta_src/frontend/parser/parser.z
#[derive(Clone, Debug, PartialEq)]
enum Token {
    Ident(String),
    
    // v0.4.1 Keywords
    KeywordFn,
    KeywordConcept,
    KeywordImpl,
    KeywordStruct,
    KeywordEnum,
    KeywordReturn,
    KeywordIf,
    KeywordElse,
    KeywordDefer,
    KeywordSpawn,
    KeywordFor,
    
    // v0.5.0 New Keywords
    KeywordMatch,
    KeywordConst,
    KeywordAsync,
    KeywordAwait,
    KeywordPub,
    KeywordMod,
    KeywordTrait,  // Alias for Concept
    KeywordWhere,
    KeywordSelf,
    KeywordZorb,    // Equivalent to Rust's "crate"
    KeywordSuper,
    KeywordDyn,
    KeywordLoop,
    KeywordBreak,
    KeywordContinue,
    KeywordLet,
    KeywordMut,
    KeywordUse,
    KeywordType,
    KeywordUnsafe,
    KeywordExtern,
    KeywordCrate,   // Keep for compatibility, map to Zorb
    
    // Literals
    Lit(i64),
    StringLit(String),
    
    // Punctuation
    LParen, RParen,
    LBrace, RBrace,
    LBracket, RBracket,
    Colon, Comma, Eq, Arrow,
    Plus, Minus, Star, Slash,
    Lt, Gt, Le, Ge, Ne, EqEq,  // Added comparison operators
    Dot, Question, Bang,
    Semi, ColonColon,
    At, Pound, Dollar,
    Underscore,
    Pipe, Amp, Caret, Tilde,
    Shl, Shr,  // << >>
    
    // v0.5.0: Range operators
    DotDot,        // ..
    DotDotEq,      // ..=
    
    Eof,
}

struct Lexer {
    input: String,
    pos: i64,
    tokens: Vec<Token>,
}

impl Lexer {
    fn new(input: String) -> Self {
        Self { input, pos: 0, tokens: vec![] }
    }

    fn tokenize(&mut self) -> Vec<Token> {
        while self.pos < self.input.len() as i64 {
            let ch = self.peek();
            if ch.is_whitespace() {
                self.skip_whitespace();
                continue;
            }
            if ch.is_alphabetic() || ch == '_' {
                self.lex_ident_or_keyword();
            } else if ch.is_digit(10) {
                self.lex_number();
            } else if ch == '"' {
                self.lex_string();
            } else {
                self.lex_symbol();
            }
        }
        self.tokens.push(Token::Eof);
        self.tokens.clone()
    }

    fn peek(&self) -> char {
        self.input.chars().nth(self.pos as usize).unwrap_or('\0')
    }

    fn peek_next(&self) -> char {
        self.input.chars().nth((self.pos + 1) as usize).unwrap_or('\0')
    }

    fn advance(&mut self) {
        self.pos += 1;
    }

    fn skip_whitespace(&mut self) {
        while self.peek().is_whitespace() {
            self.advance();
        }
    }

    fn lex_ident_or_keyword(&mut self) {
        let mut word = String::new();
        while self.peek().is_alphanumeric() || self.peek() == '_' {
            word.push(self.peek());
            self.advance();
        }
        let tok = match word.as_str() {
            // v0.4.1 Keywords
            "fn" => Token::KeywordFn,
            "concept" => Token::KeywordConcept,
            "impl" => Token::KeywordImpl,
            "struct" => Token::KeywordStruct,
            "enum" => Token::KeywordEnum,
            "return" => Token::KeywordReturn,
            "if" => Token::KeywordIf,
            "else" => Token::KeywordElse,
            "defer" => Token::KeywordDefer,
            "spawn" => Token::KeywordSpawn,
            "for" => Token::KeywordFor,
            
            // v0.5.0 New Keywords
            "match" => Token::KeywordMatch,
            "const" => Token::KeywordConst,
            "async" => Token::KeywordAsync,
            "await" => Token::KeywordAwait,
            "pub" => Token::KeywordPub,
            "mod" => Token::KeywordMod,
            "trait" => Token::KeywordTrait,
            "where" => Token::KeywordWhere,
            "self" => Token::KeywordSelf,
            "zorb" => Token::KeywordZorb,
            "super" => Token::KeywordSuper,
            "dyn" => Token::KeywordDyn,
            "loop" => Token::KeywordLoop,
            "break" => Token::KeywordBreak,
            "continue" => Token::KeywordContinue,
            "let" => Token::KeywordLet,
            "mut" => Token::KeywordMut,
            "use" => Token::KeywordUse,
            "type" => Token::KeywordType,
            "unsafe" => Token::KeywordUnsafe,
            "extern" => Token::KeywordExtern,
            "crate" => Token::KeywordCrate,  // Map to Zorb internally
            
            _ => Token::Ident(word),
        };
        self.tokens.push(tok);
    }

    fn lex_number(&mut self) {
        let mut num: i64 = 0;
        while self.peek().is_digit(10) {
            num = num * 10 + (self.peek() as i64 - '0' as i64);
            self.advance();
        }
        self.tokens.push(Token::Lit(num));
    }

    fn lex_string(&mut self) {
        self.advance(); // opening "
        let mut s = String::new();
        while self.peek() != '"' && self.peek() != '\0' {
            s.push(self.peek());
            self.advance();
        }
        self.advance(); // closing "
        self.tokens.push(Token::StringLit(s));
    }

    fn lex_symbol(&mut self) {
        let ch = self.peek();
        let tok = match ch {
            '(' => Token::LParen,
            ')' => Token::RParen,
            '{' => Token::LBrace,
            '}' => Token::RBrace,
            '[' => Token::LBracket,
            ']' => Token::RBracket,
            
            ':' => {
                if self.peek_next() == ':' {
                    self.advance(); // consume first ':'
                    self.advance(); // consume second ':'
                    Token::ColonColon
                } else {
                    Token::Colon
                }
            },
            
            ',' => Token::Comma,
            
            '=' => {
                if self.peek_next() == '=' {
                    self.advance(); // consume first '='
                    self.advance(); // consume second '='
                    Token::EqEq
                } else {
                    Token::Eq
                }
            },
            
            '+' => Token::Plus,
            
            '-' => {
                if self.peek_next() == '>' {
                    self.advance(); // consume '-'
                    self.advance(); // consume '>'
                    Token::Arrow
                } else {
                    Token::Minus
                }
            },
            
            '*' => Token::Star,
            '/' => Token::Slash,
            
            '<' => {
                if self.peek_next() == '<' {
                    self.advance(); // consume first '<'
                    self.advance(); // consume second '<'
                    Token::Shl
                } else if self.peek_next() == '=' {
                    self.advance(); // consume '<'
                    self.advance(); // consume '='
                    Token::Le
                } else {
                    Token::Lt
                }
            },
            
            '>' => {
                if self.peek_next() == '>' {
                    self.advance(); // consume first '>'
                    self.advance(); // consume second '>'
                    Token::Shr
                } else if self.peek_next() == '=' {
                    self.advance(); // consume '>'
                    self.advance(); // consume '='
                    Token::Ge
                } else {
                    Token::Gt
                }
            },
            
            '.' => {
                if self.peek_next() == '.' {
                    self.advance(); // consume first '.'
                    if self.peek_next() == '=' {
                        self.advance(); // consume second '.'
                        self.advance(); // consume '='
                        Token::DotDotEq
                    } else {
                        self.advance(); // consume second '.'
                        Token::DotDot
                    }
                } else {
                    Token::Dot
                }
            },
            
            '?' => Token::Question,
            '!' => Token::Bang,
            ';' => Token::Semi,
            '@' => Token::At,
            '#' => Token::Pound,
            '$' => Token::Dollar,
            '_' => Token::Underscore,
            '|' => Token::Pipe,
            '&' => Token::Amp,
            '^' => Token::Caret,
            '~' => Token::Tilde,
            
            '!' => {
                if self.peek_next() == '=' {
                    self.advance(); // consume '!'
                    self.advance(); // consume '='
                    Token::Ne
                } else {
                    Token::Bang
                }
            },
            
            _ => Token::Eof,
        };
        
        if tok != Token::ColonColon && tok != Token::EqEq && tok != Token::Arrow && 
           tok != Token::Shl && tok != Token::Shr && tok != Token::Le && 
           tok != Token::Ge && tok != Token::DotDot && tok != Token::DotDotEq &&
           tok != Token::Ne {
            self.advance(); // Only advance if we didn't already consume multiple chars
        }
        
        self.tokens.push(tok);
    }
}
