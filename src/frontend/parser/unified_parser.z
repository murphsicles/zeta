    // Helper methods needed by ML parser
    pub fn peek_keyword(&self, keyword: &str) -> bool {
        if let Token::Ident(ident) = self.peek() {
            ident == keyword
        } else {
            false
        }
    }
    
    pub fn peek_doc_comment(&self) -> bool {
        // Check if next token is a doc comment
        false // Simplified for now
    }
    
    pub fn parse_doc_comment(&mut self) -> Result<String, String> {
        Ok(String::new()) // Simplified for now
    }
    
    pub fn parse_type(&mut self) -> Result<String, String> {
        // Simplified type parsing
        if let Token::Ident(ty) = self.peek() {
            self.advance();
            Ok(ty)
        } else {
            Err("Expected type identifier".to_string())
        }
    }
    
    pub fn parse_type_name(&mut self) -> Result<String, String> {
        self.parse_type()
    }
    
    pub fn parse_nested_array(&mut self) -> Result<(Vec<AstNode>, Vec<i64>), String> {
        // Simplified nested array parsing
        Ok((vec![], vec![]))
    }
    
    pub fn parse_function_body(&mut self) -> Result<(Vec<AstNode>, Vec<String>, String), String> {
