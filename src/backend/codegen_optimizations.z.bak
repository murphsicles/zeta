// zeta_src/backend/codegen_optimizations.z
// v0.5.0 Code Generation Optimizations
// Missing Phase 3 items recovered and completed

use crate::frontend::ast::AstNode;
use super::codegen_v5::{CodeGeneratorV5, CodeGenContext};

impl CodeGeneratorV5 {
    /// Complete match expression generation with all strategies
    pub fn gen_match_complete(&mut self, expr: &AstNode, arms: &[AstNode]) -> Result<(), String> {
        let value = self.gen_expression(expr)?;
        let strategy = self.choose_match_strategy_complete(arms);
        
        match strategy {
            MatchStrategy::JumpTable => self.gen_match_jump_table_complete(value, arms),
            MatchStrategy::BinarySearch => self.gen_match_binary_search_complete(value, arms),
            MatchStrategy::DecisionTree => self.gen_match_decision_tree_complete(value, arms),
            MatchStrategy::IfChain => self.gen_match_if_chain_complete(value, arms),
            MatchStrategy::Hybrid => self.gen_match_hybrid(value, arms),
        }
    }
    
    /// Enhanced strategy selection
    fn choose_match_strategy_complete(&self, arms: &[AstNode]) -> MatchStrategy {
        if arms.len() == 0 {
            return MatchStrategy::IfChain;
        }
        
        // Analyze arm patterns
        let mut integer_arms = 0;
        let mut range_arms = 0;
        let mut pattern_arms = 0;
        let mut guard_arms = 0;
        
        for arm in arms {
            if let AstNode::MatchArm { pattern, guard, .. } = arm {
                match pattern {
                    AstNode::PatternLiteral(_) => integer_arms += 1,
                    AstNode::PatternRange { .. } => range_arms += 1,
                    _ => pattern_arms += 1,
                }
                if guard.is_some() {
                    guard_arms += 1;
                }
            }
        }
        
        // Choose optimal strategy
        if pattern_arms > 0 || guard_arms > 0 {
            // Complex patterns or guards need decision trees
            MatchStrategy::DecisionTree
        } else if integer_arms + range_arms >= 8 {
            // Many integer/range arms benefit from binary search
            MatchStrategy::BinarySearch
        } else if integer_arms >= 4 && self.is_dense_integer_match(arms) {
            // Dense integer matches use jump tables
            MatchStrategy::JumpTable
        } else if arms.len() <= 4 {
            // Small matches use simple if chains
            MatchStrategy::IfChain
        } else {
            // Hybrid approach for medium complexity
            MatchStrategy::Hybrid
        }
    }
    
    /// Check if integer match is dense enough for jump table
    fn is_dense_integer_match(&self, arms: &[AstNode]) -> bool {
        let mut values = Vec::new();
        
        for arm in arms {
            if let AstNode::MatchArm { pattern, .. } = arm {
                if let AstNode::PatternLiteral(expr) = pattern {
                    if let AstNode::Lit(n) = expr.as_ref() {
                        values.push(*n);
                    }
                }
            }
        }
        
        if values.len() < 4 {
            return false;
        }
        
        values.sort();
        let min = values[0];
        let max = values[values.len() - 1];
        let range = (max - min) as usize;
        
        // Dense if range <= 4 * number of values
        range <= values.len() * 4
    }
    
    /// Complete jump table generation with range support
    fn gen_match_jump_table_complete(&mut self, value: llvm::Value, arms: &[AstNode]) -> Result<(), String> {
        let func = self.context.current_function.as_ref()
            .ok_or("No current function".to_string())?;
        
        // Create blocks
        let mut arm_blocks = vec![];
        let default_block = self.context.module.append_basic_block(func, "match_default");
        let end_block = self.context.module.append_basic_block(func, "match_end");
        
        for (i, arm) in arms.iter().enumerate() {
            let block = self.context.module.append_basic_block(func, &format!("match_arm_{}", i));
            arm_blocks.push((i, block, arm));
        }
        
        // Build switch for integer arms
        let switch = self.context.builder.build_switch(value, default_block, arms.len());
        
        // Add cases
        for (i, block, arm) in &arm_blocks {
            if let AstNode::MatchArm { pattern, .. } = arm {
                match pattern {
                    AstNode::PatternLiteral(expr) => {
                        if let AstNode::Lit(n) = expr.as_ref() {
                            let case_value = self.context.builder.get_int64(*n as u64);
                            switch.add_case(case_value, *block);
                        }
                    }
                    AstNode::PatternRange { start, end, inclusive } => {
                        // Generate range check in arm block
                        // Will be handled in arm code generation
                    }
                    _ => {
                        // Other patterns go to default
                    }
                }
            }
        }
        
        // Generate arm code
        for (i, block, arm) in arm_blocks {
            self.context.builder.position_at_end(block);
            
            if let AstNode::MatchArm { pattern, guard, body } = arm {
                // Generate guard check if present
                if let Some(g) = guard {
                    let guard_block = self.context.module.append_basic_block(func, &format!("match_guard_{}", i));
                    let fail_block = self.context.module.append_basic_block(func, &format!("match_guard_fail_{}", i));
                    
                    let guard_value = self.gen_expression(g)?;
                    self.context.builder.build_cond_br(guard_value, guard_block, fail_block);
                    
                    // Guard success
                    self.context.builder.position_at_end(guard_block);
                    
                    // Generate body
                    for stmt in body {
                        self.gen_statement(stmt)?;
                    }
                    self.context.builder.build_br(end_block);
                    
                    // Guard failure
                    self.context.builder.position_at_end(fail_block);
                    self.context.builder.build_br(default_block);
                } else {
                    // Generate body directly
                    for stmt in body {
                        self.gen_statement(stmt)?;
                    }
                    self.context.builder.build_br(end_block);
                }
            }
        }
        
        // Default block (for patterns not in switch)
        self.context.builder.position_at_end(default_block);
        
        // Generate decision tree for remaining patterns
        let remaining_arms: Vec<_> = arms.iter()
            .enumerate()
            .filter(|(i, arm)| {
                if let AstNode::MatchArm { pattern, .. } = arm {
                    !matches!(pattern, AstNode::PatternLiteral(_))
                } else {
                    true
                }
            })
            .collect();
        
        if !remaining_arms.is_empty() {
            self.gen_match_decision_tree_for_arms(value, &remaining_arms, end_block)?;
        } else {
            self.context.builder.build_br(end_block);
        }
        
        // End block
        self.context.builder.position_at_end(end_block);
        
        Ok(())
    }
    
    /// Complete decision tree generation
    fn gen_match_decision_tree_complete(&mut self, value: llvm::Value, arms: &[AstNode]) -> Result<(), String> {
        let func = self.context.current_function.as_ref()
            .ok_or("No current function".to_string())?;
        
        let end_block = self.context.module.append_basic_block(func, "match_end");
        
        // Build decision tree recursively
        self.gen_decision_tree_recursive(value, arms, 0, arms.len(), end_block)?;
        
        self.context.builder.position_at_end(end_block);
        Ok(())
    }
    
    /// Recursive decision tree builder
    fn gen_decision_tree_recursive(&mut self, value: llvm::Value, arms: &[AstNode], 
                                  start: usize, end: usize, end_block: llvm::BasicBlock) -> Result<(), String> {
        if start >= end {
            return Ok(());
        }
        
        if end - start == 1 {
            // Single arm - generate it
            return self.gen_match_arm(value, &arms[start], end_block);
        }
        
        let func = self.context.current_function.as_ref()
            .ok_or("No current function".to_string())?;
        
        // Choose pivot (middle for balanced tree)
        let pivot = (start + end) / 2;
        
        // Create blocks
        let left_block = self.context.module.append_basic_block(func, &format!("match_left_{}_{}", start, pivot));
        let right_block = self.context.module.append_basic_block(func, &format!("match_right_{}_{}", pivot, end));
        
        // Generate test for pivot
        let test_result = self.gen_pattern_test(value, &arms[pivot])?;
        self.context.builder.build_cond_br(test_result, left_block, right_block);
        
        // Generate left subtree (matches pivot)
        self.context.builder.position_at_end(left_block);
        self.gen_match_arm(value, &arms[pivot], end_block)?;
        
        // Generate right subtree (doesn't match pivot)
        self.context.builder.position_at_end(right_block);
        self.gen_decision_tree_recursive(value, arms, start, pivot, end_block)?;
        self.gen_decision_tree_recursive(value, arms, pivot + 1, end, end_block)?;
        
        Ok(())
    }
    
    /// Generate pattern test
    fn gen_pattern_test(&mut self, value: llvm::Value, arm: &AstNode) -> Result<llvm::Value, String> {
        if let AstNode::MatchArm { pattern, .. } = arm {
            match pattern {
                AstNode::PatternLiteral(expr) => {
                    let pattern_value = self.gen_expression(expr)?;
                    let cmp = self.context.builder.build_icmp(
                        llvm::IntPredicate::EQ,
                        value,
                        pattern_value,
                        "pattern_cmp"
                    );
                    Ok(cmp)
                }
                AstNode::PatternRange { start, end, inclusive } => {
                    let start_val = self.gen_expression(start)?;
                    let end_val = self.gen_expression(end)?;
                    
                    let ge_start = self.context.builder.build_icmp(
                        llvm::IntPredicate::SGE,
                        value,
                        start_val,
                        "range_start"
                    );
                    
                    let le_end = self.context.builder.build_icmp(
                        if *inclusive { llvm::IntPredicate::SLE } else { llvm::IntPredicate::SLT },
                        value,
                        end_val,
                        "range_end"
                    );
                    
                    let and = self.context.builder.build_and(ge_start, le_end, "range_and");
                    Ok(and)
                }
                _ => {
                    // For complex patterns, generate more sophisticated tests
                    // For now, return true (will be refined)
                    Ok(self.context.builder.get_true())
                }
            }
        } else {
            Err("Expected match arm".to_string())
        }
    }
    
    /// Generate single match arm
    fn gen_match_arm(&mut self, value: llvm::Value, arm: &AstNode, end_block: llvm::BasicBlock) -> Result<(), String> {
        if let AstNode::MatchArm { guard, body, .. } = arm {
            let func = self.context.current_function.as_ref()
                .ok_or("No current function".to_string())?;
            
            if let Some(g) = guard {
                let guard_block = self.context.module.append_basic_block(func, "match_guard");
                let guard_fail = self.context.module.append_basic_block(func, "match_guard_fail");
                
                let guard_value = self.gen_expression(g)?;
                self.context.builder.build_cond_br(guard_value, guard_block, guard_fail);
                
                // Guard success
                self.context.builder.position_at_end(guard_block);
                for stmt in body {
                    self.gen_statement(stmt)?;
                }
                self.context.builder.build_br(end_block);
                
                // Guard failure
                self.context.builder.position_at_end(guard_fail);
                // Continue to next pattern (will be handled by caller)
            } else {
                // No guard, generate body directly
                for stmt in body {
                    self.gen_statement(stmt)?;
                }
                self.context.builder.build_br(end_block);
            }
        }
        
        Ok(())
    }
    
    /// Generate binary search for sparse integer matches
    fn gen_match_binary_search_complete(&mut self, value: llvm::Value, arms: &[AstNode]) -> Result<(), String> {
        let func = self.context.current_function.as_ref()
            .ok_or("No current function".to_string())?;
        
        let end_block = self.context.module.append_basic_block(func, "match_end");
        
        // Extract integer values
        let mut values = Vec::new();
        let mut arm_map = HashMap::new();
        
        for (i, arm) in arms.iter().enumerate() {
            if let AstNode::MatchArm { pattern, .. } = arm {
                if let AstNode::PatternLiteral(expr) = pattern {
                    if let AstNode::Lit(n) = expr.as_ref() {
                        values.push(*n);
                        arm_map.insert(*n, i);
                    }
                }
            }
        }
        
        values.sort();
        
        // Generate binary search
        self.gen_binary_search_recursive(value, &values, &arm_map, arms, 0, values.len(), end_block)?;
        
        self.context.builder.position_at_end(end_block);
        Ok(())
    }
    
    /// Recursive binary search generator
    fn gen_binary_search_recursive(&mut self, value: llvm::Value, values: &[i64], 
                                  arm_map: &HashMap<i64, usize>, arms: &[AstNode],
                                  start: usize, end: usize, end_block: llvm::BasicBlock) -> Result<(), String> {
        if start >= end {
            return Ok(());
        }
        
        let func = self.context.current_function.as_ref()
            .ok_or("No current function".to_string())?;
        
        if end - start == 1 {
            // Single value - check equality
            let val = values[start];
            let arm_idx = arm_map[&val];
            
            let eq_block = self.context.module.append_basic_block(func, "binary_eq");
            let ne_block = self.context.module.append_basic_block(func, "binary_ne");
            
            let cmp_value = self.context.builder.get_int64(val as u64);
            let cmp = self.context.builder.build_icmp(
                llvm::IntPredicate::EQ,
                value,
                cmp_value,
                "binary_cmp"
            );
            
            self.context.builder.build_cond_br(cmp, eq_block, ne_block);
            
            // Equality branch
            self.context.builder.position_at_end(eq_block);
            self.gen_match_arm(value, &arms[arm_idx], end_block)?;
            
            // Inequality branch
            self.context.builder.position_at_end(ne_block);
            // Continue (no match)
            
            return Ok(());
        }
        
        // Split range
        let mid = (start + end) / 2;
        let mid_val = values[mid];
        
        let left_block = self.context.module.append_basic_block(func, "binary_left");
        let right_block = self.context.module.append_basic_block(func, "binary_right");
        
        // Compare with middle value
        let cmp_value = self.context.builder.get_int64(mid_val as u64);
        let cmp = self.context.builder.build_icmp(
            llvm::IntPredicate::SLT,
            value,
            cmp_value,
            "binary_split"
        );
        
        self.context.builder.build_cond_br(cmp, left_block, right_block);
        
        // Left subtree (value < mid)
        self.context.builder.position_at_end(left_block);
        self.gen_binary_search_recursive(value, values, arm_map, arms, start, mid, end_block)?;
        
        // Right subtree (value >= mid)
        self.context.builder.position_at_end(right_block);
        self.gen_binary_search_recursive(value, values, arm_map, arms, mid, end, end_block)?;
        
        Ok(())
    }
    
    /// Hybrid match generation (combination of strategies)
    fn gen_match_hybrid(&mut self, value: llvm::Value, arms: &[AstNode]) -> Result<(), String> {
        // Separate arms by type
        let mut integer_arms = vec![];
        let mut other_arms = vec![];
        
        for arm in arms {
            if let AstNode::MatchArm { pattern, .. } = arm {
                match pattern {
                    AstNode::PatternLiteral(_) | AstNode::PatternRange { .. } => {
                        integer_arms.push(arm);
                    }
                    _ => {
                        other_arms.push(arm);
                    }
                }
            }
        }
        
        let func = self.context.current_function.as_ref()
            .ok_or("No current function".to_string())?;
        
        let end_block = self.context.module.append_basic_block(func, "match_end");
        
        if !integer_arms.is_empty() {
            // Generate jump table or binary search for integers
            if integer_arms.len() >= 8 && self.is_dense_integer_match(&integer_arms) {
                self.gen_match_jump_table_complete(value, &integer_arms)?;
            } else if integer_arms.len() >= 4 {
                self.gen_match_binary_search_complete(value, &integer_arms)?;
            } else {
                self.gen_match_if_chain_complete(value, &integer_arms)?;
            }
        }
        
        if !other_arms.is_empty() {
            // Generate decision tree for other patterns
            let other_block = self.context.module.append_basic_block(func, "match_other");
            self.context.builder.build_br(other_block);
            self.context