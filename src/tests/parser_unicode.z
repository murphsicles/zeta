// zeta_src/tests/parser_unicode.z
// Unicode identifier test suite for Zeta parser

fn test_unicode_identifiers() {
    // Test ASCII identifiers (should work)
    let ascii_ident = "test";
    let ascii_ident2 = "test123";
    let ascii_ident3 = "_test";
    let ascii_ident4 = "test_123";
    
    // Test basic Unicode identifiers
    // Greek letters
    let greek_alpha = "α";
    let greek_beta = "β";
    let greek_ident = "μεταβλητή"; // Greek word for "variable"
    
    // Cyrillic letters
    let cyrillic_ident = "переменная"; // Russian word for "variable"
    
    // CJK characters
    let cjk_ident = "变量"; // Chinese for "variable"
    
    // Mixed scripts
    let mixed_ident = "test123αβγ";
    let mixed_ident2 = "変数123test"; // Japanese + ASCII
    
    // Identifiers with combining marks
    // Note: These might not work with simple is_alphanumeric()
    let combining_ident = "café"; // e with acute accent
    let combining_ident2 = "naïve"; // i with diaeresis
    
    // Test that these parse as identifiers
    // We'll need to actually parse them to verify
    println!("Testing Unicode identifier support...");
    
    // Simple test: try to use these as variable names
    let α = 42;
    let β = α + 1;
    let μεταβλητή = "test";
    let переменная = 123;
    let 变量 = true;
    let café = "coffee";
    let naïve = true;
    
    println!("α = {}", α);
    println!("β = {}", β);
    println!("μεταβλητή = {}", μεταβλητή);
    println!("переменная = {}", переменная);
    println!("变量 type = {}", 变量);
    println!("café = {}", café);
    println!("naïve = {}", naïve);
    
    // Test function with Unicode parameter
    fn print_希腊字母(字母: string) {
        println!("希腊字母: {}", 字母);
    }
    
    print_希腊字母("αβγ");
    
    // Test struct with Unicode field names
    struct 用户 {
        名字: string,
        年龄: i64,
        活跃: bool,
    }
    
    let 用户1 = 用户 {
        名字: "张三",
        年龄: 30,
        活跃: true,
    };
    
    println!("用户: {} (年龄: {}, 活跃: {})", 用户1.名字, 用户1.年龄, 用户1.活跃);
}

fn main() {
    test_unicode_identifiers();
    println("All Unicode identifier tests completed!");
}