// zeta_src/tests/parser_inherent_impl.z
// Inherent impl block test suite for Zeta parser

// Test 1: Basic inherent impl block
impl MyStruct {
    fn new() -> MyStruct {
        MyStruct { x: 0 }
    }
    
    fn get_x(&self) -> i64 {
        self.x
    }
    
    fn set_x(&mut self, x: i64) {
        self.x = x
    }
}

// Test 2: Inherent impl block with generics
impl Vec<T> {
    fn push(&mut self, item: T) {
        // Implementation
    }
    
    fn pop(&mut self) -> Option<T> {
        // Implementation
        None
    }
}

// Test 3: Multiple methods in inherent impl
impl Counter {
    fn new() -> Counter {
        Counter { count: 0 }
    }
    
    fn increment(&mut self) {
        self.count += 1
    }
    
    fn get(&self) -> i64 {
        self.count
    }
    
    fn reset(&mut self) {
        self.count = 0
    }
}

// Test 4: Inherent impl with associated functions (no self)
impl MathUtils {
    fn add(a: i64, b: i64) -> i64 {
        a + b
    }
    
    fn multiply(a: i64, b: i64) -> i64 {
        a * b
    }
}

// Test 5: Mixed inherent and trait impl blocks
struct Point {
    x: f64,
    y: f64,
}

// Inherent impl block
impl Point {
    fn new(x: f64, y: f64) -> Point {
        Point { x, y }
    }
    
    fn distance_from_origin(&self) -> f64 {
        (self.x * self.x + self.y * self.y).sqrt()
    }
}

// Trait definition
trait Display {
    fn display(&self) -> string;
}

// Trait impl block (for comparison)
impl Display for Point {
    fn display(&self) -> string {
        format!("Point({}, {})", self.x, self.y)
    }
}

// Test 6: Inherent impl with method chaining
impl Builder {
    fn new() -> Builder {
        Builder { value: 0 }
    }
    
    fn with_value(mut self, value: i64) -> Builder {
        self.value = value
        self
    }
    
    fn build(self) -> Built {
        Built { value: self.value }
    }
}

// Test 7: Complex inherent impl with multiple generics
impl HashMap<K, V> {
    fn new() -> HashMap<K, V> {
        HashMap { data: vec![] }
    }
    
    fn insert(&mut self, key: K, value: V) -> Option<V> {
        // Implementation
        None
    }
    
    fn get(&self, key: &K) -> Option<&V> {
        // Implementation
        None
    }
}

// Main test function
fn test_inherent_impl_blocks() {
    println!("Testing inherent impl blocks...");
    
    // Test basic inherent impl
    let mut counter = Counter::new();
    counter.increment();
    println!("Counter value: {}", counter.get());
    
    // Test Point inherent impl
    let point = Point::new(3.0, 4.0);
    println!("Distance from origin: {}", point.distance_from_origin());
    
    // Test MathUtils associated functions
    let sum = MathUtils::add(5, 3);
    let product = MathUtils::multiply(5, 3);
    println!("Sum: {}, Product: {}", sum, product);
    
    // Test Builder pattern
    let built = Builder::new()
        .with_value(42)
        .build();
    println!("Built value: {}", built.value);
    
    println!("All inherent impl block tests completed!");
}

fn main() {
    test_inherent_impl_blocks();
}