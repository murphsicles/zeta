// Test program for bulletproof memory system
fn test_basic_allocation() -> i64 {
    // Test 1: Basic allocation and free
    let ptr: i64 = runtime_malloc(100);
    if ptr == 0 {
        return -1;
    }
    
    // Test 2: Write to memory
    let data: *mut u8 = ptr as *mut u8;
    let mut i: i64 = 0;
    while i < 100 {
        unsafe { *data.offset(i as isize) = i as u8; }
        i += 1;
    }
    
    // Test 3: Bounds check (should succeed)
    let checked = runtime_check_bounds(ptr, 50, 1);
    if checked == 0 {
        runtime_free(ptr);
        return -2;
    }
    
    // Test 4: Bounds check (should fail and report error)
    let bad_check = runtime_check_bounds(ptr, 150, 1);
    if bad_check != 0 {
        runtime_free(ptr);
        return -3;
    }
    
    // Test 5: Free memory
    runtime_free(ptr);
    
    // Test 6: Double-free detection (should report corruption but not crash)
    runtime_free(ptr);
    
    0
}

fn test_array_bounds() -> i64 {
    // Test array bounds checking
    let arr: [i64; 5] = [1, 2, 3, 4, 5];
    let mut sum: i64 = 0;
    let mut i: i64 = 0;
    
    // This should work correctly
    while i < 5 {
        sum += arr[i as usize];
        i += 1;
    }
    
    // Try to access out of bounds (simulated)
    // In the real implementation, this would be caught by runtime_check_bounds
    // For now, we just test that the basic array works
    if sum != 15 {
        return -10;
    }
    
    sum
}

fn test_memory_corruption() -> i64 {
    // Test memory corruption detection
    let ptr: i64 = runtime_malloc(50);
    if ptr == 0 {
        return -20;
    }
    
    // Write some data
    let data: *mut u8 = ptr as *mut u8;
    for i in 0..50 {
        unsafe { *data.offset(i as isize) = (i * 2) as u8; }
    }
    
    // Corrupt the header (simulated - in real test we'd need to access header directly)
    // This is to test that free detects corruption
    
    runtime_free(ptr);
    
    0
}

fn main() -> i64 {
    println_str("Testing bulletproof memory system...");
    
    // Test 1: Basic allocation
    let result1 = test_basic_allocation();
    if result1 != 0 {
        println_str("Basic allocation test failed");
        return result1;
    }
    println_str("Basic allocation test passed");
    
    // Test 2: Array bounds
    let result2 = test_array_bounds();
    if result2 != 15 {
        println_str("Array bounds test failed");
        return -100;
    }
    println_str("Array bounds test passed");
    
    // Test 3: Memory corruption
    let result3 = test_memory_corruption();
    if result3 != 0 {
        println_str("Memory corruption test failed");
        return result3;
    }
    println_str("Memory corruption test passed");
    
    // Test 4: Calloc
    let ptr = runtime_calloc(10, 8); // 10 elements of 8 bytes each
    if ptr == 0 {
        println_str("Calloc test failed");
        return -200;
    }
    
    // Check that memory is zeroed
    let data: *mut i64 = ptr as *mut i64;
    for i in 0..10 {
        if unsafe { *data.offset(i as isize) } != 0 {
            println_str("Calloc memory not zeroed");
            runtime_free(ptr);
            return -201;
        }
    }
    
    runtime_free(ptr);
    println_str("Calloc test passed");
    
    // Test 5: Realloc
    let ptr1 = runtime_malloc(20);
    if ptr1 == 0 {
        println_str("Realloc test failed (malloc)");
        return -300;
    }
    
    // Write some data
    let data1: *mut u8 = ptr1 as *mut u8;
    for i in 0..20 {
        unsafe { *data1.offset(i as isize) = i as u8; }
    }
    
    let ptr2 = runtime_realloc(ptr1, 40);
    if ptr2 == 0 {
        println_str("Realloc test failed (realloc)");
        return -301;
    }
    
    // Check that old data was preserved
    let data2: *mut u8 = ptr2 as *mut u8;
    for i in 0..20 {
        if unsafe { *data2.offset(i as isize) } != i as u8 {
            println_str("Realloc did not preserve data");
            runtime_free(ptr2);
            return -302;
        }
    }
    
    runtime_free(ptr2);
    println_str("Realloc test passed");
    
    println_str("All bulletproof memory tests passed!");
    0
}