// Test v0.5.0 style code compilation (synchronous)
// Using features that should be supported

// Generic function (v0.5.0 style)
fn identity<T>(value: T) -> T {
    value
}

// Struct with methods
struct Point {
    x: i64,
    y: i64,
}

impl Point {
    fn new(x: i64, y: i64) -> Point {
        Point { x, y }
    }
    
    fn add(&self, other: &Point) -> Point {
        Point {
            x: self.x + other.x,
            y: self.y + other.y,
        }
    }
}

// Main function using features
fn main() -> i64 {
    // Generic function call
    let x = identity(10);
    
    // Struct usage
    let p1 = Point::new(1, 2);
    let p2 = Point::new(3, 4);
    let p3 = p1.add(&p2);
    
    p3.x + p3.y + x
}