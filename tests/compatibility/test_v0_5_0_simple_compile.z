// Test v0.5.0 style code compilation
// Using features that should be supported

// Generic function (v0.5.0 style)
fn identity<T>(value: T) -> T {
    value
}

// Struct with methods
struct Point {
    x: i64,
    y: i64,
}

impl Point {
    fn new(x: i64, y: i64) -> Point {
        Point { x, y }
    }
    
    fn add(&self, other: &Point) -> Point {
        Point {
            x: self.x + other.x,
            y: self.y + other.y,
        }
    }
}

// Match expression
fn classify_number(n: i64) -> &'static str {
    match n {
        0 => "zero",
        1..=9 => "single digit",
        _ if n < 0 => "negative",
        _ => "positive",
    }
}

// Async function (new feature)
async fn fetch_value() -> i64 {
    42
}

// Main function using all features
async fn main() -> i64 {
    // Generic function call
    let x = identity(10);
    
    // Struct usage
    let p1 = Point::new(1, 2);
    let p2 = Point::new(3, 4);
    let p3 = p1.add(&p2);
    
    // Match expression
    let desc = classify_number(x);
    
    // Async await
    let fetched = fetch_value().await;
    
    p3.x + p3.y + fetched
}