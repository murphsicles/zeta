fn test() -> bool {
    return true
}

fn is_prime(n: u64) -> bool {
    if n < 2 {
        return false
    }
    if n == 2 {
        return true
    }
    if n % 2 == 0 {
        return false
    }
    let mut i = 3
    while i * i <= n {
        if n % i == 0 {
            return false
        }
        i = i + 2
    }
    return true
}

fn main() {
    let result = test()
    let prime_check = is_prime(17)
}