// Comprehensive test of bool return types

// 1. Simple bool return
fn simple_true() -> bool {
    return true
}

fn simple_false() -> bool {
    return false
}

// 2. Bool return with comparison
fn is_zero(n: i64) -> bool {
    return n == 0
}

// 3. Bool return with logical operators
fn in_range(x: i64, min: i64, max: i64) -> bool {
    x >= min && x <= max
}

// 4. Bool return with if-else
fn max(a: i64, b: i64) -> i64 {
    if a > b {
        return a
    } else {
        return b
    }
}

// 5. Complex bool expression (the original failing case)
fn between(x: i64, a: i64, b: i64) -> bool {
    x >= a && x <= b
}

// 6. Bool return with arithmetic and comparison
fn is_even(n: u64) -> bool {
    n % 2 == 0
}

// 7. Nested bool expressions
fn complex_logic(a: bool, b: bool, c: bool) -> bool {
    (a && b) || (!a && c)
}

// 8. The original is_prime function
fn is_prime(n: u64) -> bool {
    if n < 2 {
        return false
    }
    if n == 2 {
        return true
    }
    if n % 2 == 0 {
        return false
    }
    let mut i = 3
    while i * i <= n {
        if n % i == 0 {
            return false
        }
        i = i + 2
    }
    return true
}

fn main() {
    let t = simple_true()
    let f = simple_false()
    let z = is_zero(0)
    let r = in_range(5, 0, 10)
    let m = max(3, 7)
    let b = between(5, 0, 10)
    let e = is_even(42)
    let l = complex_logic(true, false, true)
    let p = is_prime(17)
}