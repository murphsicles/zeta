// Test program for bootstrap compiler - while loops
// This should be compilable by the enhanced minimal Zeta compiler

fn test_simple_while() -> i64 {
    let counter = 0;
    
    while (counter < 5) {
        counter = counter + 1;
    }
    
    return counter;
}

fn test_while_with_break() -> i64 {
    let i = 0;
    let sum = 0;
    
    while (true) {
        if (i >= 10) {
            break;
        }
        sum = sum + i;
        i = i + 1;
    }
    
    return sum;
}

fn test_nested_while() -> i64 {
    let i = 0;
    let j = 0;
    let result = 0;
    
    while (i < 3) {
        j = 0;
        while (j < 3) {
            result = result + (i * j);
            j = j + 1;
        }
        i = i + 1;
    }
    
    return result;
}

fn test_while_with_condition_update() -> i64 {
    let x = 10;
    
    while (x > 0) {
        x = x - 1;
    }
    
    return x;
}

fn test_while_factorial() -> i64 {
    let n = 5;
    let result = 1;
    let i = 1;
    
    while (i <= n) {
        result = result * i;
        i = i + 1;
    }
    
    return result;
}

fn test_while_with_if_inside() -> i64 {
    let i = 0;
    let even_sum = 0;
    let odd_sum = 0;
    
    while (i < 10) {
        if (i % 2 == 0) {
            even_sum = even_sum + i;
        } else {
            odd_sum = odd_sum + i;
        }
        i = i + 1;
    }
    
    return even_sum + odd_sum;
}

fn main() -> i64 {
    let test1 = test_simple_while();
    let test2 = test_while_with_break();
    let test3 = test_nested_while();
    let test4 = test_while_with_condition_update();
    let test5 = test_while_factorial();
    let test6 = test_while_with_if_inside();
    
    return test1 + test2 + test3 + test4 + test5 + test6;
}