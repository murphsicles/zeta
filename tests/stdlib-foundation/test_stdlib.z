// Test standard library imports
use std::malloc
use std::free
use std::print
use std::println

fn main() {
    // Test malloc and free
    let ptr = malloc<u64>(10)
    if ptr != 0 {
        println("malloc succeeded")
        free(ptr)
        println("free succeeded")
    } else {
        println("malloc failed")
    }
    
    // Test print functions
    print("Hello ")
    println("World!")
}