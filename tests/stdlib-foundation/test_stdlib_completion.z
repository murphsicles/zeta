// Test program to verify stdlib completion
// Tests env, time, and math modules

fn test_env() {
    // Test environment variables
    let test_key = "ZETA_TEST_ENV";
    let test_value = "test_value_123";
    
    // Set and get environment variable
    std::env::set_var(test_key, test_value);
    let retrieved = std::env::var(test_key).expect("Should get env var");
    assert(retrieved == test_value, "Env var value should match");
    
    // Clean up
    std::env::remove_var(test_key);
    
    // Test current directory
    let current_dir = std::env::current_dir().expect("Should get current dir");
    println("Current directory: ", current_dir);
    
    // Test command line args
    let args = std::env::args();
    println("Number of args: ", args.len());
    
    // Test OS info
    let os = std::env::consts::OS;
    let arch = std::env::consts::ARCH;
    println("OS: ", os, ", Arch: ", arch);
}

fn test_time() {
    // Test system time
    let now = std::time::SystemTime::now();
    let since_epoch = now.duration_since(std::time::UNIX_EPOCH).expect("Time should be after epoch");
    println("Seconds since epoch: ", since_epoch.as_secs());
    
    // Test instant for performance timing
    let start = std::time::Instant::now();
    // Do some work
    let mut sum = 0;
    for i in 0..1000 {
        sum += i;
    }
    let elapsed = start.elapsed();
    println("Time elapsed: ", elapsed.as_micros(), " microseconds");
    
    // Test duration
    let one_sec = std::time::Duration::from_secs(1);
    assert(one_sec.as_millis() == 1000, "1 second should be 1000 milliseconds");
    assert(one_sec.as_micros() == 1_000_000, "1 second should be 1,000,000 microseconds");
    
    // Test sleep
    println("Sleeping for 100ms...");
    std::thread::sleep(std::time::Duration::from_millis(100));
    println("Awake!");
}

fn test_math() {
    // Test constants
    println("PI = ", std::math::PI);
    println("E = ", std::math::E);
    println("SQRT2 = ", std::math::SQRT2);
    
    // Test trigonometric functions
    let angle = std::math::PI / 4.0; // 45 degrees
    println("sin(PI/4) = ", std::math::sin(angle));
    println("cos(PI/4) = ", std::math::cos(angle));
    println("tan(PI/4) = ", std::math::tan(angle));
    
    // Test exponential and logarithmic functions
    println("exp(1.0) = ", std::math::exp(1.0));
    println("ln(10.0) = ", std::math::ln(10.0));
    println("log10(100.0) = ", std::math::log10(100.0));
    println("log2(8.0) = ", std::math::log2(8.0));
    
    // Test power and root functions
    println("2^3 = ", std::math::pow(2.0, 3.0));
    println("sqrt(16) = ", std::math::sqrt(16.0));
    println("cbrt(27) = ", std::math::cbrt(27.0));
    println("hypot(3, 4) = ", std::math::hypot(3.0, 4.0));
    
    // Test PrimeZeta specific functions
    println("gcd(42, 56) = ", std::math::gcd(42, 56));
    println("lcm(6, 8) = ", std::math::lcm(6, 8));
    println("is_prime(17) = ", std::math::is_prime(17));
    println("is_prime(18) = ", std::math::is_prime(18));
    println("next_prime(20) = ", std::math::next_prime(20));
    
    // Test prime factors
    let factors = std::math::prime_factors(60);
    println("Prime factors of 60:");
    let mut i = 0;
    while factors[i] != 0 {
        println("  ", factors[i], "^", factors[i + 1]);
        i += 2;
    }
}

fn main() {
    println("Testing stdlib completion...");
    
    println("\n=== Testing Environment Module ===");
    test_env();
    
    println("\n=== Testing Time Module ===");
    test_time();
    
    println("\n=== Testing Math Module ===");
    test_math();
    
    println("\n=== All tests passed! ===");
}