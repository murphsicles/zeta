// Test runner for compiler improvements
// This file tests the basic functionality of the improved compiler

// Test 1: Basic compilation
fn basic_test() -> i32 {
    let x = 10;
    let y = 20;
    x + y
}

// Test 2: Constant folding
fn constant_folding_test() -> i32 {
    // Should be folded to 30 at compile time
    10 + 20
}

// Test 3: Dead code elimination
fn dead_code_test() -> i32 {
    let x = 10;
    let y = 20; // Should be eliminated (unused)
    let z = 30; // Should be eliminated (unused)
    x
}

// Test 4: Function with parameters
fn add(a: i32, b: i32) -> i32 {
    a + b
}

// Test 5: Control flow
fn control_flow_test(n: i32) -> i32 {
    let mut sum = 0;
    for i in 0..n {
        sum += i;
    }
    sum
}

// Test 6: Recursive function
fn factorial(n: i32) -> i32 {
    if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    }
}

// Test 7: Type inference
fn type_inference_test() -> i32 {
    let x = 10; // Should infer i32
    let y = 20; // Should infer i32
    x + y
}

// Test 8: Compile-time constants
const COMPILE_TIME_CONST: i32 = 100;

fn const_test() -> i32 {
    COMPILE_TIME_CONST * 2
}

// Test 9: Module system test
mod math {
    pub fn add(a: i32, b: i32) -> i32 {
        a + b
    }
}

// Test 10: Error handling (compile-time)
fn error_handling_test() -> Result<i32, String> {
    Ok(42)
}

// Main test runner
fn main() {
    println!("=== Zeta Compiler Improvements Test Runner ===");
    println!("Version: v0.3.38");
    println!();
    
    // Run all tests
    println!("Test 1 - Basic compilation: {}", basic_test());
    println!("Test 2 - Constant folding: {}", constant_folding_test());
    println!("Test 3 - Dead code elimination: {}", dead_code_test());
    println!("Test 4 - Function with parameters: {}", add(5, 7));
    println!("Test 5 - Control flow: {}", control_flow_test(5));
    println!("Test 6 - Recursive function (factorial 5): {}", factorial(5));
    println!("Test 7 - Type inference: {}", type_inference_test());
    println!("Test 8 - Compile-time constants: {}", const_test());
    println!("Test 9 - Module system: {}", math::add(3, 4));
    
    match error_handling_test() {
        Ok(value) => println!("Test 10 - Error handling: {}", value),
        Err(e) => println!("Test 10 - Error handling failed: {}", e),
    }
    
    println!();
    println!("All tests completed!");
    
    // Additional optimization tests
    println!();
    println!("=== Optimization Tests ===");
    
    // Test loop invariant code motion (conceptual)
    let n = 100;
    let invariant = 42 * 100; // Should be moved outside loop if in a loop
    let mut sum = 0;
    for i in 0..n {
        sum += i + invariant;
    }
    println!("Loop with invariant: {}", sum);
    
    // Test common subexpression elimination (conceptual)
    let a = 10;
    let b = 20;
    let expr1 = a * a + 2 * a * b + b * b;
    let expr2 = a * a + 2 * a * b + b * b; // Same as expr1
    println!("Common subexpression: {} + {} = {}", expr1, expr2, expr1 + expr2);
    
    println!();
    println!("Compiler improvements verified!");
}