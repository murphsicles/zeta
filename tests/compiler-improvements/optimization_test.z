// Test file for compiler optimization improvements
// This file contains code patterns that should be optimized

// Test 1: Dead code elimination
fn dead_code_test() -> i32 {
    let x = 10;
    let y = 20; // y is never used - should be eliminated
    let z = 30; // z is never used - should be eliminated
    
    // This entire block should be eliminated since condition is always false
    if false {
        println!("Dead code");
        return 100;
    }
    
    x // Only x is used
}

// Test 2: Constant folding and propagation
fn constant_folding_test() -> i32 {
    // All these should be folded at compile time
    let a = 2 + 3 * 4; // Should become 14
    let b = (10 - 5) / 2; // Should become 2
    let c = 1 << 4; // Should become 16
    
    a + b + c // Should become 32
}

// Test 3: Common subexpression elimination
fn common_subexpression_test(x: i32, y: i32) -> i32 {
    // a and b compute the same expression - b should reuse a's computation
    let a = x * x + 2 * x * y + y * y;
    let b = x * x + 2 * x * y + y * y; // Same as a
    
    a + b // Should be optimized to 2 * a
}

// Test 4: Loop invariant code motion
fn loop_invariant_test(n: i32) -> i32 {
    let mut sum = 0;
    let invariant = 42 * 100; // This is loop invariant
    
    for i in 0..n {
        // invariant should be moved outside the loop
        sum += i + invariant;
    }
    
    sum
}

// Test 5: Strength reduction
fn strength_reduction_test(n: i32) -> i32 {
    let mut result = 0;
    
    // Multiplication by 2 should become shift
    for i in 0..n {
        result += i * 2; // Should become i << 1
    }
    
    // Division by power of 2 should become shift
    result = result / 4; // Should become result >> 2
    
    result
}

// Test 6: Tail recursion optimization
fn factorial_tail_recursive(n: i32, acc: i32) -> i32 {
    if n <= 1 {
        acc
    } else {
        factorial_tail_recursive(n - 1, n * acc) // Should be optimized to loop
    }
}

// Test 7: Inlining
#[inline(always)]
fn small_helper(a: i32, b: i32) -> i32 {
    a + b
}

fn inlining_test() -> i32 {
    // small_helper should be inlined
    let x = small_helper(10, 20);
    let y = small_helper(30, 40);
    
    x + y
}

// Test 8: Unused parameter elimination
fn unused_param_test(used: i32, unused: i32) -> i32 {
    // unused parameter should be eliminated
    used * 2
}

// Test 9: Constant propagation through control flow
fn constant_propagation_test(flag: bool) -> i32 {
    let x;
    if flag {
        x = 10;
    } else {
        x = 20;
    }
    
    // If flag is known at compile time, x should be constant
    x * 2
}

// Test 10: Algebraic simplification
fn algebraic_simplification_test(a: i32, b: i32) -> i32 {
    // These should be simplified
    let x = a * 0; // Should become 0
    let y = b + 0; // Should become b
    let z = a * 1; // Should become a
    
    x + y + z // Should become a + b
}

// Main function to run all tests
fn main() {
    println!("Dead code test: {}", dead_code_test());
    println!("Constant folding test: {}", constant_folding_test());
    println!("Common subexpression test: {}", common_subexpression_test(3, 4));
    println!("Loop invariant test: {}", loop_invariant_test(5));
    println!("Strength reduction test: {}", strength_reduction_test(10));
    println!("Tail recursion test: {}", factorial_tail_recursive(5, 1));
    println!("Inlining test: {}", inlining_test());
    println!("Unused param test: {}", unused_param_test(10, 99));
    println!("Constant propagation test: {}", constant_propagation_test(true));
    println!("Algebraic simplification test: {}", algebraic_simplification_test(5, 7));
}