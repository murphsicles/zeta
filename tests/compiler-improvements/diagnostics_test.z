// E4001: Division by zero (compile-time detectable)
fn div_by_zero_test() {
    let x = 10 / 0; // Should warn about division by zero
}

// E8001: Dead code
fn dead_code_test() {
    let x = 10;
    let y = 20; // y is never used
    println!("{}", x);
    
    if false {
        println!("This will never execute"); // Dead code
    }
}

// Test for constant propagation warnings
fn constant_propagation_test() {
    const PI: f64 = 3.14159;
    let radius = 5.0;
    let area = PI * radius * radius;
    
    // The compiler should be able to compute this at compile time
    let computed = 2 + 2 * 2; // Should be constant folded to 6
}

// Test for unused imports warning
use std::collections::HashMap; // This import is never used

fn main() {
    parse_error_test();
    string_error_test();
    brace_error_test();
    type_mismatch_test();
    undefined_type_test();
    inference_error_test();
    undefined_variable_test();
    duplicate_test();
    div_by_zero_test();
    dead_code_test();
    constant_propagation_test();
}