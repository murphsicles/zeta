// E2001: Type mismatch
fn type_mismatch_test() {
    let x: i32 = 10.5; // Should trigger type mismatch
}

// E2002: Undefined type
fn undefined_type_test() {
    let x: UnknownType = 10; // UnknownType not defined
}

// E2003: Cannot infer type
fn inference_error_test() {
    let x = ; // Missing initializer
}

// E3001: Undefined variable
fn undefined_variable_test() {
    println!(undefined_var); // undefined_var not defined
}

// E3002: Duplicate definition
fn duplicate_test() {
    // Will be defined twice
}

fn duplicate_test() {
    // Duplicate function definition
