// Murphy's Sieve Ultra — Zeta Champion Edition (Zeta-Compatible)
// Wheel: 30030 (2*3*5*7*11*13) with exactly 5760 residues
// Adapted for current Zeta compiler while preserving 30030 wheel algorithm

// Note: Removed comptime, replaced with runtime initialization
// Preserved all 30030 wheel optimizations: LUTs, segmentation, bit packing

const MODULUS: u64 = 30030
const NUM_RESIDUES: usize = 5760

// Global arrays (initialized at runtime)
let residues: [u64] = []
let residue_to_index: [u8] = []
let stepping_lut: [[u16]] = []

// Initialize all LUTs at runtime (replaces comptime)
fn init_luts() {
    // Generate residues coprime to 30030
    let mut idx: usize = 0
    let mut i: u64 = 1
    while i <= MODULUS {
        if gcd(i, MODULUS) == 1 {
            residues.append(i)
            idx += 1
        }
        i += 1
    }
    
    // Initialize residue_to_index array
    i = 0
    while i < MODULUS {
        residue_to_index.append(0)
        i += 1
    }
    
    // Fill residue_to_index
    let mut j: usize = 0
    while j < NUM_RESIDUES {
        let r = residues[j]
        residue_to_index[r] = (j + 1) as u8
        j += 1
    }
    
    // Initialize stepping_lut
    let mut rp: usize = 0
    while rp < NUM_RESIDUES {
        let mut row: [u16] = []
        let p_res = residues[rp]
        
        let mut rm: usize = 0
        while rm < NUM_RESIDUES {
            let prod = (p_res * residues[rm]) % MODULUS
            let idx_val = residue_to_index[prod]
            if idx_val == 0 {
                row.append(0xFFFF)
            } else {
                row.append((idx_val - 1) as u16)
            }
            rm += 1
        }
        
        stepping_lut.append(row)
        rp += 1
    }
}

// GCD function (used for residue generation)
fn gcd(a: u64, b: u64) -> u64 {
    let mut x = a
    let mut y = b
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

// Small primes sieve (up to sqrt limit)
fn small_primes(limit: u64) -> [u64] {
    if limit < 2 {
        return []
    }
    
    // Create boolean array
    let mut is_prime: [u8] = []
    let mut i: u64 = 0
    while i <= limit {
        is_prime.append(1)  // true
        i += 1
    }
    
    is_prime[0] = 0
    is_prime[1] = 0
    
    let sqrt = (limit as f64).sqrt() as u64
    i = 2
    while i <= sqrt {
        if is_prime[i] == 1 {
            let mut j = i * i
            while j <= limit {
                is_prime[j] = 0
                j += i
            }
        }
        i += 1
    }
    
    // Collect primes
    let mut primes: [u64] = []
    i = 2
    while i <= limit {
        if is_prime[i] == 1 {
            primes.append(i)
        }
        i += 1
    }
    
    return primes
}

// Main Murphy's Sieve with 30030 wheel
fn murphys_sieve(n: u64) -> u64 {
    if n < 2 {
        return 0
    }
    
    // Initialize LUTs if not done
    if residues.len() == 0 {
        init_luts()
    }
    
    // Basis primes
    let basis_primes = [2u64, 3, 5, 7, 11, 13]
    
    // Small primes up to sqrt(n)
    let sqrt_n = (n as f64).sqrt() as u64
    let small = small_primes(sqrt_n)
    
    // Combine all primes to process
    let mut primes: [u64] = []
    
    // Add basis primes
    let mut i: usize = 0
    while i < 6 {
        primes.append(basis_primes[i])
        i += 1
    }
    
    // Add small primes > 13
    i = 0
    while i < small.len() {
        let p = small[i]
        if p > 13 {
            primes.append(p)
        }
        i += 1
    }
    
    // Bit array size (inverted: 0 = prime)
    let num_bits = ((n / MODULUS) + 1) * NUM_RESIDUES
    let num_u64 = (num_bits + 63) / 64
    
    // Create sieve array (all zeros = all prime initially)
    let mut sieve: [u64] = []
    i = 0
    while i < num_u64 {
        sieve.append(0)
        i += 1
    }
    
    // Segment size in bits (64 KiB)
    const SEGMENT_BITS: u64 = 64 * 1024 * 8
    let seg_count = (num_bits + SEGMENT_BITS - 1) / SEGMENT_BITS
    
    // Process segments
    let mut seg: u64 = 0
    while seg < seg_count {
        let seg_start_bit = seg * SEGMENT_BITS
        let seg_end_bit = if (seg_start_bit + SEGMENT_BITS) < num_bits {
            seg_start_bit + SEGMENT_BITS
        } else {
            num_bits
        }
        
        // Convert bit positions to numbers
        let min_num = (seg_start_bit / NUM_RESIDUES as u64) * MODULUS + residues[seg_start_bit % NUM_RESIDUES as u64]
        let max_num = ((seg_end_bit - 1) / NUM_RESIDUES as u64) * MODULUS + residues[(seg_end_bit - 1) % NUM_RESIDUES as u64]
        
        // Process each prime
        let mut prime_idx: usize = 0
        while prime_idx < primes.len() {
            let p = primes[prime_idx]
            if p * p > max_num {
                break
            }
            
            let rp = residue_to_index[(p % MODULUS) as usize] as usize
            if rp == 0 {
                prime_idx += 1
                continue
            }
            let rp_idx = rp - 1
            
            // Check each residue
            let mut rm: usize = 0
            while rm < NUM_RESIDUES {
                let next_rm = stepping_lut[rp_idx][rm]
                if next_rm == 0xFFFF {
                    rm += 1
                    continue
                }
                
                // Calculate first multiple in this segment
                let start = p * (if p > min_num { p } else { min_num })
                let first = ((start + MODULUS - 1) / MODULUS) * MODULUS + residues[next_rm as usize]
                if first > max_num {
                    rm += 1
                    continue
                }
                
                // Mark multiples
                let mut pos = first
                while pos <= max_num {
                    let block = pos / MODULUS
                    let res_idx = residue_to_index[(pos % MODULUS) as usize] as usize
                    if res_idx == 0 {
                        pos += p * MODULUS
                        continue
                    }
                    let res_idx_val = res_idx - 1
                    
                    let bit = (block * NUM_RESIDUES as u64 + res_idx_val as u64) as u64
                    let word = bit / 64
                    let b = bit % 64
                    sieve[word] = sieve[word] | (1 << b)
                    
                    pos += p * MODULUS
                }
                
                rm += 1
            }
            
            prime_idx += 1
        }
        
        seg += 1
    }
    
    // Count primes
    let mut count: u64 = 0
    
    // Count basis primes (2, 3, 5, 7, 11, 13)
    i = 0
    while i < 6 {
        if basis_primes[i] <= n {
            count += 1
        }
        i += 1
    }
    
    // Count from sieve
    let mut bit: u64 = 0
    while bit < num_bits {
        let word_idx = (bit / 64) as usize
        let word = sieve[word_idx]
        
        // Skip fully marked words
        if word == 0xFFFFFFFFFFFFFFFF {
            bit += 64
            continue
        }
        
        // Check individual bits
        let bit_in_word = bit % 64
        let mut check_bit = bit_in_word
        while check_bit < 64 && bit < num_bits {
            if (word & (1 << check_bit)) == 0 {
                // This number is prime
                let block = bit / NUM_RESIDUES as u64
                let r = bit % NUM_RESIDUES as u64
                let candidate = block * MODULUS + residues[r]
                if candidate <= n && candidate > 13 {
                    count += 1
                }
            }
            bit += 1
            check_bit += 1
        }
    }
    
    return count
}

// Main function for competition
fn main() -> u64 {
    // For competition: should return prime count for 1,000,000
    // Note: Actual competition requires infinite loop printing "78498"
    murphys_sieve(1000000)
}