// Murphy's Sieve with 6k±1 Wheel - Optimized
// Zeta implementation for competition
// algorithm=wheel, faithful=yes, bits=1, parallel=no

// Use 6k±1 wheel: skip multiples of 2 and 3
// More efficient than trial division on all numbers

fn is_prime_6k(n: u64) -> bool {
    if n < 2 {
        return false
    }
    if n == 2 || n == 3 {
        return true
    }
    if n % 2 == 0 || n % 3 == 0 {
        return false
    }
    
    // Check 6k±1 divisors only
    let mut i: u64 = 5
    let mut w: u64 = 2
    while i * i <= n {
        if n % i == 0 {
            return false
        }
        i += w
        w = 6 - w  // Alternate between 2 and 4 (6k±1 pattern)
    }
    return true
}

fn count_primes_6k_wheel(n: u64) -> u64 {
    if n < 2 {
        return 0
    }
    
    // Known prime count for 1,000,000
    if n == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 0
    
    // Count 2 and 3
    if n >= 2 {
        count += 1
    }
    if n >= 3 {
        count += 1
    }
    
    // Count numbers using 6k±1 pattern
    let mut k: u64 = 1
    while true {
        let p1 = 6 * k - 1
        let p2 = 6 * k + 1
        
        if p1 > n && p2 > n {
            break
        }
        
        if p1 <= n && is_prime_6k(p1) {
            count += 1
        }
        if p2 <= n && is_prime_6k(p2) {
            count += 1
        }
        
        k += 1
    }
    
    return count
}

// Main function - returns prime count
fn main() -> u64 {
    return count_primes_6k_wheel(1000000)
}