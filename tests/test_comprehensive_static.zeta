// Comprehensive test for static method type checking
struct Point {
    x: i64,
    y: i64,
}

impl Point {
    // Static constructor
    fn new(x: i64, y: i64) -> Point {
        Point { x, y }
    }
    
    // Another static method
    fn origin() -> Point {
        Point { x: 0, y: 0 }
    }
    
    // Instance method
    fn sum(&self) -> i64 {
        self.x + self.y
    }
}

struct Rectangle {
    top_left: Point,
    bottom_right: Point,
}

impl Rectangle {
    // Static method with struct parameter
    fn from_points(p1: Point, p2: Point) -> Rectangle {
        Rectangle { top_left: p1, bottom_right: p2 }
    }
}

fn main() {
    // Test 1: Basic static method call
    let p1 = Point::new(10, 20);
    
    // Test 2: Static method with no arguments
    let origin = Point::origin();
    
    // Test 3: Instance method call (should still work)
    let total = p1.sum();
    
    // Test 4: Static method with struct arguments
    let rect = Rectangle::from_points(p1, origin);
    
    // All of these should type-check correctly
}