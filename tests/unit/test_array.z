// Test bulletproof array features in Zeta
fn main() -> i64 {
    // Test 1: Create and use an array
    let arr = [1, 2, 3, 4, 5]
    
    // Test 2: Array indexing
    let sum = arr[0] + arr[1] + arr[2] + arr[3] + arr[4]
    
    // Test 3: Array with bool (mentioned in status)
    let bool_arr = [true, false, true, false, true]
    let bool_count = 0
    for i in 0..5 {
        if bool_arr[i] {
            bool_count = bool_count + 1
        }
    }
    
    // Return combined result
    sum + bool_count
}

// Test function to demonstrate array operations
fn test_array_operations() -> i64 {
    // Create array with capacity
    let mut arr = [0; 10]
    
    // Fill array
    for i in 0..10 {
        arr[i] = i * 2
    }
    
    // Calculate sum
    let mut total = 0
    for i in 0..10 {
        total = total + arr[i]
    }
    
    total
}