// CONST GENERICS VALIDATION TEST
// Test that const generics actually work in the compiler

// Test 1: Basic const generic function
comptime fn sieve<const LIMIT: usize>() -> [bool; LIMIT] {
    let mut arr: [bool; LIMIT] = [true; LIMIT];
    // Simple sieve logic - mark 0 and 1 as not prime
    if LIMIT > 0 {
        arr[0] = false;
    }
    if LIMIT > 1 {
        arr[1] = false;
    }
    return arr
}

// Test 2: Function with multiple const parameters
comptime fn matrix<const ROWS: usize, const COLS: usize>() -> [[f64; COLS]; ROWS] {
    let mut mat: [[f64; COLS]; ROWS] = [[0.0; COLS]; ROWS];
    
    // Initialize with some pattern
    let mut i = 0;
    while i < ROWS {
        let mut j = 0;
        while j < COLS {
            mat[i][j] = (i * COLS + j) as f64;
            j += 1;
        }
        i += 1;
    }
    
    return mat
}

// Test 3: CTFE with const expressions
const BASE_SIZE: usize = 10;
const DOUBLE_SIZE: usize = BASE_SIZE * 2;
const SQUARE_SIZE: usize = BASE_SIZE * BASE_SIZE;

comptime fn create_array<const SIZE: usize>() -> [i32; SIZE] {
    let mut arr: [i32; SIZE] = [0; SIZE];
    
    let mut i = 0;
    while i < SIZE {
        arr[i] = (i * i) as i32;
        i += 1;
    }
    
    return arr
}

// Test 4: ArraySize unification test
fn process_array<const N: usize>(arr: [i32; N]) -> i32 {
    let mut sum = 0;
    let mut i = 0;
    while i < N {
        sum += arr[i];
        i += 1;
    }
    return sum
}

// Test 5: Murphy's Sieve with const generics (main test)
comptime fn murphy_sieve<const LIMIT: usize>() -> [bool; LIMIT] {
    let mut sieve = [true; LIMIT];
    
    // 0 and 1 are not prime
    if LIMIT > 0 {
        sieve[0] = false;
    }
    if LIMIT > 1 {
        sieve[1] = false;
    }
    
    // Sieve of Eratosthenes
    let mut i = 2;
    while i * i < LIMIT {
        if sieve[i] {
            let mut j = i * i;
            while j < LIMIT {
                sieve[j] = false;
                j += i;
            }
        }
        i += 1;
    }
    
    return sieve
}

// Main function to test everything
fn main() -> i64 {
    // Test 1: Basic sieve
    let sieve100 = sieve::<100>();
    let sieve1000 = sieve::<1000>();
    
    // Test 2: Matrix
    let mat3x3 = matrix::<3, 3>();
    let mat5x10 = matrix::<5, 10>();
    
    // Test 3: CTFE arrays
    let base_array = create_array::<BASE_SIZE>();
    let double_array = create_array::<DOUBLE_SIZE>();
    let square_array = create_array::<SQUARE_SIZE>();
    
    // Test 4: Array processing
    let test_arr: [i32; 5] = [1, 2, 3, 4, 5];
    let sum1 = process_array::<5>(test_arr);
    
    // Test 5: Murphy's Sieve
    let murphy100 = murphy_sieve::<100>();
    let murphy1000 = murphy_sieve::<1000>();
    
    // Count primes in Murphy's Sieve up to 100
    let mut prime_count = 0;
    let mut i = 0;
    while i < 100 {
        if murphy100[i] {
            prime_count += 1;
        }
        i += 1;
    }
    
    // Return prime count (should be 25 for primes <= 100)
    return prime_count
}