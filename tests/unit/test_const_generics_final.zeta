// FINAL CONST GENERICS VALIDATION TEST
// Test that const generics actually work in the compiler

// Test 1: Basic const generic function - Murphy's Sieve
comptime fn murphy_sieve<const LIMIT: usize>() -> [bool; LIMIT] {
    let mut sieve = [true; LIMIT];
    
    // 0 and 1 are not prime
    if LIMIT > 0 {
        sieve[0] = false;
    }
    if LIMIT > 1 {
        sieve[1] = false;
    }
    
    // Sieve of Eratosthenes
    let mut i = 2;
    while i * i < LIMIT {
        if sieve[i] {
            let mut j = i * i;
            while j < LIMIT {
                sieve[j] = false;
                j += i;
            }
        }
        i += 1;
    }
    
    return sieve
}

// Test 2: CTFE with const expressions
const BASE: usize = 10;
const DOUBLE: usize = BASE * 2;

comptime fn create_array<const SIZE: usize>() -> [i32; SIZE] {
    let mut arr: [i32; SIZE] = [0; SIZE];
    
    let mut i = 0;
    while i < SIZE {
        arr[i] = (i * i) as i32;
        i += 1;
    }
    
    return arr
}

// Main function
fn main() -> i64 {
    // Test Murphy's Sieve with const generics
    let sieve100 = murphy_sieve::<100>();
    let sieve1000 = murphy_sieve::<1000>();
    
    // Test CTFE arrays
    let arr10 = create_array::<BASE>();
    let arr20 = create_array::<DOUBLE>();
    
    // Count primes up to 100
    let mut prime_count = 0;
    let mut i = 0;
    while i < 100 {
        if sieve100[i] {
            prime_count += 1;
        }
        i += 1;
    }
    
    // Return prime count (should be 25 for primes <= 100)
    return prime_count
}