fn main() -> i32 {
    // Create a large array to use memory
    // Even if loops don't work, array allocation should use memory
    let arr = array_new();
    
    // Try to push many elements (10000)
    // This should use memory even if the loop doesn't execute properly
    for i in 0..10000 {
        array_push(arr, i);
    }
    
    return array_len(arr);
}