fn test1() -> i64 {
    let mut sum = 0;
    for i in 0..10 {
        sum = sum + i;
    }
    sum
}

fn test2() -> i64 {
    let mut product = 1;
    for i in 1..6 {
        product = product * i;
    }
    product
}

fn test3() -> i64 {
    let mut sum = 0;
    for i in 0..3 {
        for j in 0..3 {
            sum = sum + i * j;
        }
    }
    sum
}

fn test4() -> i64 {
    let r = 5..10;
    let mut sum = 0;
    for i in r {
        sum = sum + i;
    }
    sum
}

fn test5() -> i64 {
    let mut count = 0;
    for i in 0..100 {
        count = count + 1;
    }
    count
}

fn main() -> i64 {
    // Return test1 result
    test1()
}