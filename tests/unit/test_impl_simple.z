// Test simple impl block
impl Option<i64> {
    fn unwrap(self) -> i64 {
        match self {
            Some(x) => x,
            None => 0,
        }
    }
}

// Test generic impl block
impl<T> Option<T> {
    fn unwrap(self) -> T {
        match self {
            Some(x) => x,
            None => panic!("unwrap on None"),
        }
    }
}