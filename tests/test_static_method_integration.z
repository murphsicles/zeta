// Integration test for static method support
// UPDATED: Using i64 to match literal default after type system integration
struct Point {
    x: i64,
    y: i64,
}

impl Point {
    fn new(x: i64, y: i64) -> Point {
        Point { x, y }
    }
    
    fn sum(&self) -> i64 {
        self.x + self.y
    }
}

fn main() -> i64 {
    // Test static method call
    let p = Point::new(10, 20);
    p.sum()
}