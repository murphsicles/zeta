// Test the ? operator with Result type
fn might_fail(succeed: bool) -> Result<i64, i64> {
    if succeed {
        Result::Ok(42)
    } else {
        Result::Err(99)
    }
}

fn test_try_operator() -> Result<i64, i64> {
    let x = might_fail(true)?;
    let y = might_fail(false)?;
    Result::Ok(x + y)
}

fn main() -> i64 {
    match test_try_operator() {
        Result::Ok(val) => val,
        Result::Err(err) => err,
    }
}