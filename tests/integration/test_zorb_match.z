// Test Zorb enum match expressions for v0.3.11

use zorb::std::option::Option;
use zorb::std::result::Result;

fn test_option_match() -> i64 {
    let some_value: Option<i64> = Option::Some(42);
    
    match some_value {
        Option::Some(x) => x,
        Option::None => 0,
    }
}

fn test_result_match() -> i64 {
    let ok_result: Result<i64, String> = Result::Ok(42);
    
    match ok_result {
        Result::Ok(x) => x,
        Result::Err(_) => 0,
    }
}

fn main() -> i64 {
    let opt_result = test_option_match();
    let res_result = test_result_match();
    
    opt_result + res_result
}