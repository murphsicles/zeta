fn test_match_basic() -> i64 {
    let x = 5;
    match x {
        1 => 10,
        2 => 20,
        3 => 30,
        4 => 40,
        5 => 50,
        _ => 0
    }
}

fn test_match_with_guard() -> i64 {
    let x = 7;
    match x {
        n if n < 5 => 1,
        n if n < 10 => 2,
        _ => 3
    }
}

fn test_match_literal() -> i64 {
    match 42 {
        42 => 100,
        _ => 0
    }
}

fn main() -> i64 {
    let a = test_match_basic();
    let b = test_match_with_guard();
    let c = test_match_literal();
    a + b + c
}
