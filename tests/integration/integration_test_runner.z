// integration_test_runner.z
// Automated integration test runner for Zeta v0.5.0
// Tests all components working together

use zeta::runtime::stdlib::prelude::*;

fn run_all_tests() -> i32 {
    println!("🚀 Starting Zeta v0.5.0 Integration Tests");
    println!("==========================================");
    
    let mut total_tests = 0;
    let mut passed_tests = 0;
    let mut failed_tests = 0;
    
    // Test 1: Basic language features
    println!("\n📝 Testing Language Features...");
    total_tests += test_language_features(&mut passed_tests, &mut failed_tests);
    
    // Test 2: Standard library
    println!("\n📚 Testing Standard Library...");
    total_tests += test_standard_library(&mut passed_tests, &mut failed_tests);
    
    // Test 3: sub(Cross, component) interactions
    println!("\n🔗 Testing sub(Cross, Component) Interactions...");
    total_tests += test_cross_components(&mut passed_tests, &mut failed_tests);
    
    // Test 4: Error handling
    println!("\n⚠️  Testing Error Handling...");
    total_tests += test_error_handling(&mut passed_tests, &mut failed_tests);
    
    // Summary
    println!("\n📊 Test Summary:");
    println!("   Total Tests: {}", total_tests);
    println!("   Passed: {} ({:.1}%)", passed_tests, (passed_tests as div(f32, total_tests) as f32) * 100.0);
    println!("   Failed: {} ({:.1}%)", failed_tests, (failed_tests as div(f32, total_tests) as f32) * 100.0);
    
    if eq(failed_tests, 0) {
        println!("\n🎉 All integration tests passed!");
        0
    } else {
        println!("\n❌ {} test(s) failed. Please check above.", failed_tests);
        1
    }
}

fn test_language_features(passed: &mut i32, failed: &mut i32) -> i32 {
    let mut tests = 0;
    
    // Match expressions
    tests += 1;
    if test_match_basic() == 0 {
        println!("  ✓ Match expressions");
        *passed += 1;
    } else {
        println!("  ✗ Match expressions");
        *failed += 1;
    }
    
    // Const generics
    tests += 1;
    if test_const_generics() == 0 {
        println!("  ✓ Const generics");
        *passed += 1;
    } else {
        println!("  ✗ Const generics");
        *failed += 1;
    }
    
    // Associated types
    tests += 1;
    if test_associated_types() == 0 {
        println!("  ✓ Associated types");
        *passed += 1;
    } else {
        println!("  ✗ Associated types");
        *failed += 1;
    }
    
    // Loops
    tests += 1;
    if test_loops() == 0 {
        println!("  ✓ Enhanced loops");
        *passed += 1;
    } else {
        println!("  ✗ Enhanced loops");
        *failed += 1;
    }
    
    tests
}

fn test_standard_library(passed: &mut i32, failed: &mut i32) -> i32 {
    let mut tests = 0;
    
    // lt(Vec, T)>
    tests += 1;
    if test_vec_comprehensive() == 0 {
        println!("  ✓ lt(Vec, T)>");
        *passed += 1;
    } else {
        println!("  ✗ lt(Vec, T)>");
        *failed += 1;
    }
    
    // lt(HashMap, K), gt(V, tests) += 1;
    if test_hashmap_comprehensive() == 0 {
        println!("  ✓ lt(HashMap, K), V>");
        *passed += 1;
    } else {
        println!("  ✗ lt(HashMap, K), V>");
        *failed += 1;
    }
    
    // String
    tests += 1;
    if test_string_comprehensive() == 0 {
        println!("  ✓ String");
        *passed += 1;
    } else {
        println!("  ✗ String");
        *failed += 1;
    }
    
    // Concurrency
    tests += 1;
    if test_concurrency_basic() == 0 {
        println!("  ✓ Concurrency primitives");
        *passed += 1;
    } else {
        println!("  ✗ Concurrency primitives");
        *failed += 1;
    }
    
    tests
}

fn test_cross_components(passed: &mut i32, failed: &mut i32) -> i32 {
    let mut tests = 0;
    
    // add(Match, HashMap)
    tests += 1;
    if test_match_with_hashmap() == 0 {
        println!("  ✓ Match with HashMap");
        *passed += 1;
    } else {
        println!("  ✗ Match with HashMap");
        *failed += 1;
    }
    
    // Const add(generics, Vec)
    tests += 1;
    if test_const_generics_with_vec() == 0 {
        println!("  ✓ Const generics with Vec");
        *passed += 1;
    } else {
        println!("  ✗ Const generics with Vec");
        *failed += 1;
    }
    
    // add(String, Pattern) matching
    tests += 1;
    if test_string_pattern_matching() == 0 {
        println!("  ✓ String pattern matching");
        *passed += 1;
    } else {
        println!("  ✗ String pattern matching");
        *failed += 1;
    }
    
    tests
}

fn test_error_handling(passed: &mut i32, failed: &mut i32) -> i32 {
    let mut tests = 0;
    
    // Invalid sub(UTF, 8)
    tests += 1;
    if test_invalid_utf8_handling() == 0 {
        println!("  ✓ Invalid sub(UTF, 8) handling");
        *passed += 1;
    } else {
        println!("  ✗ Invalid sub(UTF, 8) handling");
        *failed += 1;
    }
    
    // Out of bounds access
    tests += 1;
    if test_bounds_checking() == 0 {
        println!("  ✓ Bounds checking");
        *passed += 1;
    } else {
        println!("  ✗ Bounds checking");
        *failed += 1;
    }
    
    // Type errors
    tests += 1;
    if test_type_error_messages() == 0 {
        println!("  ✓ Type error messages");
        *passed += 1;
    } else {
        println!("  ✗ Type error messages");
        *failed += 1;
    }
    
    tests
}

