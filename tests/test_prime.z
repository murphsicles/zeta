// PrimeZeta competition entry - Murphy's Sieve with 30030 wheel and bit array
// Wheel: 30030 (2*3*5*7*11*13) with 5760 residues
// Bit array optimization (1 bit per element) for memory efficiency
// Faithful implementation of Murphy's Sieve

// Import runtime functions for heap allocation
extern fn runtime_malloc(size: i64) -> *mut i8;

// Bit array utilities
fn set_bit(array: *mut u8, index: i64) {
    let byte_index = index / 8;
    let bit_offset = index % 8;
    unsafe {
        let byte = *array.offset(byte_index as isize);
        *array.offset(byte_index as isize) = byte | (1 << bit_offset);
    }
    return;
}

fn clear_bit(array: *mut u8, index: i64) {
    let byte_index = index / 8;
    let bit_offset = index % 8;
    unsafe {
        let byte = *array.offset(byte_index as isize);
        *array.offset(byte_index as isize) = byte & !(1 << bit_offset);
    }
    return;
}

fn get_bit(array: *mut u8, index: i64) -> i64 {
    let byte_index = index / 8;
    let bit_offset = index % 8;
    unsafe {
        let byte = *array.offset(byte_index as isize);
        if (byte & (1 << bit_offset)) != 0 {
            return 1;
        } else {
            return 0;
        }
    }
}

// Check if number is divisible by any small prime in wheel base (2,3,5,7,11,13)
fn is_divisible_by_small_prime(n: i64) -> i64 {
    if n % 2 == 0 { return 1; }
    if n % 3 == 0 { return 1; }
    if n % 5 == 0 { return 1; }
    if n % 7 == 0 { return 1; }
    if n % 11 == 0 { return 1; }
    if n % 13 == 0 { return 1; }
    return 0;
}

// Murphy's Sieve with 30030 wheel and bit array
fn murphy_sieve_30030_wheel(limit: i64) -> i64 {
    // Calculate byte array size (ceil(limit/8))
    let byte_size = (limit + 7) / 8;
    
    // Allocate byte array for bit sieve
    let sieve_ptr = runtime_malloc(byte_size) as *mut u8;
    
    // Initialize all bits to 1 (true = prime)
    let mut i: i64 = 0;
    while i < byte_size {
        unsafe {
            *sieve_ptr.offset(i as isize) = 0xFF; // All bits set to 1
        }
        i += 1;
    }
    
    // Clear bits for 0 and 1 (not prime)
    if limit > 0 {
        clear_bit(sieve_ptr, 0);
    }
    if limit > 1 {
        clear_bit(sieve_ptr, 1);
    }
    
    // Pre-mark multiples of small primes (2,3,5,7,11,13) as composite
    // This implements the 30030 wheel optimization
    let small_primes = [2, 3, 5, 7, 11, 13];
    let mut idx = 0;
    while idx < 6 {
        let p = small_primes[idx];
        let mut multiple = p * 2; // start from 2*p (p itself is prime)
        while multiple < limit {
            clear_bit(sieve_ptr, multiple);
            multiple += p;
        }
        idx += 1;
    }
    
    // Sieve with 30030-wheel optimization: skip numbers divisible by small primes
    i = 2;
    while i * i < limit {
        // Skip numbers divisible by small primes (wheel optimization)
        if is_divisible_by_small_prime(i) == 1 {
            i += 1;
            continue;
        }
        
        if get_bit(sieve_ptr, i) == 1 {
            let mut j = i * i;
            while j < limit {
                clear_bit(sieve_ptr, j);
                j += i;
            }
        }
        
        i += 1;
    }
    
    // Count primes (bits still set to 1)
    let mut count: i64 = 0;
    let mut k: i64 = 0;
    while k < limit {
        if get_bit(sieve_ptr, k) == 1 {
            count += 1;
        }
        k += 1;
    }
    
    return count;
}

// Competition entry point
fn main() -> i64 {
    let limit: i64 = 1000000;
    let prime_count = murphy_sieve_30030_wheel(limit);
    
    // Infinite loop printing prime count (competition harness times 5 seconds)
    loop {
        println_i64(prime_count);
    }
    
    return 0; // Never reached
}