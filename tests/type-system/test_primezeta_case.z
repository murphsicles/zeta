// Test the specific PrimeZeta use case: list[idx] = i as u64
fn test_primezeta_case() {
    // Simulate PrimeZeta code
    let mut list = [0u64, 0u64, 0u64, 0u64, 0u64];
    let i: i64 = 42;
    
    // This is the critical line that PrimeZeta needs
    list[2] = i as u64;
    
    // Verify the conversion worked
    let value = list[2];
    // Should be 42
}