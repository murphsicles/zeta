// Simple test for u64 array syntax
const SIZE: usize = 10

// Test PrimeZeta style: [SIZE]u64
fn test1() -> [SIZE]u64 {
    let arr: [SIZE]u64 = [0; SIZE]
    arr
}

// Test Zeta style: [u64; SIZE]
fn test2() -> [u64; SIZE] {
    let arr: [u64; SIZE] = [0; SIZE]
    arr
}

fn main() -> i64 {
    0
}