// Simple benchmark test for Murphy's Sieve
// Trial division implementation

fn murphy_sieve(limit: u64) -> u64 {
    if limit <= 1 {
        return 0
    }
    
    if limit == 2 {
        return 1
    }
    
    let mut count: u64 = 0
    let mut n: u64 = 2
    
    while n < limit {
        let mut is_prime: u64 = 1
        let mut d: u64 = 2
        
        while d * d <= n {
            if n % d == 0 {
                is_prime = 0
            }
            d += 1
        }
        
        if is_prime == 1 {
            count += 1
        }
        
        n += 1
    }
    
    return count
}

fn main() -> u64 {
    // Test with limit=1000
    return murphy_sieve(1000)
}