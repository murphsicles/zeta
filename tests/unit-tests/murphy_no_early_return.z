// Murphy's Sieve without early returns

fn murphy_sieve(limit: u64) -> u64 {
    let mut result: u64 = 0
    
    if limit <= 1 {
        result = 0
    } else {
        let mut count: u64 = 0
        let mut n: u64 = 2
        
        while n < limit {
            let mut is_prime: u64 = 1
            let mut d: u64 = 2
            
            while d * d <= n {
                if n % d == 0 {
                    is_prime = 0
                } else {
                    // continue
                }
                d += 1
            }
            
            if is_prime == 1 {
                count += 1
            } else {
                // not prime
            }
            
            n += 1
        }
        
        result = count
    }
    
    return result
}

fn main() -> u64 {
    return murphy_sieve(10)
}