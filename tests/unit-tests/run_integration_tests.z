fn main() -> u64 {
    print("========================================")
    print("ZETA COMPILER INTEGRATION TEST SUITE")
    print("========================================")
    print("Time: URGENT 30 MINUTES - Father Command")
    print("Mission: Verify all compiler fixes work together")
    print("")
    
    let mut total_tests: u64 = 0
    let mut passed_tests: u64 = 0
    
    print("PHASE 1: WHILE LOOP FIXES")
    print("-------------------------")
    total_tests += 1
    if run_test_suite("test_while_fixes.z", 0) == 1 {
        passed_tests += 1
        print("✅ While loop fixes: PASSED")
    } else {
        print("❌ While loop fixes: FAILED")
    }
    print("")
    
    print("PHASE 2: TYPE COMPARISON FIXES")
    print("------------------------------")
    total_tests += 1
    if run_test_suite("test_type_comparisons.z", 0) == 1 {
        passed_tests += 1
        print("✅ Type comparison fixes: PASSED")
    } else {
        print("❌ Type comparison fixes: FAILED")
    }
    print("")
    
    print("PHASE 3: COMPLEX CONTROL FLOW")
    print("-----------------------------")
    total_tests += 1
    if run_test_suite("test_complex_control.z", 0) == 1 {
        passed_tests += 1
        print("✅ Complex control flow: PASSED")
    } else {
        print("❌ Complex control flow: FAILED")
