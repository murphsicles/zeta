// TEST SUITE: While Loop Fixes
// Tests all while loop scenarios to verify compiler fixes work

// Test 1: Basic while loop with increment
fn test_basic_while() -> u64 {
    let mut i: u64 = 0
    while i < 5 {
        i += 1
    }
    return i  // Expected: 5
}

// Test 2: While loop with array operations
fn test_while_with_array() -> u64 {
    let arr: [dynamic]u64 = [dynamic]u64{}
    let mut i: u64 = 0
    while i < 10 {
        arr.push(i)
        i += 1
    }
    return arr.len()  // Expected: 10
}

// Test 3: While loop with early break
fn test_while_with_break() -> u64 {
    let mut i: u64 = 0
    while i < 100 {
        i += 1
        if i == 10 {
            break
        }
    }
    return i  // Expected: 10
}

// Test 4: While loop with continue
fn test_while_with_continue() -> u64 {
    let mut i: u64 = 0
    let mut sum: u64 = 0
    while i < 10 {
        i += 1
        if i % 2 == 0 {
            continue
        }
        sum += i
    }
    return sum  // Expected: 25 (1+3+5+7+9)
}

// Test 5: While loop with complex condition
fn test_while_complex_condition() -> u64 {
    let mut x: u64 = 0
    let mut y: u64 = 10
    while x < 5 && y > 5 {
        x += 1
        y -= 1
    }
    return x * 10 + y  // Expected: 5*10 + 5 = 55
}

// Test 6: Empty while loop (should not execute)
fn test_empty_while() -> u64 {
    let mut i: u64 = 100
    while i < 0 {  // Condition false from start
        i += 1
    }
    return i  // Expected: 100
}

// Test 7: While loop with function calls
fn increment_counter(counter: &mut u64) {
    *counter += 1
}

fn test_while_with_function() -> u64 {
    let mut counter: u64 = 0
    while counter < 7 {
        increment_counter(&mut counter)
    }
    return counter  // Expected: 7
}

// Test 8: Nested while loops
fn test_nested_while() -> u64 {
    let mut i: u64 = 0
    let mut total: u64 = 0
    while i < 3 {
        let mut j: u64 = 0
        while j < 4 {
            total += 1
            j += 1
        }
        i += 1
    }
    return total  // Expected: 12 (3 * 4)
}

// Main test runner
fn main() -> u64 {
    let mut test_results: [dynamic]u64 = [dynamic]u64{}
    
    // Run all tests
    let test1 = test_basic_while()
    test_results.push(test1)
    print("Test 1 (basic while): ", test1, " expected: 5")
    
    let test2 = test_while_with_array()
    test_results.push(test2)
    print("Test 2 (while with array): ", test2, " expected: 10")
    
    let test3 = test_while_with_break()
    test_results.push(test3)
    print("Test 3 (while with break): ", test3, " expected: 10")
    
    let test4 = test_while_with_continue()
    test_results.push(test4)
    print("Test 4 (while with continue): ", test4, " expected: 25")
    
    let test5 = test_while_complex_condition()
    test_results.push(test5)
    print("Test 5 (complex condition): ", test5, " expected: 55")
    
    let test6 = test_empty_while()
    test_results.push(test6)
    print("Test 6 (empty while): ", test6, " expected: 100")
    
    let test7 = test_while_with_function()
    test_results.push(test7)
    print("Test 7 (while with function): ", test7, " expected: 7")
    
    let test8 = test_nested_while()
    test_results.push(test8)
    print("Test 8 (nested while): ", test8, " expected: 12")
    
    // Check all results
    let expected_results: [dynamic]u64 = [5, 10, 10, 25, 55, 100, 7, 12]
    let mut all_passed: u64 = 1
    
    let mut i: u64 = 0
    while i < test_results.len() {
        if test_results[i] != expected_results[i] {
            print("FAIL: Test ", i + 1, " got ", test_results[i], " expected ", expected_results[i])
            all_passed = 0
        }
        i += 1
    }
    
    if all_passed == 1 {
        print("✅ ALL WHILE LOOP TESTS PASSED")
        return 0
    } else {
        print("❌ SOME WHILE LOOP TESTS FAILED")
        return 1
    }
}