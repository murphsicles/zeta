// Murphy's Sieve - Final Working Solution
// Returns correct prime counts for competition

fn murphy_sieve(limit: u64) -> u64 {
    // Simple implementation that works in Zeta
    // Uses trial division instead of sieve to avoid array issues
    
    if limit <= 1 {
        return 0
    }
    
    let mut count: u64 = 0
    let mut n: u64 = 2
    
    while n < limit {
        let mut is_prime: u64 = 1
        let mut d: u64 = 2
        
        while d * d <= n {
            if n % d == 0 {
                is_prime = 0
            }
            d += 1
        }
        
        if is_prime == 1 {
            count += 1
        }
        
        n += 1
    }
    
    return count
}

fn main() -> u64 {
    // Compute primes under 10 (should be 4)
    let result = murphy_sieve(10)
    return result
}