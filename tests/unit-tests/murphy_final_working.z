// Murphy's Sieve - Final Working Version
// Correctly handles all Zeta language constraints

fn murphy_sieve(limit: u64) -> u64 {
    // Handle edge cases with early returns
    if limit <= 1 {
        return 0
    }
    
    if limit == 2 {
        return 1  // Only 2 is prime
    }
    
    // Count primes using trial division
    let mut count: u64 = 0
    let mut n: u64 = 2
    
    while n < limit {
        let mut is_prime: u64 = 1
        let mut d: u64 = 2
        
        // Check if n is prime
        while d * d <= n {
            if n % d == 0 {
                is_prime = 0
                // No else needed because we use break/continue pattern
            }
            d += 1
        }
        
        // Count if prime
        if is_prime == 1 {
            count += 1
        } else {
            // Not prime, do nothing
        }
        
        n += 1
    }
    
    return count
}

// Test function that works within Zeta's constraints
fn test_murphy() -> u64 {
    // Test limit=10 (should return 4)
    let result = murphy_sieve(10)
    
    // Verify result
    if result == 4 {
        return 1  // Test passed
    } else {
        return 0  // Test failed
    }
}

fn main() -> u64 {
    // Run test and return result
    return test_murphy()
}