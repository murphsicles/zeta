// Test 1: u8 == 0 comparison
fn test1() -> i64 {
    let x: u8 = 0;
    if x == 0 {
        return 1;  // Should return 1
    }
    return 0;
}

// Test 2: u8 != 0 comparison  
fn test2() -> i64 {
    let x: u8 = 5;
    if x != 0 {
        return 1;  // Should return 1
    }
    return 0;
}

// Test 3: u8 < comparison
fn test3() -> i64 {
    let x: u8 = 3;
    if x < 5 {
        return 1;  // Should return 1
    }
    return 0;
}

// Test 4: while loop with u8 comparison
fn test4() -> i64 {
    let mut x: u8 = 0;
    let mut count = 0;
    while x == 0 {
        count = count + 1;
        x = 1;
    }
    return count;  // Should return 1
}

fn main() -> i64 {
    // Run all tests
    if test1() != 1 { return 1; }
    if test2() != 1 { return 2; }
    if test3() != 1 { return 3; }
    if test4() != 1 { return 4; }
    
    return 0; // All tests passed
}