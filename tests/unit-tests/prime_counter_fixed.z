// Prime counter with proper else branches

fn count_primes(limit: u64) -> u64 {
    let mut count: u64 = 0
    let mut n: u64 = 2
    
    while n < limit {
        let mut is_prime: u64 = 1
        let mut d: u64 = 2
        
        while d < n {
            if n % d == 0 {
                is_prime = 0
            } else {
                // continue checking
            }
            d += 1
        }
        
        if is_prime == 1 {
            count += 1
        } else {
            // not prime
        }
        
        n += 1
    }
    
    return count
}

fn main() -> u64 {
    return count_primes(10)
}