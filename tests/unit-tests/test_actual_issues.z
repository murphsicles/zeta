// Test actual issues from PrimeZeta

// Issue 1: bool return type
fn is_prime(n: u64) -> bool {
    if n < 2 {
        return false
    }
    if n == 2 {
        return true
    }
    if n % 2 == 0 {
        return false
    }
    // Simple primality test
    let mut i: u64 = 3
    while i * i <= n {
        if n % i == 0 {
            return false
        }
        i = i + 2
    }
    return true
}

// Issue 2: array return type (PrimeZeta style)
const NUM_RESIDUES: usize = 5760

comptime fn generate_residues() -> [NUM_RESIDUES]u64 {
    var arr: [NUM_RESIDUES]u64 = [0; NUM_RESIDUES]
    // Fill with residues
    let mut i: usize = 0
    while i < NUM_RESIDUES {
        arr[i] = i as u64
        i = i + 1
    }
    return arr
}

// Issue 3: array return type (Zeta style)
fn get_small_array() -> [u64; 10] {
    let arr: [u64; 10] = [0; 10]
    return arr
}

// Issue 4: type alias
type ResidueArray = [NUM_RESIDUES]u64

// Main function
fn main() -> u64 {
    if is_prime(17) {
        let residues = generate_residues()
        return residues[0]
    } else {
        return 0
    }
}