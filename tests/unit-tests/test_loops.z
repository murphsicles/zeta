fn test_while_loop() -> i64 {
    let mut i = 0;
    let mut sum = 0;
    
    while (i < 10) {
        sum = sum + i;
        i = i + 1;
    }
    
    return sum;  // Should return 45 (0+1+2+...+9)
}

fn test_infinite_loop() -> i64 {
    let mut i = 0;
    
    loop {
        i = i + 1;
        if (i >= 10) {
            break;
        }
    }
    
    return i;  // Should return 10
}

fn test_loop_with_break_value() -> i64 {
    let result = loop {
        break 42;
    };
    
    return result;  // Should return 42
}

fn main() -> i64 {
    let sum1 = test_while_loop();  // 45
    let sum2 = test_infinite_loop();  // 10
    let sum3 = test_loop_with_break_value();  // 42
    
    return sum1 + sum2 + sum3;  // 45 + 10 + 42 = 97
}