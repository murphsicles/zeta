// Simple SIMD test program
fn main() {
    // Create a SIMD vector of 4 i32 elements
    let vec1 = Vector<i32, 4>::splat(5);
    let vec2 = Vector<i32, 4>::splat(3);
    
    // Perform SIMD operations
    let sum = vec1 + vec2;      // Should be [8, 8, 8, 8]
    let product = vec1 * vec2;  // Should be [15, 15, 15, 15]
    let diff = vec1 - vec2;     // Should be [2, 2, 2, 2]
    
    // Extract elements
    let first = sum.extract(0);
    let second = product.extract(1);
    
    // Print results
    println!("First element of sum: {}", first);
    println!("Second element of product: {}", second);
    
    // Test loading from array
    let array = [1, 2, 3, 4];
    let vec3 = Vector<i32, 4>::load(&array[0]);
    
    // Test storing to array
    let mut result = [0; 4];
    sum.store(&mut result[0]);
    
    println!("Loaded vector: {:?}", vec3);
    println!("Stored result: {:?}", result);
}