// Test SIMD vector operations
fn test_simd_add() -> i32 {
    // Create two vectors
    let v1: Vector<i32, 4> = Vector::new(1, 2, 3, 4);
    let v2: Vector<i32, 4> = Vector::new(5, 6, 7, 8);
    
    // Add them
    let result = v1 + v2;
    
    // Check result
    if result.get(0) != 6 { return 1; }
    if result.get(1) != 8 { return 2; }
    if result.get(2) != 10 { return 3; }
    if result.get(3) != 12 { return 4; }
    
    return 0;
}

fn test_simd_mul() -> i32 {
    // Create two vectors
    let v1: Vector<i32, 4> = Vector::new(2, 3, 4, 5);
    let v2: Vector<i32, 4> = Vector::new(3, 4, 5, 6);
    
    // Multiply them
    let result = v1 * v2;
    
    // Check result
    if result.get(0) != 6 { return 1; }
    if result.get(1) != 12 { return 2; }
    if result.get(2) != 20 { return 3; }
    if result.get(3) != 30 { return 4; }
    
    return 0;
}

fn test_simd_element_access() -> i32 {
    // Create a vector
    let mut v: Vector<i32, 4> = Vector::new(10, 20, 30, 40);
    
    // Get elements
    if v.get(0) != 10 { return 1; }
    if v.get(1) != 20 { return 2; }
    if v.get(2) != 30 { return 3; }
    if v.get(3) != 40 { return 4; }
    
    // Set elements
    v.set(0, 100);
    v.set(1, 200);
    
    if v.get(0) != 100 { return 5; }
    if v.get(1) != 200 { return 6; }
    
    return 0;
}

fn main() -> i32 {
    let result1 = test_simd_add();
    if result1 != 0 {
        return 100 + result1;
    }
    
    let result2 = test_simd_mul();
    if result2 != 0 {
        return 200 + result2;
    }
    
    let result3 = test_simd_element_access();
    if result3 != 0 {
        return 300 + result3;
    }
    
    return 0; // All tests passed
}