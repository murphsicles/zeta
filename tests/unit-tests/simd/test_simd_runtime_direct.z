// Test SIMD runtime functions directly
// This tests that the SIMD runtime functions are callable from Zeta code

fn test_vector_make_i32x4() -> i64 {
    // Create a vector using the runtime function
    // vector_make_i32x4 takes 4 i64 parameters and returns an i64 (pointer to vector)
    let v_ptr = vector_make_i32x4(1, 2, 3, 4);
    
    // Check that we got a non-null pointer
    if v_ptr == 0 {
        return 1; // Failed to create vector
    }
    
    // Get elements back
    let elem0 = vector_get_i32x4(v_ptr, 0);
    let elem1 = vector_get_i32x4(v_ptr, 1);
    let elem2 = vector_get_i32x4(v_ptr, 2);
    let elem3 = vector_get_i32x4(v_ptr, 3);
    
    // Check values
    if elem0 != 1 { return 10; }
    if elem1 != 2 { return 20; }
    if elem2 != 3 { return 30; }
    if elem3 != 4 { return 40; }
    
    // Free the vector
    vector_free_i32x4(v_ptr);
    
    return 0; // Success
}

fn test_vector_add_i32x4() -> i64 {
    // Create two vectors
    let v1_ptr = vector_make_i32x4(1, 2, 3, 4);
    let v2_ptr = vector_make_i32x4(5, 6, 7, 8);
    
    if v1_ptr == 0 || v2_ptr == 0 {
        return 1; // Failed to create vectors
    }
    
    // Add them
    let result_ptr = vector_add_i32x4(v1_ptr, v2_ptr);
    
    if result_ptr == 0 {
        vector_free_i32x4(v1_ptr);
        vector_free_i32x4(v2_ptr);
        return 2; // Failed to add vectors
    }
    
    // Check result
    if vector_get_i32x4(result_ptr, 0) != 6 { return 10; }
    if vector_get_i32x4(result_ptr, 1) != 8 { return 20; }
    if vector_get_i32x4(result_ptr, 2) != 10 { return 30; }
    if vector_get_i32x4(result_ptr, 3) != 12 { return 40; }
    
    // Clean up
    vector_free_i32x4(v1_ptr);
    vector_free_i32x4(v2_ptr);
    vector_free_i32x4(result_ptr);
    
    return 0; // Success
}

fn main() -> i64 {
    let test1_result = test_vector_make_i32x4();
    if test1_result != 0 {
        return 100 + test1_result;
    }
    
    let test2_result = test_vector_add_i32x4();
    if test2_result != 0 {
        return 200 + test2_result;
    }
    
    return 0; // All tests passed
}