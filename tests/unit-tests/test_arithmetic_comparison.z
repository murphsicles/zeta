// Test arithmetic comparison instead of ==

fn test_arithmetic() -> u64 {
    let arr: [dynamic]u8 = [dynamic]u8{}
    
    // Create array [1, 1, 0]
    arr.push(1)
    arr.push(1)
    arr.push(0)
    
    // Count zeros using arithmetic
    let mut count: u64 = 0
    let mut n: u64 = 0
    while n < 3 {
        // Instead of arr[n] == 0, check if arr[n] - 0 == 0
        // But subtraction might also have type issues
        // Let's try: if arr[n] < 1
        if arr[n] < 1 {
            count += 1
        }
        n += 1
    }
    
    return count  // Should be 1
}

fn main() -> u64 {
    return test_arithmetic()
}