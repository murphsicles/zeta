fn main() -> i64 {
    let mut x: u8 = 0;
    
    // Debug: check value before loop
    // if x == 0 { return 100; } else { return 200; }
    
    // Simple loop that should execute once
    while x == 0 {
        x = 1;
        return 1; // Exit immediately
    }
    
    return 0; // Should never reach here
}