// Benchmark comparison: Scalar vs SIMD Murphy's Sieve
// This file compares the performance of both implementations

// Scalar implementation (baseline)
fn murphy_sieve_scalar(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    if limit == 2 {
        return 1
    }
    
    let array_size = limit + 1
    let mut bits: [u8] = []
    
    // Initialize
    let mut i: u64 = 0
    while i < array_size {
        bits.append(1)
        i += 1
    }
    
    bits[0] = 0
    bits[1] = 0
    
    // Mark multiples of wheel primes
    i = 4
    while i <= limit {
        bits[i] = 0
        i += 2
    }
    
    i = 6
    while i <= limit {
        bits[i] = 0
        i += 3
    }
    
    i = 10
    while i <= limit {
        bits[i] = 0
        i += 5
    }
    
    i = 14
    while i <= limit {
        bits[i] = 0
        i += 7
    }
    
    i = 22
    while i <= limit {
        bits[i] = 0
        i += 11
    }
    
    i = 26
    while i <= limit {
        bits[i] = 0
        i += 13
    }
    
    // Main sieve loop
    let mut p: u64 = 17
    
    while p * p <= limit {
        if bits[p] == 1 {
            let mut multiple = p * p
            while multiple <= limit {
                bits[multiple] = 0
                multiple += p
            }
        }
        
        p += 1
        while p <= limit && (p % 2 == 0 || p % 3 == 0 || p % 5 == 0 || 
                            p % 7 == 0 || p % 11 == 0 || p % 13 == 0) {
            p += 1
        }
    }
    
    // Count primes
    let mut count: u64 = 0
    i = 2
    
    while i <= limit {
        if bits[i] == 1 {
            count += 1
        }
        i += 1
    }
    
    return count
}

// SIMD-optimized implementation
fn murphy_sieve_simd(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    if limit == 2 {
        return 1
    }
    
    let array_size = limit + 1
    let mut bits: [u8] = []
    
    // Initialize
    let mut i: u64 = 0
    while i < array_size {
        bits.append(1)
        i += 1
    }
    
    bits[0] = 0
    bits[1] = 0
    
    // SIMD-optimized marking for wheel primes
    mark_multiples_simd_optimized(&mut bits, limit, 2, 4)
    mark_multiples_simd_optimized(&mut bits, limit, 3, 6)
    mark_multiples_simd_optimized(&mut bits, limit, 5, 10)
    mark_multiples_simd_optimized(&mut bits, limit, 7, 14)
    mark_multiples_simd_optimized(&mut bits, limit, 11, 22)
    mark_multiples_simd_optimized(&mut bits, limit, 13, 26)
    
    // Main sieve loop with SIMD optimization
    let mut p: u64 = 17
    
    while p * p <= limit {
        if bits[p] == 1 {
            mark_multiples_simd_optimized(&mut bits, limit, p, p * p)
        }
        
        p += 1
        while p <= limit && (p % 2 == 0 || p % 3 == 0 || p % 5 == 0 || 
                            p % 7 == 0 || p % 11 == 0 || p % 13 == 0) {
            p += 1
        }
    }
    
    // SIMD-optimized counting
    return count_primes_simd_optimized(&bits, limit)
}

// SIMD-optimized marking (simulated with loop unrolling)
fn mark_multiples_simd_optimized(bits: &mut [u8], limit: u64, prime: u64, start: u64) {
    const SIMD_WIDTH: u64 = 8
    
    if prime < SIMD_WIDTH * 2 || (limit - start) < SIMD_WIDTH * 8 {
        // Use scalar for small cases
        let mut multiple = start
        while multiple <= limit {
            bits[multiple] = 0
            multiple += prime
        }
        return
    }
    
    let prime_x8 = prime * SIMD_WIDTH
    let mut multiple = start
    
    // Process in chunks of 8 (SIMD width)
    while multiple + prime_x8 <= limit {
        // Unrolled loop simulates SIMD operations
        bits[multiple] = 0
        bits[multiple + prime] = 0
        bits[multiple + 2 * prime] = 0
        bits[multiple + 3 * prime] = 0
        bits[multiple + 4 * prime] = 0
        bits[multiple + 5 * prime] = 0
        bits[multiple + 6 * prime] = 0
        bits[multiple + 7 * prime] = 0
        
        multiple += prime_x8
    }
    
    // Process remainder
    while multiple <= limit {
        bits[multiple] = 0
        multiple += prime
    }
}

// SIMD-optimized counting (simulated with loop unrolling)
fn count_primes_simd_optimized(bits: &[u8], limit: u64) -> u64 {
    const SIMD_WIDTH: u64 = 8
    let mut count: u64 = 0
    let mut i: u64 = 2
    
    // Process in chunks
    while i + SIMD_WIDTH <= limit + 1 {
        // Unrolled counting simulates SIMD compare and sum
        if bits[i] == 1 { count += 1 }
        if bits[i + 1] == 1 { count += 1 }
        if bits[i + 2] == 1 { count += 1 }
        if bits[i + 3] == 1 { count += 1 }
        if bits[i + 4] == 1 { count += 1 }
        if bits[i + 5] == 1 { count += 1 }
        if bits[i + 6] == 1 { count += 1 }
        if bits[i + 7] == 1 { count += 1 }
        
        i += SIMD_WIDTH
    }
    
    // Process remainder
    while i <= limit {
        if bits[i] == 1 {
            count += 1
        }
        i += 1
    }
    
    return count
}

// Run benchmark iterations
fn run_benchmark(limit: u64, iterations: u64, use_simd: u64) -> u64 {
    let mut total_primes: u64 = 0
    let mut iter = 0
    
    while iter < iterations {
        if use_simd == 1 {
            total_primes += murphy_sieve_simd(limit)
        } else {
            total_primes += murphy_sieve_scalar(limit)
        }
        iter += 1
    }
    
    // Return average
    return total_primes / iterations
}

// Verify both implementations give same results
fn verify_correctness() -> u64 {
    let test_limits = [10, 100, 1000, 10000, 100000]
    let mut passed = 0
    
    for limit in test_limits {
        let scalar_result = murphy_sieve_scalar(limit)
        let simd_result = murphy_sieve_simd(limit)
        
        if scalar_result == simd_result {
            passed += 1
        }
    }
    
    return passed
}

// Main benchmark comparison
fn main() -> u64 {
    // First verify both implementations are correct
    let correctness = verify_correctness()
    
    if correctness != 5 {
        // Not all tests passed
        return 0
    }
    
    // Run performance comparison
    let limit = 100000
    let iterations = 5
    
    // Run scalar benchmark
    let scalar_result = run_benchmark(limit, iterations, 0)
    
    // Run SIMD benchmark  
    let simd_result = run_benchmark(limit, iterations, 1)
    
    // Both should give same result (78498 for limit=100000)
    let expected = 9592  // primes under 100000
    
    if scalar_result == expected && simd_result == expected {
        return 1  // Success - both correct
    } else {
        return 0  // Failure - wrong results
    }
}