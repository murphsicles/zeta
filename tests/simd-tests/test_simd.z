// Simple SIMD test
use std::simd;

fn test_simd_basic() {
    // Test that we can declare vector types
    let v1: simd::Vector<i32, 4> = simd::splat(5);
    let v2 = simd::from_array([1, 2, 3, 4]);
    
    // Test basic operations
    let v3 = simd::add(v1, v2);
    let sum = simd::horizontal_add(v3);
    
    println!("Sum: {}", sum);
}

fn main() {
    test_simd_basic();
}