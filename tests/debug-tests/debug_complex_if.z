fn test() -> u64 {
    let mut is_prime = true
    let n: u64 = 17
    
    let mut i: u64 = 5
    while i * i <= n {
        if n % i == 0 {
            is_prime = false
            break
        }
        i += 6
    }
    
    if is_prime {
        return 1
    } else {
        return 0
    }
}

fn main() -> u64 {
    return test()
}