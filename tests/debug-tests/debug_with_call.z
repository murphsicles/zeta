// Debug with function call in loop

fn check_number(n: u64) -> u64 {
    // Simple check
    if n == 0 {
        return 0
    } else {
        return 1
    }
}

fn counter_with_call(limit: u64) -> u64 {
    let mut count: u64 = 0
    let mut n: u64 = 0
    
    while n < limit {
        let result = check_number(n)
        count += result
        n = n + 1
    }
    
    return count
}

fn main() -> u64 {
    return counter_with_call(5)
}