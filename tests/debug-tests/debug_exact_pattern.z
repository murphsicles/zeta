// Exact pattern from failing algorithm
fn test() -> u64 {
    let n: u64 = 17
    let mut is_prime = true
    
    let mut i: u64 = 5
    while i * i <= n {
        if n % i == 0 {
            is_prime = false
            break
        }
        i += 6
    }
    
    return if is_prime { 1 } else { 0 }
}

fn main() -> u64 {
    return test()
}