// Simple test for dynamic arrays
fn main() -> u64 {
    // Test 1: Create dynamic array
    let arr: [dynamic]u64 = [dynamic]u64{}
    
    // Test 2: Push values
    arr.push(42)
    arr.push(100)
    
    // Test 3: Access values
    let sum = arr[0] + arr[1]
    
    // Should return 142
    return sum
}