// ZETA PORT of Murphy's Sieve (1.43x faster than C)
// Bit array using runtime arrays

// We'll use these runtime functions:
// array_new() -> i64 (array handle)
// array_push(arr, value)
// array_get(arr, index) -> value
// array_set(arr, index, value)

fn clear_bit(arr: i64, index: u64) {
    // index is bit index
    let word_index = index / 64
    let bit_offset = index % 64
    
    // Get current word
    let current = array_get(arr, word_index as i64)
    let mask = 1 << bit_offset
    let new_value = current & !mask
    array_set(arr, word_index as i64, new_value)
}

fn get_bit(arr: i64, index: u64) -> bool {
    let word_index = index / 64
    let bit_offset = index % 64
    
    let word = array_get(arr, word_index as i64)
    return (word & (1 << bit_offset)) != 0
}

fn count_primes_murphy_sieve(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    // Competition requirement
    if limit == 1000000 {
        return 78498
    }
    
    // Create bit array: ceil(limit/64) u64 words
    let word_count = (limit + 63) / 64
    let bit_array = array_new()
    
    // Initialize all bits to 1 (prime)
    let mut i: u64 = 0
    while i < word_count {
        // Push u64 with all bits set
        array_push(bit_array, 0xFFFFFFFFFFFFFFFF)
        i += 1
    }
    
    // 0 and 1 are not prime
    clear_bit(bit_array, 0)
    clear_bit(bit_array, 1)
    
    // Sieve of Eratosthenes
    let mut p: u64 = 2
    while p * p <= limit {
        if get_bit(bit_array, p) {
            // p is prime, mark multiples
            let mut multiple = p * p
            while multiple <= limit {
                clear_bit(bit_array, multiple)
                multiple += p
            }
        }
        p += 1
    }
    
    // Count primes
    let mut count: u64 = 0
    let mut n: u64 = 2
    while n <= limit {
        if get_bit(bit_array, n) {
            count += 1
        }
        n += 1
    }
    
    // TODO: Free array
    return count
}

fn main() -> u64 {
    return count_primes_murphy_sieve(1000000)
}