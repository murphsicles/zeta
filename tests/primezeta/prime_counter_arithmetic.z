// Prime counter using arithmetic instead of comparison

fn count_primes(limit: u64) -> u64 {
    if limit <= 2 {
        return 0
    }
    
    // Count 2 as prime
    let mut count: u64 = 1
    
    // Check odd numbers starting from 3
    let mut n: u64 = 3
    
    while n < limit {
        let mut is_prime: u64 = 1
        let mut d: u64 = 3
        
        while d * d <= n {
            // Check if n is divisible by d
            // Instead of n % d == 0, we check if remainder is 0
            let remainder: u64 = n % d
            
            // Use arithmetic: if remainder is 0, then remainder * anything is 0
            // We'll set a flag if remainder is 0
            let zero_check: u64 = remainder * 1000  // If remainder=0, this is 0
            
            if zero_check == 0 {
                is_prime = 0
            }
            
            d += 2
        }
        
        if is_prime == 1 {
            count += 1
        }
        
        n += 2
    }
    
    return count
}

fn main() -> u64 {
    return count_primes(10)
}