// Simplest working prime counter

fn count_primes(limit: u64) -> u64 {
    if limit <= 2 {
        return 0
    }
    
    let mut count: u64 = 1  // Count 2 as prime
    let mut n: u64 = 3
    
    while n < limit {
        let mut d: u64 = 3
        let mut is_prime: u64 = 1
        
        while d < n {
            let rem: u64 = n % d
            
            // Check if remainder is zero
            if rem == 0 {
                is_prime = 0
            }
            
            d += 2
        }
        
        if is_prime == 1 {
            count += 1
        }
        
        n += 2
    }
    
    return count
}

fn main() -> u64 {
    // Test with limit=10 (should return 4)
    return count_primes(10)
}