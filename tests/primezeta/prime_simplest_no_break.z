// Simplest algorithm - no break, simple conditions

fn count_primes_simple_no_break(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    if limit == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 1  // Count 2
    
    // Check odd numbers
    let mut n: u64 = 3
    while n <= limit {
        // Trial division
        let mut is_prime = true
        let mut i: u64 = 3
        
        // Use while with condition only
        while i * i <= n {
            if n % i == 0 {
                is_prime = false
                // Set i high to exit loop (no break!)
                i = n
            }
            i += 2
        }
        
        if is_prime {
            count += 1
        }
        
        n += 2
    }
    
    return count
}

fn main() -> u64 {
    return count_primes_simple_no_break(1000000)
}