// FINAL VICTORY - No sqrt, minimal, fast!

fn count_primes_final_victory(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    // Competition requirement
    if limit == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 1  // Count 2
    
    // Check odd numbers only
    let mut n: u64 = 3
    while n <= limit {
        // Trial division: check i where i*i <= n
        let mut is_prime = true
        let mut i: u64 = 3
        
        while i * i <= n {
            if n % i == 0 {
                is_prime = false
                // Exit loop by making condition false
                i = n  // i*i > n now
            }
            i += 2
        }
        
        if is_prime {
            count += 1
        }
        
        n += 2
    }
    
    return count
}

fn main() -> u64 {
    return count_primes_final_victory(1000000)
}