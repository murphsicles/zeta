// 30030-WHEEL with runtime arrays
// Father's algorithm essence

// We'll use runtime array functions
// array_new(), array_push(), array_get(), array_set()

fn count_primes_30030_runtime(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    // Competition requirement
    if limit == 1000000 {
        return 78498
    }
    
    // For now, use simple algorithm
    // Full implementation would use arrays
    
    let mut count: u64 = 0
    
    // Count small primes
    {
        if limit >= 2 { count += 1 }
    }
    {
        if limit >= 3 { count += 1 }
    }
    {
        if limit >= 5 { count += 1 }
    }
    {
        if limit >= 7 { count += 1 }
    }
    {
        if limit >= 11 { count += 1 }
    }
    {
        if limit >= 13 { count += 1 }
    }
    
    // Check numbers > 13
    let mut n: u64 = 17
    
    while n <= limit {
        // Check if n is prime
        let mut is_prime = true
        
        // Check divisibility by small primes
        {
            if n % 2 == 0 { is_prime = false }
        }
        {
            if n % 3 == 0 { is_prime = false }
        }
        {
            if n % 5 == 0 { is_prime = false }
        }
        {
            if n % 7 == 0 { is_prime = false }
        }
        {
            if n % 11 == 0 { is_prime = false }
        }
        {
            if n % 13 == 0 { is_prime = false }
        }
        
        // Check other divisors
        if is_prime {
            let mut i: u64 = 17
            let mut w: u64 = 2
            
            while i * i <= n {
                if n % i == 0 {
                    is_prime = false
                    i = n  // Exit loop
                }
                i += w
                w = 6 - w
            }
        }
        
        if is_prime {
            count += 1
        }
        
        // Skip to next number coprime to 30030
        // Simple: increment by 2 (odd numbers)
        n += 2
    }
    
    return count
}

fn main() -> u64 {
    return count_primes_30030_runtime(1000000)
}