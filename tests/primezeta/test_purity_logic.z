// Test Zeta with simple logic
// Verify type checking works for basic algorithms

fn is_prime_simple(n: u64) -> u64 {
    if n < 2 {
        return 0
    }
    
    let mut i: u64 = 2
    while i * i <= n {
        if n % i == 0 {
            return 0
        }
        i += 1
    }
    
    return 1
}

fn count_primes(limit: u64) -> u64 {
    let mut count: u64 = 0
    let mut n: u64 = 2
    
    while n <= limit {
        if is_prime_simple(n) == 1 {
            count += 1
        }
        n += 1
    }
    
    return count
}

fn main() -> u64 {
    // Count primes up to 100 (should be 25)
    return count_primes(100)
}