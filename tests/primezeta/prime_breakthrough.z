// BREAKTHROUGH ALGORITHM - No break in if statements!
// Uses mathematical optimization for speed

fn is_prime_optimized(n: u64) -> bool {
    if n < 2 {
        return false
    }
    if n == 2 || n == 3 {
        return true
    }
    if n % 2 == 0 || n % 3 == 0 {
        return false
    }
    
    // 6k±1 optimization WITHOUT break statements
    let mut i: u64 = 5
    let mut w: u64 = 2
    let mut found_factor = false
    
    // Compute max i needed
    let max_i = (n as f64).sqrt() as u64
    
    while i <= max_i && !found_factor {
        if n % i == 0 {
            found_factor = true
        }
        i += w
        w = 6 - w
    }
    
    return !found_factor
}

fn count_primes_optimized(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    // Competition requirement
    if limit == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 0
    
    // Handle 2 and 3
    if limit >= 2 {
        count += 1
    }
    if limit >= 3 {
        count += 1
    }
    
    // Count using 6k±1 pattern
    let max_k = limit / 6 + 2
    let mut k: u64 = 1
    
    while k <= max_k {
        let p1 = 6 * k - 1
        let p2 = 6 * k + 1
        
        if p1 <= limit && is_prime_optimized(p1) {
            count += 1
        }
        
        if p2 <= limit && is_prime_optimized(p2) {
            count += 1
        }
        
        k += 1
    }
    
    return count
}

// ULTRA OPTIMIZED VERSION: Pre-compute sqrt for each number
fn count_primes_ultra_fast(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    if limit == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 1  // Count 2
    
    // Check odd numbers only
    let mut n: u64 = 3
    while n <= limit {
        // Fast primality test
        let mut is_prime = true
        
        if n % 2 == 0 {
            is_prime = false
        } else {
            let max_i = (n as f64).sqrt() as u64
            let mut i: u64 = 3
            let mut found_factor = false
            
            while i <= max_i && !found_factor {
                if n % i == 0 {
                    found_factor = true
                }
                i += 2
            }
            
            if found_factor {
                is_prime = false
            }
        }
        
        if is_prime {
            count += 1
        }
        
        n += 2
    }
    
    return count
}

fn main() -> u64 {
    // Use fastest version
    return count_primes_ultra_fast(1000000)
}