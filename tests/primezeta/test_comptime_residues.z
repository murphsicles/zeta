// PrimeZeta comptime function test
// This simulates the PrimeZeta residue generation that needs comptime evaluation

const MODULUS: u64 = 10
const NUM_RESIDUES: usize = 4

// This is the function that needs comptime evaluation
comptime fn generate_residues() -> [NUM_RESIDUES]u64 {
    // Simplified version - actual PrimeZeta has gcd check
    var list: [NUM_RESIDUES]u64 = [0; NUM_RESIDUES]
    list[0] = 1
    list[1] = 3
    list[2] = 7
    list[3] = 9
    return list
}

// Use the comptime result
const RESIDUES: [NUM_RESIDUES]u64 = generate_residues()

fn main() -> u64 {
    // Sum the residues (should be 1 + 3 + 7 + 9 = 20)
    var sum: u64 = 0
    for i in 0..NUM_RESIDUES {
        sum = sum + RESIDUES[i]
    }
    return sum
}