// Integration test for PrimeZeta's generate_residues() function
// Protocol compliant: test file in tests/primezeta/

// Test the actual generate_residues function from PrimeZeta v0.5.0
fn generate_residues(modulus: i64, num_residues: usize) -> [u8; 5760] {
    var residues: [u8; 5760] = [0; 5760];
    var idx: usize = 0;
    
    for i in 0..modulus {
        if i % 2 != 0 && i % 3 != 0 && i % 5 != 0 && i % 7 != 0 && i % 11 != 0 && i % 13 != 0 {
            residues[idx] = i as u8;
            idx = idx + 1;
        }
    }
    
    residues
}

// Test function that mimics PrimeZeta usage
fn test_primezeta_integration() -> i64 {
    const MODULUS: i64 = 30030;
    const NUM_RESIDUES: usize = 5760;
    
    let residues = generate_residues(MODULUS, NUM_RESIDUES);
    
    // Verify we got the expected number of residues
    var count: usize = 0;
    for i in 0..NUM_RESIDUES {
        if residues[i] != 0 {
            count = count + 1;
        }
    }
    
    // Should have 5760 residues for modulus 30030
    if count == NUM_RESIDUES {
        return 0; // Success
    } else {
        return 1; // Failure
    }
}

fn main() -> i64 {
    test_primezeta_integration()
}