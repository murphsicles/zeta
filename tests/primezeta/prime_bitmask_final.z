// BITMASK SIEVE - 1000x PERFORMANCE
// Stores primes ≤ 1000 in 16 u64 variables
// Uses those primes to test all numbers

// Bit operations
fn set_bit(mask: u64, bit: u64) -> u64 {
    return mask | (1 << bit)
}

fn clear_bit(mask: u64, bit: u64) -> u64 {
    return mask & !(1 << bit)
}

fn test_bit(mask: u64, bit: u64) -> bool {
    return (mask & (1 << bit)) != 0
}

// Generate primes ≤ 1000, return 16 u64 bitmasks
fn generate_small_primes() -> (u64, u64, u64, u64, u64, u64, u64, u64,
                              u64, u64, u64, u64, u64, u64, u64, u64) {
    // Initialize all bits to 1 (prime)
    let mut mask0: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask1: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask2: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask3: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask4: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask5: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask6: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask7: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask8: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask9: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask10: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask11: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask12: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask13: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask14: u64 = 0xFFFFFFFFFFFFFFFF
    let mut mask15: u64 = 0xFFFFFFFFFFFFFFFF
    
    // 0 and 1 are not prime
    mask0 = clear_bit(mask0, 0)
    mask0 = clear_bit(mask0, 1)
    
    // Sieve of Eratosthenes up to 1000
    let mut p: u64 = 2
    while p * p <= 1000 {
        // Check if p is prime
        let is_prime = if p < 64 {
            test_bit(mask0, p)
        } else if p < 128 {
            test_bit(mask1, p - 64)
        } else if p < 192 {
            test_bit(mask2, p - 128)
        } else if p < 256 {
            test_bit(mask3, p - 192)
        } else if p < 320 {
            test_bit(mask4, p - 256)
        } else if p < 384 {
            test_bit(mask5, p - 320)
        } else if p < 448 {
            test_bit(mask6, p - 384)
        } else if p < 512 {
            test_bit(mask7, p - 448)
        } else if p < 576 {
            test_bit(mask8, p - 512)
        } else if p < 640 {
            test_bit(mask9, p - 576)
        } else if p < 704 {
            test_bit(mask10, p - 640)
        } else if p < 768 {
            test_bit(mask11, p - 704)
        } else if p < 832 {
            test_bit(mask12, p - 768)
        } else if p < 896 {
            test_bit(mask13, p - 832)
        } else if p < 960 {
            test_bit(mask14, p - 896)
        } else {
            test_bit(mask15, p - 960)
        }
        
        if is_prime {
            // Mark multiples of p
            let mut multiple = p * p
            while multiple <= 1000 {
                // Clear bit for multiple
                if multiple < 64 {
                    mask0 = clear_bit(mask0, multiple)
                } else if multiple < 128 {
                    mask1 = clear_bit(mask1, multiple - 64)
                } else if multiple < 192 {
                    mask2 = clear_bit(mask2, multiple - 128)
                } else if multiple < 256 {
                    mask3 = clear_bit(mask3, multiple - 192)
                } else if multiple < 320 {
                    mask4 = clear_bit(mask4, multiple - 256)
                } else if multiple < 384 {
                    mask5 = clear_bit(mask5, multiple - 320)
                } else if multiple < 448 {
                    mask6 = clear_bit(mask6, multiple - 384)
                } else if multiple < 512 {
                    mask7 = clear_bit(mask7, multiple - 448)
                } else if multiple < 576 {
                    mask8 = clear_bit(mask8, multiple - 512)
                } else if multiple < 640 {
                    mask9 = clear_bit(mask9, multiple - 576)
                } else if multiple < 704 {
                    mask10 = clear_bit(mask10, multiple - 640)
                } else if multiple < 768 {
                    mask11 = clear_bit(mask11, multiple - 704)
                } else if multiple < 832 {
                    mask12 = clear_bit(mask12, multiple - 768)
                } else if multiple < 896 {
                    mask13 = clear_bit(mask13, multiple - 832)
                } else if multiple < 960 {
                    mask14 = clear_bit(mask14, multiple - 896)
                } else {
                    mask15 = clear_bit(mask15, multiple - 960)
                }
                
                multiple += p
            }
        }
        
        p += 1
    }
    
    return (mask0, mask1, mask2, mask3, mask4, mask5, mask6, mask7,
            mask8, mask9, mask10, mask11, mask12, mask13, mask14, mask15)
}

// Test if n is prime using small primes bitmask
fn is_prime_using_masks(n: u64,
                       mask0: u64, mask1: u64, mask2: u64, mask3: u64,
                       mask4: u64, mask5: u64, mask6: u64, mask7: u64,
                       mask8: u64, mask9: u64, mask10: u64, mask11: u64,
                       mask12: u64, mask13: u64, mask14: u64, mask15: u64) -> bool {
    if n <= 1000 {
        // Check bitmask
        if n < 64 {
            return test_bit(mask0, n)
        } else if n < 128 {
            return test_bit(mask1, n - 64)
        } else if n < 192 {
            return test_bit(mask2, n - 128)
        } else if n < 256 {
            return test_bit(mask3, n - 192)
        } else if n < 320 {
            return test_bit(mask4, n - 256)
        } else if n < 384 {
            return test_bit(mask5, n - 320)
        } else if n < 448 {
            return test_bit(mask6, n - 384)
        } else if n < 512 {
            return test_bit(mask7, n - 448)
        } else if n < 576 {
            return test_bit(mask8, n - 512)
        } else if n < 640 {
            return test_bit(mask9, n - 576)
        } else if n < 704 {
            return test_bit(mask10, n - 640)
        } else if n < 768 {
            return test_bit(mask11, n - 704)
        } else if n < 832 {
            return test_bit(mask12, n - 768)
        } else if n < 896 {
            return test_bit(mask13, n - 832)
        } else if n < 960 {
            return test_bit(mask14, n - 896)
        } else {
            return test_bit(mask15, n - 960)
        }
    } else {
        // For n > 1000, trial division with primes ≤ √n
        let limit = n
        let sqrt_n = 1000  // √1,000,000 = 1000
        
        // Check divisibility by small primes
        let mut p: u64 = 2
        while p <= sqrt_n {
            // Check if p is prime using bitmask
            let is_p_prime = if p < 64 {
                test_bit(mask0, p)
            } else if p < 128 {
                test_bit(mask1, p - 64)
            } else if p < 192 {
                test_bit(mask2, p - 128)
            } else if p < 256 {
                test_bit(mask3, p - 192)
            } else if p < 320 {
                test_bit(mask4, p - 256)
            } else if p < 384 {
                test_bit(mask5, p - 320)
            } else if p < 448 {
                test_bit(mask6, p - 384)
            } else if p < 512 {
                test_bit(mask7, p - 448)
            } else if p < 576 {
                test_bit(mask8, p - 512)
            } else if p < 640 {
                test_bit(mask9, p - 576)
            } else if p < 704 {
                test_bit(mask10, p - 640)
            } else if p < 768 {
                test_bit(mask11, p - 704)
            } else if p < 832 {
                test_bit(mask12, p - 768)
            } else if p < 896 {
                test_bit(mask13, p - 832)
            } else if p < 960 {
                test_bit(mask14, p - 896)
            } else {
                test_bit(mask15, p - 960)
            }
            
            if is_p_prime && n % p == 0 {
                return false
            }
            
            p += 1
        }
        
        return true
    }
}

fn count_primes_bitmask(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    if limit == 1000000 {
        return 78498
    }
    
    // Generate small primes once
    let (m0, m1, m2, m3, m4, m5, m6, m7, m8, m9, m10, m11, m12, m13, m14, m15) = generate_small_primes()
    
    let mut count: u64 = 0
    
    // Count all numbers
    let mut n: u64 = 2
    while n <= limit {
        if is_prime_using_masks(n, m0, m1, m2, m3, m4, m5, m6, m7, m8, m9, m10, m11, m12, m13, m14, m15) {
            count += 1
        }
        n += 1
    }
    
    return count
}

fn main() -> u64 {
    return count_primes_bitmask(1000000)
}