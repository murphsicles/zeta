// Simple test of Murphy's Sieve with limit=3

fn murphy_sieve(limit: u64) -> u64 {
    // Create dynamic bit array for sieve
    // 0 = prime, 1 = composite
    let bits: [dynamic]u8 = [dynamic]u8{}
    
    // Initialize array with zeros (all prime initially)
    let mut i: u64 = 0
    while i < limit {
        bits.push(0)
        i += 1
    }
    
    // Debug: print array size
    // bits.size() // Not available in Zeta
    
    // Mark 0 and 1 as not prime (if within bounds)
    if limit > 0 {
        bits[0] = 1
    }
    if limit > 1 {
        bits[1] = 1
    }
    
    // Sieve of Eratosthenes
    let mut p: u64 = 2
    while p * p < limit {
        // If p is prime (bits[p] == 0)
        if bits[p] == 0 {
            // Mark all multiples of p as composite
            let mut multiple: u64 = p * p
            while multiple < limit {
                bits[multiple] = 1
                multiple += p
            }
        }
        p += 1
    }
    
    // Count primes (bits[i] == 0)
    let mut count: u64 = 0
    let mut n: u64 = 0
    while n < limit {
        if bits[n] == 0 {
            count += 1
        }
        n += 1
    }
    
    return count
}

fn main() -> u64 {
    // Test with limit=3 (should return 1 - prime: 2)
    return murphy_sieve(3)
}