// ULTRA-OPTIMIZED TRIAL DIVISION
// Maximum performance within Zeta constraints

fn count_primes_ultra(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    if limit == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 1  // Count 2
    
    // Check odd numbers only
    let mut n: u64 = 3
    while n <= limit {
        // Trial division up to sqrt(n)
        let mut is_prime = true
        let mut i: u64 = 3
        
        // Compute sqrt once
        let max_i = n  // Will be set to sqrt approximation
        
        while i * i <= n {
            if n % i == 0 {
                is_prime = false
                // Exit by setting i high
                i = n
            }
            i += 2  // Check odd divisors only
        }
        
        if is_prime {
            count += 1
        }
        
        n += 2  // Next odd number
    }
    
    return count
}

// Even more optimized: 6k±1 wheel
fn count_primes_6k_ultra(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    if limit == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 0
    
    // Count 2 and 3
    if limit >= 2 { count += 1 }
    if limit >= 3 { count += 1 }
    
    // 6k±1 pattern
    let mut k: u64 = 1
    while true {
        let p1 = 6 * k - 1
        let p2 = 6 * k + 1
        
        if p1 > limit && p2 > limit {
            break
        }
        
        // Check p1
        if p1 <= limit {
            let mut is_prime = true
            let mut i: u64 = 5
            let mut w: u64 = 2
            
            while i * i <= p1 {
                if p1 % i == 0 {
                    is_prime = false
                    i = p1  // Exit
                }
                i += w
                w = 6 - w
            }
            
            if is_prime {
                count += 1
            }
        }
        
        // Check p2
        if p2 <= limit {
            let mut is_prime = true
            let mut i: u64 = 5
            let mut w: u64 = 2
            
            while i * i <= p2 {
                if p2 % i == 0 {
                    is_prime = false
                    i = p2  // Exit
                }
                i += w
                w = 6 - w
            }
            
            if is_prime {
                count += 1
            }
        }
        
        k += 1
    }
    
    return count
}

fn main() -> u64 {
    // Use 6k±1 version for better performance
    return count_primes_6k_ultra(1000000)
}