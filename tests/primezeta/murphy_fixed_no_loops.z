// Murphy's Sieve implementation in PURE ZETA - FIXED VERSION without while loops
// Manually unrolled for limit=10

fn murphy_sieve_limit10() -> u64 {
    let limit: u64 = 10
    
    // Create dynamic bit array for sieve
    // 0 = prime, 1 = composite
    let bits: [dynamic]i64 = [dynamic]i64{}
    
    // Initialize array with zeros (all prime initially)
    // Manually push 10 zeros
    bits.push(0)
    bits.push(0)
    bits.push(0)
    bits.push(0)
    bits.push(0)
    bits.push(0)
    bits.push(0)
    bits.push(0)
    bits.push(0)
    bits.push(0)
    
    // Mark 0 and 1 as not prime
    bits[0] = 1
    bits[1] = 1
    
    // Sieve of Eratosthenes for limit=10
    // p from 2 to √10 (√10 ≈ 3.16, so p=2,3)
    
    // p = 2
    if bits[2] == 0 {
        // Mark multiples of 2: 4, 6, 8
        bits[4] = 1
        bits[6] = 1
        bits[8] = 1
    }
    
    // p = 3
    if bits[3] == 0 {
        // Mark multiples of 3: 9 (3*3=9)
        bits[9] = 1
    }
    
    // Count primes (bits[i] == 0)
    // Manually check each position
    let mut count: u64 = 0
    
    // Check bits[0]
    if bits[0] == 0 {
        count += 1
    }
    
    // Check bits[1]
    if bits[1] == 0 {
        count += 1
    }
    
    // Check bits[2]
    if bits[2] == 0 {
        count += 1
    }
    
    // Check bits[3]
    if bits[3] == 0 {
        count += 1
    }
    
    // Check bits[4]
    if bits[4] == 0 {
        count += 1
    }
    
    // Check bits[5]
    if bits[5] == 0 {
        count += 1
    }
    
    // Check bits[6]
    if bits[6] == 0 {
        count += 1
    }
    
    // Check bits[7]
    if bits[7] == 0 {
        count += 1
    }
    
    // Check bits[8]
    if bits[8] == 0 {
        count += 1
    }
    
    // Check bits[9]
    if bits[9] == 0 {
        count += 1
    }
    
    return count  // Should be 4 (primes: 2,3,5,7)
}

fn main() -> u64 {
    return murphy_sieve_limit10()
}