// Sieve algorithm with NO break statements
// Uses flag variables instead of break

fn count_primes_no_break(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    if limit == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 1  // Count 2
    
    // Check odd numbers
    let mut n: u64 = 3
    while n <= limit {
        // Trial division without break
        let mut is_prime = true
        let mut i: u64 = 3
        let mut continue_checking = true
        
        while continue_checking && i * i <= n {
            if n % i == 0 {
                is_prime = false
                continue_checking = false
            }
            i += 2
        }
        
        if is_prime {
            count += 1
        }
        
        n += 2
    }
    
    return count
}

// Optimized 6k±1 version without break
fn count_primes_6k_no_break(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    if limit == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 0
    
    // Count 2 and 3
    if limit >= 2 { count += 1 }
    if limit >= 3 { count += 1 }
    
    // 6k±1 pattern
    let mut k: u64 = 1
    let mut continue_loop = true
    
    while continue_loop {
        let p1 = 6 * k - 1
        let p2 = 6 * k + 1
        
        if p1 > limit && p2 > limit {
            continue_loop = false
        } else {
            // Check p1
            if p1 <= limit {
                let mut is_prime = true
                let mut i: u64 = 5
                let mut w: u64 = 2
                let mut keep_checking = true
                
                while keep_checking && i * i <= p1 {
                    if p1 % i == 0 {
                        is_prime = false
                        keep_checking = false
                    }
                    i += w
                    w = 6 - w
                }
                
                if is_prime {
                    count += 1
                }
            }
            
            // Check p2
            if p2 <= limit {
                let mut is_prime = true
                let mut i: u64 = 5
                let mut w: u64 = 2
                let mut keep_checking = true
                
                while keep_checking && i * i <= p2 {
                    if p2 % i == 0 {
                        is_prime = false
                        keep_checking = false
                    }
                    i += w
                    w = 6 - w
                }
                
                if is_prime {
                    count += 1
                }
            }
            
            k += 1
        }
    }
    
    return count
}

fn main() -> u64 {
    // Use optimized version
    return count_primes_6k_no_break(1000000)
}