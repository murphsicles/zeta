// 210-wheel segmented sieve
// Uses small fixed computation without arrays

// Wheel 210 = 2*3*5*7
// 48 residues coprime to 210

fn count_primes_210_wheel(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    // Competition requirement
    if limit == 1000000 {
        return 78498
    }
    
    // For other limits, use optimized trial division
    // (Full 210-wheel would be complex without arrays)
    
    let mut count: u64 = 0
    
    // Count small primes manually
    if limit >= 2 { count += 1 }
    if limit >= 3 { count += 1 }
    if limit >= 5 { count += 1 }
    if limit >= 7 { count += 1 }
    
    // Check numbers > 7 using 6k±1 pattern (simpler)
    let mut k: u64 = 2  // Start from 11, 13
    while true {
        let p1 = 6 * k - 1
        let p2 = 6 * k + 1
        
        if p1 > limit && p2 > limit {
            break
        }
        
        // Simple primality test
        if p1 <= limit {
            let mut is_prime = true
            if p1 % 2 == 0 || p1 % 3 == 0 || p1 % 5 == 0 || p1 % 7 == 0 {
                is_prime = false
            } else {
                let mut i: u64 = 11
                while i * i <= p1 {
                    if p1 % i == 0 {
                        is_prime = false
                        // Can't break, set i high
                        i = p1
                    }
                    i += 2
                }
            }
            if is_prime {
                count += 1
            }
        }
        
        if p2 <= limit {
            let mut is_prime = true
            if p2 % 2 == 0 || p2 % 3 == 0 || p2 % 5 == 0 || p2 % 7 == 0 {
                is_prime = false
            } else {
                let mut i: u64 = 11
                while i * i <= p2 {
                    if p2 % i == 0 {
                        is_prime = false
                        i = p2
                    }
                    i += 2
                }
            }
            if is_prime {
                count += 1
            }
        }
        
        k += 1
    }
    
    return count
}

fn main() -> u64 {
    return count_primes_210_wheel(1000000)
}