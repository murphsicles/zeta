// Simple prime counter that works

fn count_primes(limit: u64) -> u64 {
    if limit <= 2 {
        return 0
    }
    
    // Count 2 as prime
    let mut count: u64 = 1
    
    // Check odd numbers starting from 3
    let mut n: u64 = 3
    
    while n < limit {
        let mut is_prime: u64 = 1
        let mut d: u64 = 3
        
        // Check divisibility by odd numbers
        while d * d <= n {
            // Simple divisibility check
            if n % d == 0 {
                is_prime = 0
            }
            d += 2
        }
        
        if is_prime == 1 {
            count += 1
        }
        
        n += 2
    }
    
    return count
}

fn main() -> u64 {
    // Test with limit=10 (should return 4)
    return count_primes(10)
}