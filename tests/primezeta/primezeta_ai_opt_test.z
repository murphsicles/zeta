// PrimeZeta v0.5.0 compatibility test with #[ai_opt]
// This simulates the actual PrimeZeta code structure

const MODULUS: u64 = 30030
const NUM_RESIDUES: usize = 5760

// Precomputed residues coprime to 30030 (generated once at CTFE)
comptime residues: [NUM_RESIDUES]u64 = generate_residues()

// Residue index LUT
comptime residue_to_index: [MODULUS]u8 = generate_residue_index()

// Giant CTFE stepping LUT: for every prime-residue pair, precompute next mark offset
// This is the secret sauce of the current world champion
#[ai_opt]  // Line that needs to be parsed correctly
comptime stepping_lut: [[NUM_RESIDUES]u16; NUM_RESIDUES] = generate_stepping_lut()

// ==================== CTFE HELPERS ====================
comptime fn generate_residues() -> [NUM_RESIDUES]u64 {
    var list: [NUM_RESIDUES]u64 = [0; NUM_RESIDUES]
    var idx: usize = 0
    for i in 1..MODULUS {
        if gcd(i, MODULUS) == 1 {
            list[idx] = i as u64
            idx += 1
        }
    }
    return list
}

comptime fn generate_residue_index() -> [MODULUS]u8 {
    var arr: [MODULUS]u8 = [0; MODULUS]
    for i in 0..NUM_RESIDUES {
        arr[residues[i] as usize] = (i + 1) as u8
    }
    return arr
}

#[ai_opt]  // Another #[ai_opt] on a function
comptime fn generate_stepping_lut() -> [[NUM_RESIDUES]u16; NUM_RESIDUES] {
    var lut: [[NUM_RESIDUES]u16; NUM_RESIDUES] = [[0; NUM_RESIDUES]; NUM_RESIDUES]
    // Simplified for test
    return lut
}

// Helper function (not in original PrimeZeta but needed for compilation)
fn gcd(a: u64, b: u64) -> u64 {
    if b == 0 {
        return a
    }
    return gcd(b, a % b)
}

fn main() -> i64 {
    println!("PrimeZeta compatibility test with #[ai_opt]")
    0
}