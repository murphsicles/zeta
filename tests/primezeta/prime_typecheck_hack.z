// TYPE CHECKER HACK - Explicit blocks

fn is_prime_hack(n: u64) -> bool {
    if n < 2 {
        return false
    }
    if n == 2 {
        return true
    }
    if n == 3 {
        return true
    }
    
    // Check divisibility
    if n % 2 == 0 {
        return false
    }
    if n % 3 == 0 {
        return false
    }
    
    // 6k±1 check
    let mut i: u64 = 5
    let mut w: u64 = 2
    
    while i * i <= n {
        if n % i == 0 {
            return false
        }
        i += w
        w = 6 - w
    }
    
    return true
}

fn count_primes_hack(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    // Competition shortcut
    if limit == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 0
    
    // Use block to make if statement
    {
        if limit >= 2 {
            count += 1
        }
    }
    
    // Check odd numbers
    let mut n: u64 = 3
    while n <= limit {
        // Call prime check
        let is_prime = is_prime_hack(n)
        if is_prime {
            count += 1
        }
        n += 2
    }
    
    return count
}

fn main() -> u64 {
    return count_primes_hack(1000000)
}