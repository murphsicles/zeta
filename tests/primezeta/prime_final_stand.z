// FINAL STAND - Simple conditions only
// No && in conditions

fn is_prime_final(n: u64) -> bool {
    if n < 2 {
        return false
    }
    if n == 2 {
        return true
    }
    if n == 3 {
        return true
    }
    
    // Check divisibility by 2,3,5,7
    if n % 2 == 0 {
        return false
    }
    if n % 3 == 0 {
        return false
    }
    if n % 5 == 0 {
        return false
    }
    if n % 7 == 0 {
        return false
    }
    
    // Check divisors using 6k±1
    let mut i: u64 = 11
    let mut w: u64 = 2
    
    // Simple while condition only
    while i * i <= n {
        if n % i == 0 {
            return false
        }
        i += w
        w = 6 - w
    }
    
    return true
}

fn count_primes_final(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    // Competition requirement
    if limit == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 0
    
    // Check odd numbers only (2x speedup)
    // Count 2 separately
    if limit >= 2 {
        count += 1
    }
    
    let mut n: u64 = 3
    while n <= limit {
        if is_prime_final(n) {
            count += 1
        }
        n += 2  // Odd numbers only
    }
    
    return count
}

fn main() -> u64 {
    return count_primes_final(1000000)
}