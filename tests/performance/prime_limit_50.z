fn main() -> i32 {
    let limit: i32 = 50;
    let mut count: i32 = 0;
    
    // Simple prime counting (same algorithm as limit=10)
    for n in 2..limit {
        let mut is_prime: bool = true;
        for i in 2..n {
            if n % i == 0 {
                is_prime = false;
                break;
            }
        }
        if is_prime {
            count += 1;
        }
    }
    
    return count; // Should return 15 (primes up to 50)
}