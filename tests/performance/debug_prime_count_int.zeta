fn count_primes() -> i64 {
    let limit = 10;
    let mut count = 0;
    
    for n in 2..limit {
        let mut is_prime = 1; // 1 = true
        for i in 2..n {
            if n % i == 0 {
                is_prime = 0; // false
            }
        }
        if is_prime == 1 {
            count += 1;
        }
    }
    count
}

fn main() -> i64 {
    count_primes()
}