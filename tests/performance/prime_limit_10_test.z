fn main() -> i64 {
    let limit: i64 = 10;
    let mut count: i64 = 0;
    
    // Same algorithm as previous tests
    for n in 2..limit {
        let mut is_prime: bool = true;
        for i in 2..n {
            if n % i == 0 {
                is_prime = false;
                break;
            }
        }
        if is_prime {
            count += 1;
        }
    }
    
    return count; // Should return 4 (primes: 2, 3, 5, 7)
}