// Validation test for Murphy's Sieve implementations
// Tests correctness against known prime counts

// Test implementations (simplified versions for testing)
fn sieve_baseline(limit: usize) -> u64 {
    if limit < 2 {
        return 0;
    }
    
    let mut is_prime: [u8; 1000] = [1; 1000];
    is_prime[0] = 0;
    is_prime[1] = 0;
    
    let mut i = 2;
    while i * i <= limit {
        if is_prime[i] == 1 {
            let mut j = i * i;
            while j <= limit {
                is_prime[j] = 0;
                j += i;
            }
        }
        i += 1;
    }
    
    let mut count: u64 = 0;
    let mut k = 2;
    while k <= limit {
        if is_prime[k] == 1 {
            count += 1;
        }
        k += 1;
    }
    
    return count;
}

fn sieve_optimized(limit: usize) -> u64 {
    if limit < 2 {
        return 0;
    }
    
    let mut is_prime: [u8; 1000] = [1; 1000];
    is_prime[0] = 0;
    is_prime[1] = 0;
    
    // Handle small primes
    let mut j = 4;
    while j <= limit {
        is_prime[j] = 0;
        j += 2;
    }
    
    j = 9;
    while j <= limit {
        is_prime[j] = 0;
        j += 3;
    }
    
    j = 25;
    while j <= limit {
        is_prime[j] = 0;
        j += 5;
    }
    
    // Wheel factorization
    let sqrt_limit = 31;  // sqrt(1000) ≈ 31
    let mut i = 7;
    
    while i <= sqrt_limit {
        // Wheel offsets for 2,3,5
        let offsets = [0, 4, 6, 10, 12, 16, 18, 22];
        for &offset in &offsets {
            let prime = i + offset;
            if prime > sqrt_limit {
                break;
            }
            
            if is_prime[prime] == 1 {
                let mut multiple = prime * prime;
                while multiple <= limit {
                    is_prime[multiple] = 0;
                    multiple += prime;
                }
            }
        }
        i += 30;
    }
    
    let mut count: u64 = 0;
    let mut k = 2;
    while k <= limit {
        if is_prime[k] == 1 {
            count += 1;
        }
        k += 1;
    }
    
    return count;
}

// Known prime counts for validation
// π(10) = 4
// π(100) = 25  
// π(1000) = 168
// π(10000) = 1229
// π(100000) = 9592
// π(1000000) = 78498

fn test_small_limits() -> bool {
    let test_cases = [
        (10, 4),
        (100, 25),
        (1000, 168),
    ];
    
    for &(limit, expected) in &test_cases {
        let count1 = sieve_baseline(limit);
        let count2 = sieve_optimized(limit);
        
        if count1 != expected as u64 || count2 != expected as u64 {
            return false;
        }
    }
    
    return true;
}

fn test_consistency() -> bool {
    // Test that both implementations give same results
    for limit in [50, 200, 500, 800] {
        let count1 = sieve_baseline(limit);
        let count2 = sieve_optimized(limit);
        
        if count1 != count2 {
            return false;
        }
    }
    
    return true;
}

fn main() -> u64 {
    // Run validation tests
    let small_limits_ok = test_small_limits();
    let consistency_ok = test_consistency();
    
    // Return test results
    // 0 = all tests passed
    // 1 = small limits test failed
    // 2 = consistency test failed
    // 3 = both tests failed
    
    if small_limits_ok && consistency_ok {
        return 0;
    } else if !small_limits_ok && consistency_ok {
        return 1;
    } else if small_limits_ok && !consistency_ok {
        return 2;
    } else {
        return 3;
    }
}