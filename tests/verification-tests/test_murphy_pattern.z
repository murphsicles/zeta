// Test Murphy's Sieve pattern that previously failed
// Array indexing in while loop with if statement without else

fn test_murphy_pattern() -> u64 {
    let limit = 10
    let mut bits = [0; 11]  // Array of size limit+1
    
    // Initialize (this would fail before the fix)
    let mut i = 2
    while i <= limit {
        if i % 2 == 0 {
            bits[i] = 1  // Mark as composite
        }
        // No else branch - this was the problem
        i = i + 1
    }
    
    // Count primes (simple test)
    let mut count = 0
    let mut p = 2
    while p <= limit {
        if bits[p] == 0 {
            count = count + 1
        }
        p = p + 1
    }
    
    return count  // Should return number of primes <= 10
}

fn main() -> u64 {
    return test_murphy_pattern()  // Should return 4 (primes: 2,3,5,7)
}