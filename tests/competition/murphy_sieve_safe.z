// Murphy's Sieve with bounds checking

fn murphy_sieve_safe(limit: i32) -> i32 {
    // Use a static array size for testing
    let array_size = 1000;
    let mut sieve: [bool; 1000] = [false; 1000];
    
    // Safety check
    if limit > array_size {
        return 0;
    }
    
    // Initialize
    if limit > 0 {
        sieve[0] = false;
    }
    if limit > 1 {
        sieve[1] = false;
    }
    
    // Mark potential primes
    let mut i = 2;
    while i < limit {
        sieve[i] = true;
        i += 1;
    }
    
    // Sieve with bounds checking
    i = 2;
    while i * i < limit {
        if sieve[i] {
            let mut j = i * i;
            while j < limit {
                sieve[j] = false;
                j += i;
            }
        }
        i += 1;
    }
    
    // Count
    let mut count = 0;
    let mut k = 0;
    while k < limit {
        if sieve[k] {
            count += 1;
        }
        k += 1;
    }
    
    return count;
}

fn main() -> i32 {
    // Test with limit 100 (should return 25 primes)
    let result = murphy_sieve_safe(100);
    return result; // Should return 25
}