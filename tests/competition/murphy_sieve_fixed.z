// Murphy's Sieve - Fixed version
// The bug was in the while loop condition: i * i < limit
// The condition needs to be manually recomputed each iteration

fn main() -> i64 {
    let limit: i64 = 1000;
    
    // Create array (using fixed size for now)
    let mut is_prime: [bool; 1000] = [true; 1000];
    
    // 0 and 1 are not prime
    is_prime[0] = false;
    is_prime[1] = false;
    
    let mut i: i64 = 2;
    
    // Manually compute and check condition
    let mut condition = i * i < limit;
    
    while condition {
        if is_prime[i as usize] {
            let mut j: i64 = i * i;
            while j < limit {
                is_prime[j as usize] = false;
                j += i;
            }
        }
        
        i += 1;
        condition = i * i < limit; // Recompute condition
    }
    
    // Count primes
    let mut count: i64 = 0;
    let mut k: i64 = 0;
    while k < limit {
        if is_prime[k as usize] {
            count += 1;
        }
        k += 1;
    }
    
    return count; // Should return 168 for limit=1000
}