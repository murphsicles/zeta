// Murphy's Sieve - Fixed version with small limit
fn main() -> i64 {
    let limit: i64 = 10;
    
    // Create array
    let mut is_prime: [bool; 10] = [true; 10];
    
    // 0 and 1 are not prime
    is_prime[0] = false;
    is_prime[1] = false;
    
    let mut i: i64 = 2;
    
    // Manually compute and check condition
    let mut condition = i * i < limit;
    
    while condition {
        if is_prime[i as usize] {
            let mut j: i64 = i * i;
            while j < limit {
                is_prime[j as usize] = false;
                j += i;
            }
        }
        
        i += 1;
        condition = i * i < limit; // Recompute condition
    }
    
    // Count primes
    let mut count: i64 = 0;
    let mut k: i64 = 0;
    while k < limit {
        if is_prime[k as usize] {
            count += 1;
        }
        k += 1;
    }
    
    return count; // Should return 4 for limit=10
}