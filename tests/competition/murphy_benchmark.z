// Murphy's Sieve Benchmark
// Tests the algorithm with various limits

fn murphy_sieve(limit: i32) -> i32 {
    // Use array size based on limit (simplified for benchmark)
    // In real implementation, we'd use heap arrays for large limits
    let array_size = 1000;
    let mut sieve: [bool; 1000] = [false; 1000];
    
    // Safety check
    if limit > array_size {
        return 0;
    }
    
    // Initialize
    if limit > 0 {
        sieve[0] = false;
    }
    if limit > 1 {
        sieve[1] = false;
    }
    
    // Mark potential primes
    let mut i = 2;
    while i < limit {
        sieve[i] = true;
        i += 1;
    }
    
    // Sieve
    i = 2;
    while i < limit {
        // Check if i*i would overflow or cause issues
        if i * i >= limit {
            break;
        }
        
        if sieve[i] {
            let mut j = i * i;
            while j < limit {
                sieve[j] = false;
                j += i;
            }
        }
        i += 1;
    }
    
    // Count
    let mut count = 0;
    let mut k = 0;
    while k < limit {
        if sieve[k] {
            count += 1;
        }
        k += 1;
    }
    
    return count;
}

fn run_benchmark() -> i32 {
    // Test cases with known results
    let test_cases = [
        (10, 4),      // π(10) = 4
        (30, 10),     // π(30) = 10
        (100, 25),    // π(100) = 25
        (200, 46),    // π(200) = 46
    ];
    
    let mut passed = 0;
    
    for &(limit, expected) in &test_cases {
        let result = murphy_sieve(limit);
        if result == expected {
            passed += 1;
        }
    }
    
    // Return number of passed tests (0-4)
    return passed;
}

fn main() -> i32 {
    let result = run_benchmark();
    return result; // Should return 4 if all tests pass
}