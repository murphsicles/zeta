// Test array assignment in comptime context
// Objective 3: Add array assignment in comptime

comptime fn array_literal() -> [i64; 3] {
    [1, 2, 3]
}

comptime fn array_indexing() -> i64 {
    let arr = [10, 20, 30, 40, 50]
    arr[2]
}

comptime fn array_element_assignment() -> [i64; 3] {
    var arr = [0, 0, 0]
    arr[0] = 100
    arr[1] = 200
    arr[2] = 300
    arr
}

comptime fn array_in_loop() -> [i64; 5] {
    var result = [0, 0, 0, 0, 0]
    for i in 0..5 {
        result[i] = i * 10
    }
    result
}

comptime fn nested_array() -> [[i64; 2]; 2] {
    var matrix = [[0, 0], [0, 0]]
    matrix[0][0] = 1
    matrix[0][1] = 2
    matrix[1][0] = 3
    matrix[1][1] = 4
    matrix
}

comptime fn array_from_function() -> [i64; 3] {
    fn make_array() -> [i64; 3] {
        [7, 8, 9]
    }
    make_array()
}

comptime fn array_slice_assignment() -> [i64; 5] {
    var arr = [0, 0, 0, 0, 0]
    // Simulate slice assignment (simplified)
    for i in 0..3 {
        arr[i] = (i + 1) * 100
    }
    arr
}

comptime fn array_return_from_comptime() -> [i64; 4] {
    comptime fn generate() -> [i64; 4] {
        var result = [0, 0, 0, 0]
        for i in 0..4 {
            result[i] = i * i
        }
        result
    }
    generate()
}

fn main() -> i64 {
    let arr1 = array_literal()
    let val1 = array_indexing()
    let arr2 = array_element_assignment()
    let arr3 = array_in_loop()
    let matrix = nested_array()
    let arr4 = array_from_function()
    let arr5 = array_slice_assignment()
    let arr6 = array_return_from_comptime()
    
    // Sum all array elements for a single return value
    var total = val1
    
    for elem in arr1 {
        total = total + elem
    }
    
    for elem in arr2 {
        total = total + elem
    }
    
    for elem in arr3 {
        total = total + elem
    }
    
    for row in matrix {
        for elem in row {
            total = total + elem
        }
    }
    
    for elem in arr4 {
        total = total + elem
    }
    
    for elem in arr5 {
        total = total + elem
    }
    
    for elem in arr6 {
        total = total + elem
    }
    
    total
}