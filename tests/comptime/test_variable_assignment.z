// Test variable assignment in comptime context
// Objective 1: Implement variable assignment in comptime

comptime fn simple_assignment() -> i64 {
    let x = 42
    x
}

comptime fn multiple_assignments() -> i64 {
    let a = 10
    let b = 32
    a + b
}

comptime fn variable_mutation() -> i64 {
    var x = 5
    x = x + 10
    x
}

comptime fn nested_assignments() -> i64 {
    let outer = 100
    {
        let inner = 42
        outer + inner
    }
}

comptime fn reassignment() -> i64 {
    var counter = 0
    counter = counter + 1
    counter = counter + 2
    counter = counter + 3
    counter
}

fn main() -> i64 {
    let result1 = simple_assignment()
    let result2 = multiple_assignments()
    let result3 = variable_mutation()
    let result4 = nested_assignments()
    let result5 = reassignment()
    
    // All should be evaluated at compile time
    result1 + result2 + result3 + result4 + result5
}