// Test control flow in comptime context
// Objective 2: Implement comptime control flow

comptime fn simple_if() -> i64 {
    if true {
        42
    } else {
        0
    }
}

comptime fn if_else() -> i64 {
    let condition = false
    if condition {
        100
    } else {
        200
    }
}

comptime fn if_with_expression() -> i64 {
    let x = 10
    let y = 20
    if x < y {
        x + y
    } else {
        x - y
    }
}

comptime fn nested_if() -> i64 {
    let a = 5
    let b = 10
    let c = 15
    
    if a < b {
        if b < c {
            a + b + c
        } else {
            a
        }
    } else {
        b
    }
}

comptime fn for_loop_range() -> i64 {
    var sum = 0
    for i in 0..10 {
        sum = sum + i
    }
    sum
}

comptime fn for_loop_with_step() -> i64 {
    var result = 0
    for i in 0..20 step 2 {
        result = result + i
    }
    result
}

comptime fn nested_loops() -> i64 {
    var total = 0
    for i in 0..5 {
        for j in 0..5 {
            total = total + (i * j)
        }
    }
    total
}

comptime fn loop_with_break() -> i64 {
    var value = 0
    for i in 0..100 {
        if i == 42 {
            value = i
            break
        }
    }
    value
}

comptime fn loop_with_continue() -> i64 {
    var sum = 0
    for i in 0..10 {
        if i % 2 == 0 {
            continue
        }
        sum = sum + i
    }
    sum
}

fn main() -> i64 {
    let r1 = simple_if()
    let r2 = if_else()
    let r3 = if_with_expression()
    let r4 = nested_if()
    let r5 = for_loop_range()
    let r6 = for_loop_with_step()
    let r7 = nested_loops()
    let r8 = loop_with_break()
    let r9 = loop_with_continue()
    
    // All should be evaluated at compile time
    r1 + r2 + r3 + r4 + r5 + r6 + r7 + r8 + r9
}