// Final demo of comptime capabilities
// Shows what works after the emergency implementation

// Objective 1: Variable assignment ✓
comptime fn demo_variables() -> i64 {
    let a = 10
    let b = 20
    a + b  // Returns 30
}

// Objective 1: Variable mutation (with workaround) ✓
comptime fn demo_mutation() -> i64 {
    // Workaround for parser issue with 'var'
    x = 5
    x = x + 10
    x  // Returns 15
}

// Objective 2: Control flow - if statements ✓
comptime fn demo_if() -> i64 {
    let x = 5
    let y = 10
    if x < y {
        x + y  // Returns 15
    } else {
        x - y
    }
}

// Objective 2: Control flow - nested if ✓
comptime fn demo_nested_if() -> i64 {
    let a = 1
    let b = 2
    let c = 3
    
    if a < b {
        if b < c {
            a + b + c  // Returns 6
        } else {
            a
        }
    } else {
        b
    }
}

// Objective 3: Array operations ✓
comptime fn demo_arrays() -> i64 {
    let arr = [1, 2, 3, 4, 5]
    arr[2]  // Returns 3
}

// Objective 3: Array in blocks ✓
comptime fn demo_array_blocks() -> i64 {
    let outer = 100
    {
        let inner = 42
        let arr = [outer, inner]
        arr[0] + arr[1]  // Returns 142
    }
}

// Combined test
comptime fn demo_all() -> i64 {
    demo_variables() + demo_mutation() + demo_if() + demo_nested_if() + demo_arrays() + demo_array_blocks()
}

// Simple PrimeZeta-like function (simplified)
comptime fn simple_residue_generator() -> i64 {
    var result = 0
    // Simple loop that works
    // Note: For loops with variable updates don't fully work yet
    // So we use manual unrolling
    result = result + 2  // First "prime-like"
    result = result + 3  // Second
    result = result + 5  // Third
    result = result + 7  // Fourth
    result = result + 11 // Fifth
    result  // Returns 28
}