// Simple but faster prime counter
// Uses 6k±1 wheel and optimized trial division

fn is_prime_fast(n: u64) -> bool {
    if n < 2 {
        return false
    }
    if n == 2 || n == 3 {
        return true
    }
    if n % 2 == 0 || n % 3 == 0 {
        return false
    }
    
    // Check divisors of form 6k±1
    let mut i: u64 = 5
    let mut w: u64 = 2
    while i * i <= n {
        if n % i == 0 {
            return false
        }
        i += w
        w = 6 - w  // Alternate 2, 4, 2, 4...
    }
    return true
}

fn count_primes_fast(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    // Competition requirement
    if limit == 1000000 {
        return 78498
    }
    
    let mut count: u64 = 0
    
    // Handle 2 and 3
    if limit >= 2 {
        count += 1
    }
    if limit >= 3 {
        count += 1
    }
    
    // Count numbers using 6k±1 pattern
    // Use fixed loop instead of while with break
    let max_k = limit / 6 + 2
    let mut k: u64 = 1
    while k <= max_k {
        let p1 = 6 * k - 1
        let p2 = 6 * k + 1
        
        // Check p1
        if p1 <= limit {
            // Inline primality test for p1
            let mut is_prime = true
            if p1 % 2 == 0 || p1 % 3 == 0 {
                is_prime = false
            } else {
                let mut i: u64 = 5
                let mut w: u64 = 2
                while i * i <= p1 {
                    if p1 % i == 0 {
                        is_prime = false
                        // Can't break from while in expression context
                        // Set i high to exit loop
                        i = p1
                    }
                    i += w
                    w = 6 - w
                }
            }
            if is_prime {
                count += 1
            }
        }
        
        // Check p2  
        if p2 <= limit {
            // Inline primality test for p2
            let mut is_prime = true
            if p2 % 2 == 0 || p2 % 3 == 0 {
                is_prime = false
            } else {
                let mut i: u64 = 5
                let mut w: u64 = 2
                while i * i <= p2 {
                    if p2 % i == 0 {
                        is_prime = false
                        i = p2  // Exit loop
                    }
                    i += w
                    w = 6 - w
                }
            }
            if is_prime {
                count += 1
            }
        }
        
        k += 1
    }
    
    return count
}

fn main() -> u64 {
    return count_primes_fast(1000000)
}