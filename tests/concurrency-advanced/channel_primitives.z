// tests/concurrency-advanced/channel_primitives.z
// Advanced channel primitives: MPSC, bounded/unbounded, selection, timeouts

// Channel trait definition
trait Channel<T> {
    fn send(&self, value: T) -> Result<(), ChannelError>;
    fn recv(&self) -> Result<T, ChannelError>;
    fn try_recv(&self) -> Result<T, ChannelError>;
    fn len(&self) -> usize;
    fn is_empty(&self) -> bool;
    fn capacity(&self) -> Option<usize>;
}

// Channel errors
enum ChannelError {
    Closed,
    Timeout,
    Full,
    Empty,
    Disconnected,
}

// Unbounded MPSC channel
struct UnboundedChannel<T> {
    sender: std::sync::mpsc::Sender<T>,
    receiver: std::sync::mpsc::Receiver<T>,
}

impl<T> UnboundedChannel<T> {
    fn new() -> Self {
        let (sender, receiver) = std::sync::mpsc::channel();
        Self { sender, receiver }
    }
    
    fn sender(&self) -> UnboundedSender<T> {
        UnboundedSender {
            inner: self.sender.clone(),
        }
    }
    
    fn receiver(&self) -> UnboundedReceiver<T> {
        UnboundedReceiver {
            inner: self.receiver.clone(),
        }
    }
}

impl<T: Send + 'static> Channel<T> for UnboundedChannel<T> {
    fn send(&self, value: T) -> Result<(), ChannelError> {
        self.sender.send(value)
            .map_err(|_| ChannelError::Disconnected)
    }
    
    fn recv(&self) -> Result<T, ChannelError> {
        self.receiver.recv()
            .map_err(|_| ChannelError::Disconnected)
    }
    
    fn try_recv(&self) -> Result<T, ChannelError> {
        self.receiver.try_recv()
            .map_err(|e| match e {
                std::sync::mpsc::TryRecvError::Empty => ChannelError::Empty,
                std::sync::mpsc::TryRecvError::Disconnected => ChannelError::Disconnected,
            })
    }
    
    fn len(&self) -> usize {
        0 // Unbounded channels don't track length
    }
    
    fn is_empty(&self) -> bool {
        true // Can't determine for unbounded
    }
    
    fn capacity(&self) -> Option<usize> {
        None // Unbounded
    }
}

// Bounded MPSC channel
struct BoundedChannel<T> {
    sender: std::sync::mpsc::SyncSender<T>,
    receiver: std::sync::mpsc::Receiver<T>,
    capacity: usize,
}

impl<T> BoundedChannel<T> {
    fn new(capacity: usize) -> Self {
        let (sender, receiver) = std::sync::mpsc::sync_channel(capacity);
        Self {
            sender,
            receiver,
            capacity,
        }
    }
    
    fn sender(&self) -> BoundedSender<T> {
        BoundedSender {
            inner: self.sender.clone(),
            capacity: self.capacity,
        }
    }
    
    fn receiver(&self) -> BoundedReceiver<T> {
        BoundedReceiver {
            inner: self.receiver.clone(),
        }
    }
}

impl<T: Send + 'static> Channel<T> for BoundedChannel<T> {
    fn send(&self, value: T) -> Result<(), ChannelError> {
        self.sender.send(value)
            .map_err(|e| {
                if e.is_full() {
                    ChannelError::Full
                } else {
                    ChannelError::Disconnected
                }
            })
    }
    
    fn recv(&self) -> Result<T, ChannelError> {
        self.receiver.recv()
            .map_err(|_| ChannelError::Disconnected)
    }
    
    fn try_recv(&self) -> Result<T, ChannelError> {
        self.receiver.try_recv()
            .map_err(|e| match e {
                std::sync::mpsc::TryRecvError::Empty => ChannelError::Empty,
                std::sync::mpsc::TryRecvError::Disconnected => ChannelError::Disconnected,
            })
    }
    
    fn len(&self) -> usize {
        0 // Bounded channels don't track length
    }
    
    fn is_empty(&self) -> bool {
        true // Can't determine for bounded
    }
    
    fn capacity(&self) -> Option<usize> {
        Some(self.capacity)
    }
}

// Sender/Receiver wrappers
struct UnboundedSender<T> {
    inner: std::sync::mpsc::Sender<T>,
}

struct UnboundedReceiver<T> {
    inner: std::sync::mpsc::Receiver<T>,
}

struct BoundedSender<T> {
    inner: std::sync::mpsc::SyncSender<T>,
    capacity: usize,
}

struct BoundedReceiver<T> {
    inner: std::sync::mpsc::Receiver<T>,
}

// Channel selector for multiple channel operations
struct ChannelSelector {
    channels: Vec<SelectorEntry>,
}

struct SelectorEntry {
    id: usize,
    ready: bool,
}

impl ChannelSelector {
    fn new() -> Self {
        Self {
            channels: Vec::new(),
        }
    }
    
    fn add_channel<T>(&mut self, channel: &dyn Channel<T>) -> usize {
        let id = self.channels.len();
        self.channels.push(SelectorEntry {
            id,
            ready: false,
        });
        id
    }
    
    fn select(&mut self, timeout_ms: Option<u64>) -> Option<usize> {
        // In a real implementation, this would use OS primitives like select/epoll/kqueue
        // For this example, we simulate with a simple check
        for entry in &mut self.channels {
            // Simulate readiness check
            entry.ready = rand::random::<bool>();
        }
        
        for entry in &self.channels {
            if entry.ready {
                return Some(entry.id);
            }
        }
        
        // Simulate timeout
        if let Some(ms) = timeout_ms {
            std::thread::sleep(std::time::Duration::from_millis(ms));
        }
        
        None
    }
}

// Async channel with timeout support
struct AsyncChannel<T> {
    inner: std::sync::Arc<std::sync::Mutex<Vec<T>>>,
    semaphore: std::sync::Arc<std::sync::Condvar>,
}

impl<T> AsyncChannel<T> {
    fn new() -> Self {
        Self {
            inner: std::sync::Arc::new(std::sync::Mutex::new(Vec::new())),
            semaphore: std::sync::Arc::new(std::sync::Condvar::new()),
        }
    }
    
    fn send(&self, value: T) {
        let mut inner = self.inner.lock().unwrap();
        inner.push(value);
        self.semaphore.notify_one();
    }
    
    fn recv(&self, timeout_ms: Option<u64>) -> Result<T, ChannelError> {
        let mut inner = self.inner.lock().unwrap();
        
        if let Some(timeout) = timeout_ms {
            let start = std::time::Instant::now();
            
            while inner.is_empty() {
                let elapsed = start.elapsed();
                if elapsed.as_millis() > timeout as u128 {
                    return Err(ChannelError::Timeout);
                }
                
                let remaining = std::time::Duration::from_millis(timeout) - elapsed;
                let (new_inner, timeout_result) = self.semaphore.wait_timeout(inner, remaining).unwrap();
                inner = new_inner;
                
                if timeout_result.timed_out() {
                    return Err(ChannelError::Timeout);
                }
            }
        } else {
            while inner.is_empty() {
                inner = self.semaphore.wait(inner).unwrap();
            }
        }
        
        if !inner.is_empty() {
            Ok(inner.remove(0))
        } else {
            Err(ChannelError::Empty)
        }
    }
}

// Test functions
fn test_unbounded_channel() -> i32 {
    println!("=== Testing Unbounded Channel ===");
    
    let channel = UnboundedChannel::<i32>::new();
    let sender = channel.sender();
    let receiver = channel.receiver();
    
    // Spawn sender thread
    let handle = std::thread::spawn(move || {
        for i in 0..10 {
            sender.inner.send(i * 10).unwrap();
            println!("Sent: {}", i * 10);
            std::thread::sleep(std::time::Duration::from_millis(10));
        }
    });
    
    // Receive in main thread
    for _ in 0..10 {
        let value = receiver.inner.recv().unwrap();
        println!("Received: {}", value);
    }
    
    handle.join().unwrap();
    println!("Unbounded channel test passed");
    0
}

fn test_bounded_channel() -> i32 {
    println!("\n=== Testing Bounded Channel ===");
    
    let channel = BoundedChannel::<i32>::new(3);
    let sender = channel.sender();
    let receiver = channel.receiver();
    
    // Spawn sender thread (will block when full)
    let handle = std::thread::spawn(move || {
        for i in 0..5 {
            println!("Attempting to send: {}", i);
            sender.inner.send(i).unwrap();
            println!("Sent: {}", i);
        }
    });
    
    // Receive slowly to demonstrate backpressure
    for i in 0..5 {
        std::thread::sleep(std::time::Duration::from_millis(100));
        let value = receiver.inner.recv().unwrap();
        println!("Received: {}", value);
    }
    
    handle.join().unwrap();
    println!("Bounded channel test passed");
    0
}

fn test_async_channel() -> i32 {
    println!("\n=== Testing Async Channel with Timeout ===");
    
    let channel = std::sync::Arc::new(AsyncChannel::<String>::new());
    let channel_clone = channel.clone();
    
    // Spawn sender thread
    let handle = std::thread::spawn(move || {
        std::thread::sleep(std::time::Duration::from_millis(50));
        channel_clone.send("Hello".to_string());
        std::thread::sleep(std::time::Duration::from_millis(50));
        channel_clone.send("World".to_string());
    });
    
    // Test with timeout (should succeed)
    match channel.recv(Some(100)) {
        Ok(msg) => println!("Received with timeout: {}", msg),
        Err(e) => println!("Timeout error: {:?}", e),
    }
    
    // Test with timeout (should get second message)
    match channel.recv(Some(100)) {
        Ok(msg) => println!("Received second: {}", msg),
        Err(e) => println!("Error: {:?}", e),
    }
    
    // Test with timeout (should fail)
    match channel.recv(Some(10)) {
        Ok(msg) => println!("Unexpected: {}", msg),
        Err(e) => println!("Expected timeout: {:?}", e),
    }
    
    handle.join().unwrap();
    println!("Async channel test passed");
    0
}

fn test_channel_selector() -> i32 {
    println!("\n=== Testing Channel Selector ===");
    
    let mut selector = ChannelSelector::new();
    
    // Create multiple channels
    let channel1 = UnboundedChannel::<i32>::new();
    let channel2 = BoundedChannel::<i32>::new(2);
    let channel3 = std::sync::Arc::new(AsyncChannel::<i32>::new());
    
    // Add to selector
    let id1 = selector.add_channel(&channel1);
    let id2 = selector.add_channel(&channel2);
    let id3 = selector.add_channel(&channel3);
    
    println!("Added channels with IDs: {}, {}, {}", id1, id2, id3);
    
    // Simulate selection
    match selector.select(Some(100)) {
        Some(id) => println!("Selector chose channel {}", id),
        None => println!("Selector timed out"),
    }
    
    println!("Channel selector test completed");
    0
}

fn main() -> i32 {
    let mut result = 0;
    
    result += test_unbounded_channel();
    result += test_bounded_channel();
    result += test_async_channel();
    result += test_channel_selector();
    
    println!("\n=== All Channel Tests Complete ===");
    result
}