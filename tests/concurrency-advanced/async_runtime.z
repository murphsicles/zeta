// tests/concurrency-advanced/async_runtime.z
// Enhanced async runtime with work stealing, task scheduling, and async I/O

// Task priority levels
enum Priority {
    High = 3,
    Normal = 2,
    Low = 1,
    Background = 0,
}

// Task state
enum TaskState {
    Ready,
    Running,
    Blocked,
    Completed,
    Cancelled,
}

// Task trait
trait Task {
    fn run(&mut self);
    fn priority(&self) -> Priority;
    fn state(&self) -> TaskState;
    fn set_state(&mut self, state: TaskState);
    fn is_completed(&self) -> bool;
}

// Concrete task implementation
struct AsyncTask {
    id: u64,
    priority: Priority,
    state: TaskState,
    func: Box<dyn FnOnce() + Send>,
}

impl AsyncTask {
    fn new<F>(id: u64, priority: Priority, func: F) -> Self
    where
        F: FnOnce() + Send + 'static,
    {
        Self {
            id,
            priority,
            state: TaskState::Ready,
            func: Box::new(func),
        }
    }
}

impl Task for AsyncTask {
    fn run(&mut self) {
        self.state = TaskState::Running;
        println!("Task {} running with priority {:?}", self.id, self.priority);
        
        // Execute the function
        (self.func)();
        
        self.state = TaskState::Completed;
        println!("Task {} completed", self.id);
    }
    
    fn priority(&self) -> Priority {
        self.priority
    }
    
    fn state(&self) -> TaskState {
        self.state
    }
    
    fn set_state(&mut self, state: TaskState) {
        self.state = state;
    }
    
    fn is_completed(&self) -> bool {
        matches!(self.state, TaskState::Completed | TaskState::Cancelled)
    }
}

// Work-stealing deque for task scheduling
struct WorkStealingDeque<T> {
    tasks: std::sync::Arc<std::sync::Mutex<Vec<T>>>,
}

impl<T> WorkStealingDeque<T> {
    fn new() -> Self {
        Self {
            tasks: std::sync::Arc::new(std::sync::Mutex::new(Vec::new())),
        }
    }
    
    fn push(&self, task: T) {
        let mut tasks = self.tasks.lock().unwrap();
        tasks.push(task);
    }
    
    fn pop(&self) -> Option<T> {
        let mut tasks = self.tasks.lock().unwrap();
        tasks.pop()
    }
    
    fn steal(&self) -> Option<T> {
        let mut tasks = self.tasks.lock().unwrap();
        if tasks.is_empty() {
            None
        } else {
            // Steal from the front (oldest tasks)
            Some(tasks.remove(0))
        }
    }
    
    fn len(&self) -> usize {
        let tasks = self.tasks.lock().unwrap();
        tasks.len()
    }
    
    fn is_empty(&self) -> bool {
        let tasks = self.tasks.lock().unwrap();
        tasks.is_empty()
    }
}

// Worker thread in the runtime
struct Worker {
    id: usize,
    deque: WorkStealingDeque<Box<dyn Task + Send>>,
    is_running: std::sync::Arc<std::sync::atomic::AtomicBool>,
}

impl Worker {
    fn new(id: usize) -> Self {
        Self {
            id,
            deque: WorkStealingDeque::new(),
            is_running: std::sync::Arc::new(std::sync::atomic::AtomicBool::new(true)),
        }
    }
    
    fn run(&self) {
        println!("Worker {} started", self.id);
        
        while self.is_running.load(std::sync::atomic::Ordering::Relaxed) {
            // Try to get a task from local deque
            if let Some(mut task) = self.deque.pop() {
                task.run();
            } else {
                // No local work, yield to prevent busy waiting
                std::thread::yield_now();
            }
        }
        
        println!("Worker {} stopped", self.id);
    }
    
    fn stop(&self) {
        self.is_running.store(false, std::sync::atomic::Ordering::Relaxed);
    }
}

// Async runtime with work stealing
struct AsyncRuntime {
    workers: Vec<std::sync::Arc<Worker>>,
    global_queue: WorkStealingDeque<Box<dyn Task + Send>>,
    next_task_id: std::sync::atomic::AtomicU64,
}

impl AsyncRuntime {
    fn new(worker_count: usize) -> Self {
        let mut workers = Vec::with_capacity(worker_count);
        
        for i in 0..worker_count {
            let worker = std::sync::Arc::new(Worker::new(i));
            workers.push(worker.clone());
            
            // Start worker thread
            let worker_clone = worker.clone();
            std::thread::spawn(move || {
                worker_clone.run();
            });
        }
        
        Self {
            workers,
            global_queue: WorkStealingDeque::new(),
            next_task_id: std::sync::atomic::AtomicU64::new(1),
        }
    }
    
    fn spawn<F>(&self, priority: Priority, func: F)
    where
        F: FnOnce() + Send + 'static,
    {
        let task_id = self.next_task_id.fetch_add(1, std::sync::atomic::Ordering::SeqCst);
        let task = Box::new(AsyncTask::new(task_id, priority, func));
        
        // For now, just add to global queue
        // In a real implementation, we'd use work stealing
        self.global_queue.push(task);
        
        println!("Spawned task {} with priority {:?}", task_id, priority);
    }
    
    fn spawn_with_priority<F>(&self, func: F, priority: Priority)
    where
        F: FnOnce() + Send + 'static,
    {
        self.spawn(priority, func);
    }
    
    fn shutdown(&self) {
        println!("Shutting down async runtime");
        
        // Stop all workers
        for worker in &self.workers {
            worker.stop();
        }
        
        // Wait a bit for workers to stop
        std::thread::sleep(std::time::Duration::from_millis(100));
    }
}

// Future trait for async/await
trait Future {
    type Output;
    
    fn poll(&mut self) -> Poll<Self::Output>;
}

enum Poll<T> {
    Ready(T),
    Pending,
}

// Simple future implementation
struct ValueFuture<T> {
    value: Option<T>,
}

impl<T> ValueFuture<T> {
    fn new(value: T) -> Self {
        Self {
            value: Some(value),
        }
    }
}

impl<T> Future for ValueFuture<T> {
    type Output = T;
    
    fn poll(&mut self) -> Poll<Self::Output> {
        if let Some(value) = self.value.take() {
            Poll::Ready(value)
        } else {
            Poll::Pending
        }
    }
}

// Async I/O simulation
struct AsyncFile {
    filename: String,
    content: Vec<u8>,
    position: usize,
}

impl AsyncFile {
    fn new(filename: &str) -> Self {
        Self {
            filename: filename.to_string(),
            content: Vec::new(),
            position: 0,
        }
    }
    
    async fn read(&mut self, size: usize) -> Vec<u8> {
        println!("Async reading {} bytes from {}", size, self.filename);
        
        // Simulate async I/O delay
        async_std::task::sleep(std::time::Duration::from_millis(50)).await;
        
        let end = std::cmp::min(self.position + size, self.content.len());
        let result = self.content[self.position..end].to_vec();
        self.position = end;
        
        result
    }
    
    async fn write(&mut self, data: &[u8]) -> usize {
        println!("Async writing {} bytes to {}", data.len(), self.filename);
        
        // Simulate async I/O delay
        async_std::task::sleep(std::time::Duration::from_millis(30)).await;
        
        self.content.extend_from_slice(data);
        data.len()
    }
    
    async fn seek(&mut self, position: usize) {
        println!("Async seeking to position {} in {}", position, self.filename);
        self.position = std::cmp::min(position, self.content.len());
    }
}

// Test functions
fn test_task_scheduling() -> i32 {
    println!("=== Testing Task Scheduling ===");
    
    let runtime = AsyncRuntime::new(2);
    
    // Spawn tasks with different priorities
    runtime.spawn(Priority::High, || {
        println!("High priority task executing");
        std::thread::sleep(std::time::Duration::from_millis(20));
    });
    
    runtime.spawn(Priority::Normal, || {
        println!("Normal priority task executing");
        std::thread::sleep(std::time::Duration::from_millis(30));
    });
    
    runtime.spawn(Priority::Low, || {
        println!("Low priority task executing");
        std::thread::sleep(std::time::Duration::from_millis(40));
    });
    
    runtime.spawn(Priority::Background, || {
        println!("Background priority task executing");
        std::thread::sleep(std::time::Duration::from_millis(50));
    });
    
    // Wait for tasks to complete
    std::thread::sleep(std::time::Duration::from_millis(200));
    
    runtime.shutdown();
    println!("Task scheduling test passed");
    0
}

fn test_work_stealing() -> i32 {
    println!("\n=== Testing Work Stealing ===");
    
    let deque = WorkStealingDeque::<i32>::new();
    
    // Add some tasks
    for i in 0..10 {
        deque.push(i);
    }
    
    println!("Deque has {} tasks", deque.len());
    
    // Simulate local worker popping tasks
    println!("Local worker popping tasks:");
    while let Some(task) = deque.pop() {
        println!("  Popped task: {}", task);
    }
    
    // Refill deque
    for i in 10..20 {
        deque.push(i);
    }
    
    // Simulate another worker stealing
    println!("Another worker stealing tasks:");
    while let Some(task) = deque.steal() {
        println!("  Stole task: {}", task);
    }
    
    println!("Work stealing test passed");
    0
}

