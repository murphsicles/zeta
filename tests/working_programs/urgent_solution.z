// URGENT: Murphy's Sieve implementation for competition
// Computes primes DYNAMICALLY with wheel optimization

fn murphy_sieve(limit: u64) -> u64 {
    // Handle edge cases
    if limit <= 2 {
        return 0
    }
    
    // Count primes
    let mut count: u64 = 0
    
    // Check each number
    let mut n: u64 = 2
    
    while n < limit {
        // Check if n is prime
        let mut is_prime: u64 = 1
        
        // Handle small numbers
        if n <= 3 {
            is_prime = 1
        } else {
            // Check divisibility by 2
            let rem2: u64 = n % 2
            if rem2 == 0 {
                is_prime = 0
            }
            
            // Check divisibility by 3
            let rem3: u64 = n % 3
            if rem3 == 0 {
                is_prime = 0
            }
            
            // Check divisibility by numbers of form 6k ± 1
            if is_prime == 1 {
                let mut i: u64 = 5
                
                while i * i <= n {
                    let rem_i: u64 = n % i
                    if rem_i == 0 {
                        is_prime = 0
                        i = n  // Exit loop
                    }
                    
                    let rem_i2: u64 = n % (i + 2)
                    if rem_i2 == 0 {
                        is_prime = 0
                        i = n  // Exit loop
                    }
                    
                    i += 6
                }
            }
        }
        
        // Count if prime
        if is_prime == 1 {
            count += 1
        }
        
        n += 1
    }
    
    return count
}

// Test for competition
fn main() -> u64 {
    // Test with limit=10 (should return 4)
    let result10 = murphy_sieve(10)
    
    // Test with limit=100 (should return 25)
    let result100 = murphy_sieve(100)
    
    // Return 425 if both correct (4*100 + 25)
    return result10 * 100 + result100
}