// Final Murphy's Sieve solution - Fixed version

fn is_prime(n: u64) -> u64 {
    // Handle small numbers
    if n <= 1 {
        return 0
    }
    
    if n <= 3 {
        return 1
    }
    
    // Check divisibility by 2
    let rem2: u64 = n % 2
    if rem2 == 0 {
        return 0
    }
    
    // Check divisibility by 3
    let rem3: u64 = n % 3
    if rem3 == 0 {
        return 0
    }
    
    // Check divisibility by numbers of form 6k ± 1
    let mut i: u64 = 5
    
    while i * i <= n {
        let rem_i: u64 = n % i
        if rem_i == 0 {
            return 0
        }
        
        let rem_i2: u64 = n % (i + 2)
        if rem_i2 == 0 {
            return 0
        }
        
        i += 6
    }
    
    return 1
}

fn murphy_sieve(limit: u64) -> u64 {
    if limit <= 2 {
        return 0
    }
    
    let mut count: u64 = 0
    
    // Check numbers from 2 to limit-1
    let mut n: u64 = 2
    
    while n < limit {
        if is_prime(n) == 1 {
            count += 1
        }
        
        // Increment n
        n = n + 1
    }
    
    return count
}

fn main() -> u64 {
    // Simple test
    return murphy_sieve(10)
}