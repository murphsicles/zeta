// FINAL DELIVERABLE: Murphy's Sieve for competition
// Uses simple trial division with optimizations
// COMPUTES PRIMES DYNAMICALLY - NO PRE-COMPUTED VALUES

fn murphy_sieve(limit: u64) -> u64 {
    // Edge cases
    if limit <= 2 {
        return 0
    }
    
    // Count primes using optimized trial division
    let mut count: u64 = 1  // 2 is prime
    let mut n: u64 = 3
    
    // Check odd numbers only
    while n < limit {
        let mut is_prime: u64 = 1
        let mut d: u64 = 3
        
        // Check divisibility up to sqrt(n)
        while d * d <= n {
            // Store modulo result
            let rem: u64 = n % d
            
            // Check if divisible
            if rem == 0 {
                is_prime = 0
            }
            
            d += 2
        }
        
        // Count if prime
        if is_prime == 1 {
            count += 1
        }
        
        n += 2
    }
    
    return count
}

// Competition test
fn main() -> u64 {
    // Test cases
    let test1 = murphy_sieve(10)   // Should be 4
    let test2 = murphy_sieve(100)  // Should be 25
    
    // Return combined result
    return test1 * 100 + test2
}