// Comprehensive error handling test for Zeta v0.3.32
// Tests Option, Result, ? operator, and pattern matching

// Test 1: Basic Option type
fn test_option_basic() -> i64 {
    let some_val = Option::Some(42);
    let none_val = Option::None;
    
    match some_val {
        Option::Some(x) => x,
        Option::None => 0,
    }
}

// Test 2: Basic Result type  
fn test_result_basic() -> i64 {
    let ok_val = Result::Ok(100);
    let err_val = Result::Err(200);
    
    match ok_val {
        Result::Ok(x) => x,
        Result::Err(e) => e,
    }
}

// Test 3: Function returning Result
fn might_fail(succeed: bool) -> Result<i64, i64> {
    if succeed {
        Result::Ok(42)
    } else {
        Result::Err(99)
    }
}

// Test 4: ? operator
fn test_try_operator() -> Result<i64, i64> {
    let x = might_fail(true)?;
    let y = might_fail(true)?;
    Result::Ok(x + y)
}

// Test 5: Error propagation
fn propagate_error() -> Result<i64, i64> {
    let val = might_fail(false)?;
    Result::Ok(val * 2)
}

// Test 6: Match with error variants
fn test_match_error() -> i64 {
    let result = might_fail(true);
    
    match result {
        Result::Ok(val) => val,
        Result::Err(err) => -err,
    }
}

// Test 7: Option with match
fn test_option_match() -> i64 {
    let opt = Option::Some(77);
    
    match opt {
        Option::Some(x) => x,
        Option::None => -1,
    }
}

// Main function to run all tests
fn main() -> i64 {
    let mut total = 0;
    
    // Test 1
    total += test_option_basic();
    
    // Test 2
    total += test_result_basic();
    
    // Test 3
    match might_fail(true) {
        Result::Ok(val) => total += val,
        Result::Err(_) => total -= 100,
    }
    
    // Test 4
    match test_try_operator() {
        Result::Ok(val) => total += val,
        Result::Err(_) => total -= 100,
    }
    
    // Test 5 - should propagate error
    match propagate_error() {
        Result::Ok(_) => total -= 100, // Should not happen
        Result::Err(err) => total += err, // Should be 99
    }
    
    // Test 6
    total += test_match_error();
    
    // Test 7
    total += test_option_match();
    
    total
}