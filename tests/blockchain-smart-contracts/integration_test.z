fn test_complete_dapp_workflow() {
    println!("🎯 Testing Complete DApp Workflow...");
    
    // 1. Create blockchain
    let mut blockchain = Blockchain::new(2);
    
    // 2. Create wallets
    let alice = Wallet::new();
    let bob = Wallet::new();
    
    println!("👛 Wallets created:");
    println!("  Alice: {}", alice.address);
    println!("  Bob: {}", bob.address);
    
    // 3. Create and deploy a smart contract
    let source = r#"
        contract SimpleBank {
            mapping(address => uint) balances;
            
            function deposit() public payable {
                balances[msg.sender] += msg.value;
            }
            
            function withdraw(uint amount) public {
                require(balances[msg.sender] >= amount, "Insufficient balance");
                balances[msg.sender] -= amount;
                payable(msg.sender).transfer(amount);
            }
            
            function getBalance(address account) public view returns (uint) {
                return balances[account];
            }
        }
    "#;
    
    let compiler = ContractCompiler::new();
    let mut engine = ContractExecutionEngine::new();
    
    let compiled = compiler.compile(source).unwrap();
    let contract = engine.deploy_contract(compiled, alice.address.clone(), 0).unwrap();
    
    println!("📄 Smart contract deployed at: {}", contract.address);
    
    // 4. Create transactions
    let tx1 = alice.create_transaction(contract.address.clone(), 1000000000000000000u64); // 1 ETH
    let tx2 = alice.create_transaction(bob.address.clone(), 500000000000000000u64); // 0.5 ETH
    
    blockchain.create_transaction(tx1);
    blockchain.create_transaction(tx2);
    
    // 5. Mine transactions
    blockchain.mine_pending_transactions(alice.address.clone());
    
    // 6. Verify blockchain state
    assert!(blockchain.is_chain_valid(), "Blockchain should be valid");
    assert_eq!(blockchain.chain.len(), 2, "Should have 2 blocks");
    
    let alice_balance = blockchain.get_balance(alice.address.clone());
    let bob_balance = blockchain.get_balance(bob.address.clone());
    
    println!("💰 Final balances:");
    println!("  Alice: {} wei", alice_balance);
    println!("  Bob: {} wei", bob_balance);
    
    // 7. Test cryptographic operations
    let message = b"