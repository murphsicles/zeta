                            Parameter {
                                name: String::from("values"),
                                type_name: String::from("uint256[]"),
                            },
                            Parameter {
                                name: String::from("calldatas"),
                                type_name: String::from("bytes[]"),
                            },
                            Parameter {
                                name: String::from("description"),
                                type_name: String::from("string"),
                            },
                        ],
                        outputs: vec![Parameter {
                            name: String::new(),
                            type_name: String::from("uint256"),
                        }],
                        payable: false,
                        constant: false,
                        gas_estimate: 200000,
                    },
                    Function {
                        name: String::from("vote"),
                        inputs: vec![
                            Parameter {
                                name: String::from("proposalId"),
                                type_name: String::from("uint256"),
                            },
                            Parameter {
                                name: String::from("support"),
                                type_name: String::from("uint8"),
                            },
                        ],
                        outputs: Vec::new(),
                        payable: false,
                        constant: false,
                        gas_estimate: 100000,
                    },
                ],
                events: vec![
                    Event {
                        name: String::from("ProposalCreated"),
                        parameters: vec![
                            Parameter {
                                name: String::from("proposalId"),
                                type_name: String::from("uint256"),
                            },
                            Parameter {
                                name: String::from("proposer"),
                                type_name: String::from("address"),
                            },
                        ],
                        indexed: vec![true, true],
