// Should generate routing table at compile time

// 11. Reflection-based serialization
fn serialize_reflective<T: Reflect>(value: &T) -> String {
    let mut result = String::new();
    let type_info = T::type_info();
    
    result.push_str(&format!("{{\"type\":\"{}\",\"fields\":{{", type_info.name));
    
    for (i, field) in type_info.fields.iter().enumerate() {
        if i > 0 {
            result.push(',');
        }
        
        let field_value = value.get_field(&field.name).unwrap();
        result.push_str(&format!("\"{}\":{}", field.name, field_value));
    }
    
    result.push_str("}}");
    result
}

// 12. Compile-time enum variant information
fn enum_info_example() {
    let status_info = type_of::<Status>();
    
    match status_info.kind {
        TypeKind::Enum => {
            println!("Enum variants:");
            for variant in status_info.variants {
                println!("  Variant: {}", variant.name);
                if !variant.fields.is_empty() {
                    println!("    Fields: {:?}", variant.fields);
                }
            }
        }
        _ => println!("Not an enum"),
    }
}

// 13. Attribute-based validation generation
#[auto_validate]
fn create_user(user: ValidatedUser) -> Result<(), ValidationError> {
    // Function parameters are automatically validated
    Ok(())
}

// 14. Compile-time SQL schema generation
#[sql_table(name = "users")]
struct SqlUser {
    #[sql_column(primary_key = true, auto_increment = true)]
    id: u64,
    
    #[sql_column(unique = true, max_length = 50)]
    username: String,
    
    #[sql_column(unique = true)]
    email: String,
    
    #[sql_column(default = "true")]
    active: bool,
    
    #[sql_column(name = "created_at", default = "CURRENT_TIMESTAMP")]
    created: DateTime,
}

// Should generate:
// CREATE TABLE users (
//     id BIGINT PRIMARY KEY AUTO_INCREMENT,
//     username VARCHAR(50) UNIQUE,
//     email VARCHAR(255) UNIQUE,
//     active BOOLEAN DEFAULT TRUE,
//     created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
// );

// Main function to test compile-time reflection
fn main() {
    println!("Testing Compile-time Reflection");
    
    type_info_example();
    enum_info_example();
    
    // Test reflection-based serialization
    let user = User {
        id: 1,
        username: "testuser".to_string(),
        email: "test@example.com".to_string(),
        active: true,
    };
    
    let json = serialize_reflective(&user);
    println!("Serialized user: {}", json);
    
    // Test generated accessors
    let mut data = Data {
        private_field: 42,
        another_field: "hello".to_string(),
    };
    
    println!("Data field: {}", data.private_field());
    data.set_private_field(100);
    println!("Updated field: {}", data.private_field());
    
    println!("All reflection tests completed!");
}