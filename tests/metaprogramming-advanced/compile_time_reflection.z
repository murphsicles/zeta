// Compile-time Reflection Test File
// Tests for compile-time type information and reflection in Zeta v0.3.41

// 1. Type information at compile time
#[reflect]
struct User {
    id: u64,
    username: String,
    email: String,
    active: bool,
}

#[reflect]
enum Status {
    Pending,
    Active,
    Suspended,
    Banned,
}

// 2. Trait introspection
#[introspect]
trait Serializable {
    fn serialize(&self) -> String;
    fn deserialize(data: &str) -> Self;
}

// 3. Compile-time attribute inspection
#[inspect]
#[derive(Debug, Clone)]
#[serde(rename_all = "camelCase")]
struct Config {
    #[field(description = "Server hostname")]
    host: String,
    
    #[field(description = "Server port", default = "8080")]
    port: u16,
    
    #[field(description = "Enable SSL", default = "true")]
    ssl_enabled: bool,
}

// 4. Compile-time validation
#[validate]
struct ValidatedUser {
    #[validate(length(min = 3, max = 20))]
    username: String,
    
    #[validate(email)]
    email: String,
    
    #[validate(range(min = 0, max = 150))]
    age: u8,
}

// 5. Type information queries at compile time
fn type_info_example() {
    // Get type information at compile time
    let user_info = type_of::<User>();
    println!("Type name: {}", user_info.name);
    println!("Kind: {:?}", user_info.kind);
    println!("Field count: {}", user_info.fields.len());
    
    for field in &user_info.fields {
        println!("  Field: {} (type: {})", field.name, field.type_name);
        if let Some(offset) = field.offset {
            println!("    Offset: {}", offset);
        }
    }
    
    // Check if a type implements a trait
    if implements::<User, Debug>() {
        println!("User implements Debug");
    }
    
    if implements::<User, Clone>() {
        println!("User implements Clone");
    }
}

// 6. Compile-time field iteration
fn iterate_fields<T: Reflect>() {
    let type_info = T::type_info();
    
    for field in type_info.fields {
        println!("Field: {}", field.name);
        
        // Access field attributes
        for attr in field.attributes {
            println!("  Attribute: {} = {:?}", attr.name, attr.args);
        }
    }
}

