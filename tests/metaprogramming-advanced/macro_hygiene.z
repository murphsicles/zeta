// 12. Hygiene with attributes
#[macro_hygiene]
macro_rules! attributed_macro {
    ($expr:expr) => {
        {
            #[inline]
            fn helper() -> i32 {
                $expr
            }
            helper()
        }
    }
}

fn test_attributed_hygiene() {
    let result = attributed_macro!(5 + 3);
    println!("Attributed macro result: {}", result);
}

// 13. Hygiene in recursive macros
macro_rules! recursive_factorial {
    (0) => { 1 };
    ($n:expr) => {
        $n * recursive_factorial!($n - 1)
    };
}

fn test_recursive_hygiene() {
    let n = 10; // Outer n
    
    let fact5 = recursive_factorial!(5);
    println!("Factorial of 5: {}", fact5); // Should print 120
    
    println!("Outer n: {}", n); // Should still be 10
}

// 14. Hygiene with lifetime parameters
macro_rules! lifetime_hygiene {
    ($expr:expr) => {
        {
            let result = $expr;
            &result
        }
    }
}

fn test_lifetime_hygiene() {
    let value = lifetime_hygiene!("test");
    println!("Lifetime hygiene: {}", value);
}

// Main function to test all hygiene features
fn main() {
    println!("Testing Macro Hygiene System");
    
    test_basic_hygiene();
    test_variable_capture();
    test_unique_ids();
    test_nested_hygiene();
    test_loop_hygiene();
    test_generated_functions();
    test_pattern_hygiene();
    test_closure_hygiene();
    test_complex_hygiene();
    test_generic_hygiene();
    test_attributed_hygiene();
    test_recursive_hygiene();
    test_lifetime_hygiene();
    
    println!("All hygiene tests completed!");
    
    // Test that hygiene prevents common errors
    println!("\nTesting error prevention:");
    
    // This should work without issues due to hygiene
    let x = 1;
    let y = 2;
    let z = hygienic_add!(x, y);
    println!("Hygienic addition: {} + {} = {}", x, y, z);
    
    // Variables should not be captured unexpectedly
    let counter = 0;
    for _ in 0..3 {
        let _ = unique_counter!();
        // counter should not be affected
    }
    println!("Counter unchanged: {}", counter);
}