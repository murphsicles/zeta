    // Fields and methods generated from .proto file
}

// 7. GraphQL schema generation
#[graphql_schema]
struct GraphQLUser {
    id: ID!,
    username: String!,
    email: String!,
    posts: Vec<Post>,
}

// Should generate GraphQL schema and resolvers

// 8. Web API generation
#[rest_api]
struct UserController {
    #[get("/users")]
    fn get_all() -> Vec<User>,
    
    #[get("/users/:id")]
    fn get_by_id(id: u64) -> Option<User>,
    
    #[post("/users")]
    fn create(user: User) -> User,
    
    #[put("/users/:id")]
    fn update(id: u64, user: User) -> Option<User>,
    
    #[delete("/users/:id")]
    fn delete(id: u64) -> bool,
}

// 9. State machine generation
#[state_machine]
enum OrderState {
    Created,
    Paid,
    Shipped,
    Delivered,
    Cancelled,
}

// Should generate:
// - State transition methods
// - Validation of allowed transitions
// - Event handlers

// 10. Builder pattern with validation
#[smart_builder]
struct Config {
    #[required]
    host: String,
    
    #[required]
    port: u16,
    
    #[default = "5000"]
    timeout: u64,
    
    #[validate(range = "1..10")]
    retries: u8,
    
    #[default = "false"]
    debug: bool,
}

// 11. Observer pattern generation
#[observable]
struct DataModel {
    value: i32,
    name: String,
}

// Should generate:
// - Observer registration methods
// - Event notification system
// - Change tracking

// 12. Cache wrapper generation
#[cached(ttl = "300")] // 5 minutes
fn expensive_computation(x: i32, y: i32) -> i32 {
    std::thread::sleep(std::time::Duration::from_secs(1));
    x * y
}

// Should generate caching layer

// 13. Retry logic generation
#[retry(max_attempts = 3, backoff = "exponential")]
fn unreliable_network_call(url: &str) -> Result<String, Error> {
    // ...
}

// 14. Metrics collection generation
#[instrument]
fn process_request(request: Request) -> Response {
    // Function automatically records metrics:
    // - Execution time
    // - Success/failure count
