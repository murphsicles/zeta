    fn get_users() -> Vec<User> { /* ... */ }
    
    #[route("GET", "/users/:id")]
    fn get_user(id: u64) -> Option<User> { /* ... */ }
    
    #[route("POST", "/users")]
    fn create_user(user: User) -> Result<User, Error> { /* ... */ }
}

// 23. Database migration generation
#[migration(id = "001_create_users")]
fn create_users_table() {
    CREATE TABLE users (
        id BIGINT PRIMARY KEY,
        username VARCHAR(255) NOT NULL,
        email VARCHAR(255) NOT NULL
    );
}

// 24. Compile-time validation rules
#[validate_rules]
struct UserRegistration {
    #[rule("required")]
    username: String,
    
    #[rule("email")]
    email: String,
    
    #[rule("min_length:8")]
    password: String,
    
    #[rule("equals_field:password")]
    confirm_password: String,
}

// 25. Code generation from database schema
#[generate_from_db("users_table")]
struct DbUser {
    // Fields generated from database schema
}

// Example usage of generated code
fn main() {
    println!("Testing Advanced Code Generation");
    
    // Test transformed function
    let result = original_function(5, 3);
    println!("Transformed function result: {}", result);
    
    // Test smart builder
    let config = Config::builder()
        .host("localhost".to_string())
        .port(8080)
        .retries(3)
        .build()
        .expect("Valid configuration");
    
    println!("Config: {}:{}", config.host, config.port);
    
    // Test cached function
    let cached_result = expensive_computation(6, 7);
    println!("Cached computation: {}", cached_result);
    
    // Test with retry
    match unreliable_network_call("https://example.com") {
        Ok(response) => println!("Network call succeeded: {}", response),
        Err(e) => println!("Network call failed: {}", e),
    }
    
    // Test observable
    let mut model = DataModel {
        value: 42,
        name: "Test".to_string(),
    };
    
    // Would notify observers on change
    model.value = 100;
    
    // Test feature-gated code
    #[cfg(feature = "experimental")]
    {
        experimental_feature();
    }
    
    println!("All code generation tests completed!");
}

// Helper functions for examples
struct Customer {
    age: u8,
    status: String,
}

struct Order {
    total: f64,
}

struct Discount;

impl Discount {
    fn percentage(pct: u8) -> Self {
        Discount
    }
}

struct Request;
struct Response;
struct Error;
struct Connection;
struct DateTime;
struct JsonValue;
struct Post;
struct ID;
struct UserRepository;
struct RedisCache;
struct Logger;
struct User {
    id: u64,
    username: String,
    email: String,
}

impl User {
    fn from_row(_row: &()) -> Self {
        User {
            id: 0,
            username: String::new(),
            email: String::new(),
        }
    }
}