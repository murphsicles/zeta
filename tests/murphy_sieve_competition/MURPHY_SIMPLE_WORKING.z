// Murphy's Sieve - Simple Working Version
// Avoids all problematic patterns

fn murphy_sieve(limit: u64) -> u64 {
    // Simple prime counter using trial division
    // This version COMPILES and RUNS
    
    if limit <= 1 {
        return 0
    }
    
    let mut count: u64 = 0
    let mut n: u64 = 2
    
    while n < limit {
        let mut is_prime: u64 = 1
        let mut d: u64 = 2
        
        // Check divisibility
        while d < n {
            // Check if n is divisible by d
            let remainder: u64 = n % d
            if remainder == 0 {
                is_prime = 0
            } else {
                // Not divisible, continue
            }
            d += 1
        }
        
        // Count prime numbers
        if is_prime == 1 {
            count += 1
        } else {
            // Not prime
        }
        
        n += 1
    }
    
    return count
}

fn main() -> u64 {
    // Test with limit=10 (should return 4)
    return murphy_sieve(10)
}