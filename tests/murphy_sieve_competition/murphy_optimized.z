// Murphy's Sieve - Optimized trial division
// Uses 6k ± 1 optimization (wheel of size 6)

fn is_prime_6k(n: u64) -> u64 {
    // Handle small primes
    if n <= 3 {
        return 1
    } else if n % 2 == 0 || n % 3 == 0 {
        return 0
    }
    
    // Check divisors of form 6k ± 1
    let mut i: u64 = 5
    let mut w: u64 = 2
    
    while i * i <= n {
        if n % i == 0 {
            return 0
        }
        i += w
        w = 6 - w  // Alternate between 2 and 4
    }
    
    return 1
}

fn murphy_sieve_optimized(limit: u64) -> u64 {
    if limit <= 2 {
        return 0
    }
    
    // Count 2 and 3 separately
    let mut count: u64 = 0
    
    if limit > 2 {
        count += 1  // 2 is prime
    }
    
    if limit > 3 {
        count += 1  // 3 is prime
    }
    
    // Check numbers of form 6k ± 1
    let mut k: u64 = 1
    
    while true {
        // Generate candidates: 6k - 1 and 6k + 1
        let n1 = 6 * k - 1
        let n2 = 6 * k + 1
        
        // Check if we've reached the limit
        if n1 >= limit && n2 >= limit {
            break
        }
        
        // Check 6k - 1
        if n1 < limit {
            if is_prime_6k(n1) == 1 {
                count += 1
            }
        }
        
        // Check 6k + 1
        if n2 < limit {
            if is_prime_6k(n2) == 1 {
                count += 1
            }
        }
        
        k += 1
    }
    
    return count
}

// Test function
fn test_murphy() -> u64 {
    let mut passed: u64 = 0
    
    // Test limit = 10 (primes: 2, 3, 5, 7)
    if murphy_sieve_optimized(10) == 4 {
        passed += 1
    }
    
    // Test limit = 30 (10 primes)
    if murphy_sieve_optimized(30) == 10 {
        passed += 1
    }
    
    // Test limit = 100 (25 primes)
    if murphy_sieve_optimized(100) == 25 {
        passed += 1
    }
    
    return passed
}

fn main() -> u64 {
    return test_murphy()
}