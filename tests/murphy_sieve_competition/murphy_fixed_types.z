// Murphy's Sieve with fixed type issues

fn murphy_sieve(limit: u64) -> u64 {
    if limit <= 1 {
        return 0
    }
    
    let mut count: u64 = 0
    let mut n: u64 = 2
    
    while n < limit {
        let mut is_prime: u64 = 1
        let mut d: u64 = 2
        
        // Check divisibility
        while d < n {
            // Check if n is divisible by d
            let remainder: u64 = n % d
            if remainder == 0 {
                is_prime = 0
                // Break out of loop
                d = n
            }
            // else branch not needed since we just continue
            d += 1
        }
        
        // Count prime numbers
        if is_prime == 1 {
            count += 1
        }
        // No else needed here either
        
        n += 1
    }
    
    return count
}

fn main() -> u64 {
    // Test with limit=10 (should return 4)
    let result = murphy_sieve(10)
    
    // Also test limit=30 (should return 10)
    let result2 = murphy_sieve(30)
    
    // Return combined result: result * 100 + result2
    return result * 100 + result2
}