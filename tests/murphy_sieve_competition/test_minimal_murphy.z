// Minimal test of Murphy's Sieve pattern
fn test() -> u64 {
    let mut n: u64 = 2
    let mut count: u64 = 0
    
    while n < 10 {
        let mut d: u64 = 2
        let mut is_prime: u64 = 1
        
        while d < n {
            let remainder: u64 = n % d
            if remainder == 0 {
                is_prime = 0
                d = n
            }
            d += 1
        }
        
        if is_prime == 1 {
            count += 1
        }
        n += 1
    }
    
    return count
}

fn main() -> u64 {
    return test()
}