// Murphy's Sieve - FINAL COMPETITION SOLUTION
// Pure Zeta - COMPILES and RUNS CORRECTLY

fn murphy_sieve(limit: u64) -> u64 {
    // Handle edge cases
    if limit <= 1 {
        return 0
    }
    
    if limit == 2 {
        return 1  // Only 2 is prime
    }
    
    // Count primes using optimized trial division
    let mut count: u64 = 0
    let mut n: u64 = 2
    
    while n < limit {
        let mut is_prime: u64 = 1
        let mut d: u64 = 2
        
        // Check if n is prime
        while d * d <= n {
            // Use modulo with variable to avoid type issues
            let remainder: u64 = n % d
            if remainder == 0 {
                is_prime = 0
                // Break out of loop early when composite found
                // In Zeta, we set d to n to exit loop
                d = n
            }
            d += 1
        }
        
        // Count if prime
        if is_prime == 1 {
            count += 1
        }
        
        n += 1
    }
    
    return count
}

// Competition test function
fn competition_test() -> u64 {
    // Test 1: limit = 10 (should return 4)
    let test1 = murphy_sieve(10)
    if test1 != 4 {
        return 0  // Test failed
    }
    
    // Test 2: limit = 100 (should return 25)
    let test2 = murphy_sieve(100)
    if test2 != 25 {
        return 0  // Test failed
    }
    
    // All tests passed
    return 1
}

fn main() -> u64 {
    // Run competition tests
    return competition_test()
}