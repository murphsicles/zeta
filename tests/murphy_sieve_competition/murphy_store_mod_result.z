// Murphy's Sieve - Store modulo result in variable

fn murphy_sieve(limit: u64) -> u64 {
    if limit <= 1 {
        return 0
    }
    
    let mut count: u64 = 0
    let mut n: u64 = 2
    
    while n < limit {
        let mut is_prime: u64 = 1
        let mut d: u64 = 2
        
        while d * d <= n {
            // Store modulo result first
            let remainder: u64 = n % d
            
            if remainder == 0 {
                is_prime = 0
                // Exit loop
                d = n + 1
            } else {
                // Continue
                d += 1
            }
        }
        
        if is_prime == 1 {
            count += 1
        }
        
        n += 1
    }
    
    return count
}

fn main() -> u64 {
    // Simple test
    return murphy_sieve(10)
}