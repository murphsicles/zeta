// Medium-scale prime sieve test
fn main() -> i64 {
    let limit: i64 = 10_000;
    
    // Heap array
    let mut is_prime = [true; limit as usize];
    
    // 0 and 1 are not prime
    is_prime[0] = false;
    is_prime[1] = false;
    
    // Sieve
    let mut i: i64 = 2;
    while i * i < limit {
        if is_prime[i as usize] {
            let mut j: i64 = i * i;
            while j < limit {
                is_prime[j as usize] = false;
                j += i;
            }
        }
        i += 1;
    }
    
    // Count primes
    let mut count: i64 = 0;
    let mut k: i64 = 0;
    while k < limit {
        if is_prime[k as usize] {
            count += 1;
        }
        k += 1;
    }
    
    count  // Should return 1,229 for limit=10,000
}