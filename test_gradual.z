// Test 1: Just impl
impl Parser {
    fn new() -> Parser {
        Parser { input: "", pos: 0 }
    }
}

// Test 2: struct then impl
struct Parser {
    input: String,
    pos: usize,
}

impl Parser {
    fn new() -> Parser {
        Parser { input: "", pos: 0 }
    }
}

// Test 3: enum then struct then impl
enum AstNode {
    Program(Vec<AstNode>),
}

struct Parser {
    input: String,
    pos: usize,
}

impl Parser {
    fn new() -> Parser {
        Parser { input: "", pos: 0 }
    }
}

// Test 4: Full enum from bootstrap
enum AstNode {
    Program(Vec<AstNode>),
    FuncDef {
        name: String,
        params: Vec<(String, String)>, // (name, type)
        ret: String,
        body: Vec<AstNode>,
    },
    Return(Box<AstNode>),
    Lit(i64),
    Ident(String),
    Call {
        func: String,
        args: Vec<AstNode>,
    },
    VarDecl {
        name: String,
        value: Box<AstNode>,
    },
    If {
        condition: Box<AstNode>,
        then_body: Vec<AstNode>,
        else_body: Vec<AstNode>,
    },
}

struct Parser {
    input: String,
    pos: usize,
}

impl Parser {
    fn new() -> Parser {
        Parser { input: "", pos: 0 }
    }
}