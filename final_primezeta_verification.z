// 8. CONTROL FLOW - PrimeZeta uses loops extensively
fn control_flow_test(limit: u64) -> u64 {
    var sum: u64 = 0
    
    // While loops (PrimeZeta uses these)
    var i: u64 = 0
    while i < limit {
        sum += i
        i += 1
    }
    
    // If statements
    if sum > 1000 {
        return sum
    } else {
        return sum * 2
    }
}

