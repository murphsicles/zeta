// 4. GCD FUNCTION - PrimeZeta uses this
fn gcd(a: u64, b: u64) -> u64 {
    var x = a
    var y = b
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

// 5. MURPHY'S SIEVE - CORE PRIMEZETA ALGORITHM
// Simplified version that tests all syntax
fn murphy_sieve_simple(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    // Array initialization - critical syntax
    var sieve: [limit+1]bool = [true; limit+1]
    sieve[0] = false
    sieve[1] = false
    
    // Wheel factorization (simplified)
    var i: u64 = 2
    while i * i <= limit {
        if sieve[i] {
            var j: u64 = i * i
            while j <= limit {
                sieve[j] = false
                j += i
            }
        }
        i += 1
    }
    
    // Count primes
    var count: u64 = 0
    i = 2
    while i <= limit {
        if sieve[i] {
            count += 1
        }
        i += 1
    }
    
    return count
}

// 6. WHEEL FACTORIZATION - PrimeZeta optimization
fn wheel_factorization_test() -> u64 {
    // Test wheel of first 3 primes (2, 3, 5)
    const WHEEL_SIZE: u64 = 30  // 2*3*5
    
    // Create residues array
    var residues: [8]u64 = [1, 7, 11, 13, 17, 19, 23, 29]
    
    // Test that we can iterate through wheel
    var total: u64 = 0
    var i: usize = 0
    while i < 8 {
        total += residues[i]
        i += 1
    }
    
    return total
}

