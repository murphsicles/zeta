// Test program for v0.5.0 standard library

use std::option::Option;
use std::result::Result;
use std::collections::Vec;
use std::string::String;

fn main() -> i32 {
    // Test Option
    let opt: Option<i32> = Option::Some(42);
    let value = opt.unwrap_or(0);
    
    // Test Result
    let res: Result<i32, String> = Result::Ok(100);
    let res_value = res.unwrap_or(0);
    
    // Test Vec (stub)
    let vec = Vec::<i32>::new();
    let len = vec.len();
    
    // Test String (stub)
    let s = String::from("hello");
    let str_len = s.len();
    
    value + res_value + len as i32 + str_len as i32
}