// Test with small limit
fn main() -> i64 {
    let limit = 1000;
    let mut count = 0;
    
    if limit >= 2 {
        count = 1; // Prime 2
        
        let mut n = 3;
        while n <= limit {
            let mut prime = 1;
            let mut d = 3;
            
            while d * d <= n {
                if n % d == 0 {
                    prime = 0;
                    break;
                }
                d = d + 2;
            }
            
            if prime == 1 {
                count = count + 1;
            }
            n = n + 2;
        }
    }
    
    println_i64(count); // Should be 168
    return count;
}