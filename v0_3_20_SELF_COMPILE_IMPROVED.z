// Extended token definitions
fn tok_fn() -> i64 { 100 }
fn tok_main() -> i64 { 101 }
fn tok_return() -> i64 { 102 }
fn tok_const() -> i64 { 103 }
fn tok_struct() -> i64 { 104 }
fn tok_plus() -> i64 { 105 }

// Enhanced lexer - recognizes more tokens
fn lex_char_enhanced(c: i64) -> i64 {
    if c == 102 {  // 'f'
        tok_fn()
    } else if c == 109 {  // 'm'
        tok_main()
    } else if c == 114 {  // 'r'
        tok_return()
    } else if c == 99 {  // 'c'
        tok_const()
    } else if c == 115 {  // 's'
        tok_struct()
    } else if c == 43 {  // '+'
        tok_plus()
    } else {
        0  // Not a recognized token
    }
}

// Enhanced parser - checks for more patterns
fn parse_enhanced(t1: i64, t2: i64, t3: i64, t4: i64, t5: i64) -> i64 {
    // Pattern 1: "fn main() -> i64 { return 0 }"
    if t1 == tok_fn() && t2 == tok_main() && t3 == tok_return() {
        return 1;
    }
    
    // Pattern 2: "const X = 5"
    if t1 == tok_const() {
        return 2;
    }
    
    // Pattern 3: "struct S {"
    if t1 == tok_struct() {
        return 3;
    }
    
    // Pattern 4: "x + y"
    if t1 == tok_plus() {
        return 4;
    }
    
    0  // No pattern matched
}

// Compile function with enhanced capabilities
fn compile_enhanced(source: i64) -> i64 {
    // Lex the source (simplified - just check first 5 chars)
    let t1 = lex_char_enhanced(source / 100000000);
    let t2 = lex_char_enhanced((source / 1000000) % 100);
    let t3 = lex_char_enhanced((source / 10000) % 100);
    let t4 = lex_char_enhanced((source / 100) % 100);
    let t5 = lex_char_enhanced(source % 100);
    
    // Parse with enhanced patterns
    let parsed = parse_enhanced(t1, t2, t3, t4, t5);
    
    // If any pattern matched, compilation succeeded
    if parsed > 0 {
        0  // Success
    } else {
        1  // Failure
    }
}

