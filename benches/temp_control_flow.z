
fn main() -> i64 {
    let mut result = 0;
    let mut i = 0;
    while i < 1000 {
        if i % 2 == 0 {
            result = result + i;
        } else {
            result = result - i;
        }
        
        if i % 3 == 0 {
            result = result * 2;
        }
        
        if i % 5 == 0 {
            result = result / 2;
        }
        
        i = i + 1;
    }
    result
}
