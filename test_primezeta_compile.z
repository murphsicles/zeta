// Simple PrimeZeta compilation test
// Testing array syntax and basic functions

const MODULUS: u64 = 30030
const NUM_RESIDUES: usize = 5760

// Test array initialization with [0; SIZE] syntax
comptime fn init_array() -> [NUM_RESIDUES]u64 {
    var list: [NUM_RESIDUES]u64 = [0; NUM_RESIDUES]
    return list
}

// Test simple prime sieve
fn simple_sieve(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    // Create array with [true; limit+1] syntax
    var sieve: [limit+1]bool = [true; limit+1]
    sieve[0] = false
    sieve[1] = false
    
    var i: u64 = 2
    while i * i <= limit {
        if sieve[i] {
            var j: u64 = i * i
            while j <= limit {
                sieve[j] = false
                j += i
            }
        }
        i += 1
    }
    
    // Count primes
    var count: u64 = 0
    i = 2
    while i <= limit {
        if sieve[i] {
            count += 1
        }
        i += 1
    }
    
    return count
}

fn main() -> u64 {
    // Test with small limit
    let result = simple_sieve(30)
    
    // Should be 10 primes up to 30
    if result == 10 {
        return 1  // Success
    } else {
        return 0  // Failure
    }
}