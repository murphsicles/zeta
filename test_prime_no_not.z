// Prime sieve without ! operator (uses direct assignment)
fn main() -> i64 {
    let limit: i64 = 10;
    
    // Stack array - small size
    let mut is_prime: [bool; 10] = [true; 10];
    
    // Manually mark non-primes (0 and 1 not prime)
    is_prime[0] = false;
    is_prime[1] = false;
    
    // Sieve algorithm (simplified)
    let mut i: i64 = 2;
    while i < limit {
        if is_prime[i as usize] {
            // Mark multiples as not prime
            let mut j: i64 = i * i;
            while j < limit {
                is_prime[j as usize] = false;
                j += i;
            }
        }
        i += 1;
    }
    
    // Count primes
    let mut count: i64 = 0;
    let mut k: i64 = 0;
    while k < limit {
        if is_prime[k as usize] {
            count += 1;
        }
        k += 1;
    }
    
    count  // Should return 4 for limit=10
}