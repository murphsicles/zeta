// Test identity-aware pattern matching
fn test_pattern() -> i64 {
    let s: string[identity:read] = "hello";
    
    // This should work: matching a read-only string with a read-only pattern
    match s {
        t: string[identity:read] => t.len(),
        _ => 0
    }
}

fn main() -> i64 {
    test_pattern()
}