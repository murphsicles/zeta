//! Stub for std::option::Option
pub enum Option<T> {
    Some(T),
    None,
}

impl<T> Option<T> {
    pub fn unwrap_or(self, default: T) -> T {
        match self {
            Option::Some(value) => value,
            Option::None => default,
        }
    }
    
    pub fn is_some(&self) -> bool {
        match self {
            Option::Some(_) => true,
            Option::None => false,
        }
    }
    
    pub fn is_none(&self) -> bool {
        !self.is_some()
    }
}