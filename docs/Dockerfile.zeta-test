# Dockerfile for Zeta compiler testing
FROM ubuntu:22.04

# Install dependencies
RUN apt-get update && apt-get install -y \
    curl \
    build-essential \
    git \
    cmake \
    llvm-14 \
    clang-14 \
    lld-14 \
    && rm -rf /var/lib/apt/lists/*

# Set up Rust (for Zeta compiler build)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Create workspace
WORKDIR /zeta

# Copy Zeta source code
COPY . .

# Build Zeta compiler
RUN cargo build --release

# Test while loop fix
RUN ./target/release/zetac test_while_final_correct.z

# Test Murphy's Sieve
RUN ./target/release/zetac murphy_after_fix.z

# Keep container running for interactive testing
CMD ["/bin/bash"]