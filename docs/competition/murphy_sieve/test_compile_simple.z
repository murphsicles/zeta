// Simple test to verify Zeta compiler can compile sieve code

// Simple sieve implementation
fn simple_sieve(limit: i64) -> i64 {
    if limit < 2 {
        return 0;
    }
    
    // Simple array for testing
    let mut is_prime: [i64] = [];
    
    // Initialize
    let mut i: i64 = 0;
    while i <= limit {
        is_prime.append(1);
        i += 1;
    }
    
    // Mark 0 and 1 as not prime
    if limit >= 0 {
        is_prime[0] = 0;
    }
    if limit >= 1 {
        is_prime[1] = 0;
    }
    
    // Simple sieve
    let mut p: i64 = 2;
    while p * p <= limit {
        if is_prime[p] == 1 {
            let mut multiple = p * p;
            while multiple <= limit {
                is_prime[multiple] = 0;
                multiple += p;
            }
        }
        p += 1;
    }
    
    // Count primes
    let mut count: i64 = 0;
    i = 2;
    while i <= limit {
        if is_prime[i] == 1 {
            count += 1;
        }
        i += 1;
    }
    
    return count;
}

// Test with small limit
fn test_small() -> i64 {
    let result = simple_sieve(10);
    // Should be 4 primes under 10: 2, 3, 5, 7
    if result == 4 {
        return 0;  // Success
    } else {
        return 1;  // Failure
    }
}

// Main function
fn main() -> i64 {
    return test_small();
}