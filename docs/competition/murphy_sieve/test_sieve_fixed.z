// Fixed sieve implementation with correct Zeta syntax

fn simple_sieve(limit: i64) -> i64 {
    if limit < 2 {
        return 0;
    }
    
    // Create dynamic array
    let mut is_prime: [dynamic]i64 = [dynamic]i64{};
    
    // Initialize array with 1s (prime)
    let mut i: i64 = 0;
    while i <= limit {
        is_prime.push(1);
        i += 1;
    }
    
    // Mark 0 and 1 as not prime
    if limit >= 0 {
        is_prime[0] = 0;
    }
    if limit >= 1 {
        is_prime[1] = 0;
    }
    
    // Simple sieve algorithm
    let mut p: i64 = 2;
    while p * p <= limit {
        if is_prime[p] == 1 {
            let mut multiple = p * p;
            while multiple <= limit {
                is_prime[multiple] = 0;
                multiple += p;
            }
        }
        p += 1;
    }
    
    // Count primes
    let mut count: i64 = 0;
    i = 2;
    while i <= limit {
        if is_prime[i] == 1 {
            count += 1;
        }
        i += 1;
    }
    
    return count;
}

// Test function
fn test_sieve() -> i64 {
    // Test with limit = 10
    let result = simple_sieve(10);
    
    // Should be 4 primes under 10: 2, 3, 5, 7
    if result == 4 {
        return 0;  // Success
    } else {
        return 1;  // Failure
    }
}

// Main function
fn main() -> i64 {
    return test_sieve();
}