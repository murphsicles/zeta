// Test file for true Murphy's Sieve algorithm
// Tests the implementation with various limits

// Import the sieve implementation
// Note: In Zeta/PrimeZeta, we'd use a module system
// For now, we'll include the implementation directly

// Maximum limit constant (must match implementation)
const MAX_LIMIT: usize = 1000000;

// True Murphy's Sieve implementation
fn murphy_sieve_true(limit: usize) -> usize {
    // Validate input
    if limit > MAX_LIMIT {
        // Return 0 to indicate error (exceeds maximum)
        return 0;
    }
    
    if limit < 2 {
        return 0;
    }
    
    // Create bit array using const for size
    // 0 = prime, 1 = composite
    let mut is_composite: [usize; MAX_LIMIT + 1] = [0; MAX_LIMIT + 1];
    
    // Mark 0 and 1 as composite (not prime)
    is_composite[0] = 1;
    is_composite[1] = 1;
    
    // Sieve of Eratosthenes algorithm
    let mut p: usize = 2;
    
    // Only need to check up to sqrt(limit)
    while p * p <= limit {
        // If p is prime
        if is_composite[p] == 0 {
            // Mark all multiples of p as composite
            let mut multiple: usize = p * p;
            while multiple <= limit {
                is_composite[multiple] = 1;
                multiple += p;
            }
        }
        p += 1;
    }
    
    // Count primes (is_composite[i] == 0)
    let mut count: usize = 0;
    let mut i: usize = 2;
    
    while i <= limit {
        if is_composite[i] == 0 {
            count += 1;
        }
        i += 1;
    }
    
    return count;
}

// Optimized version with wheel optimization
fn murphy_sieve_optimized(limit: usize) -> usize {
    // Validate input
    if limit > MAX_LIMIT {
        return 0;
    }
    
    if limit < 2 {
        return 0;
    }
    
    if limit == 2 {
        return 1;
    }
    
    // Create bit array using const for size
    let mut is_composite: [usize; MAX_LIMIT + 1] = [0; MAX_LIMIT + 1];
    
    // Mark 0 and 1 as composite
    is_composite[0] = 1;
    is_composite[1] = 1;
    
    // Wheel optimization: pre-mark multiples of small primes
    // Mark multiples of 2
    let mut i: usize = 4;
    while i <= limit {
        is_composite[i] = 1;
        i += 2;
    }
    
    // Mark multiples of 3
    i = 9;
    while i <= limit {
        is_composite[i] = 1;
        i += 3;
    }
    
    // Mark multiples of 5
    i = 25;
    while i <= limit {
        is_composite[i] = 1;
        i += 5;
    }
    
    // Main sieve loop starting from 7
    let mut p: usize = 7;
    
    while p * p <= limit {
        if is_composite[p] == 0 {
            let mut multiple: usize = p * p;
            while multiple <= limit {
                is_composite[multiple] = 1;
                multiple += p;
            }
        }
        p += 1;
    }
    
    // Count primes
    let mut count: usize = 0;
    i = 2;
    
    while i <= limit {
        if is_composite[i] == 0 {
            count += 1;
        }
        i += 1;
    }
    
    return count;
}

// Known prime counts for verification
fn known_prime_count(limit: usize) -> usize {
    match limit {
        0 => 0,
        1 => 0,
        2 => 1,
        10 => 4,      // primes: 2, 3, 5, 7
        100 => 25,    // 25 primes under 100
        1_000 => 168, // 168 primes under 1000
        10_000 => 1229,
        100_000 => 9592,
        1_000_000 => 78498,
        _ => 0,
    }
}

// Test function for basic functionality
fn test_basic() -> usize {
    let mut passed = 0;
    
    // Test 1: limit = 0
    if murphy_sieve_true(0) == 0 {
        passed += 1;
    }
    
    // Test 2: limit = 1
    if murphy_sieve_true(1) == 0 {
        passed += 1;
    }
    
    // Test 3: limit = 2
    if murphy_sieve_true(2) == 1 {
        passed += 1;
    }
    
    // Test 4: limit = 10
    if murphy_sieve_true(10) == 4 {
        passed += 1;
    }
    
    // Test 5: limit = 100
    if murphy_sieve_true(100) == 25 {
        passed += 1;
    }
    
    return passed;
}

// Test function for optimized version
fn test_optimized() -> usize {
    let mut passed = 0;
    
    // Test with various limits
    let test_limits = [10, 100, 1_000, 10_000];
    
    for limit in test_limits {
        let result_true = murphy_sieve_true(limit);
        let result_optimized = murphy_sieve_optimized(limit);
        
        if result_true == result_optimized {
            passed += 1;
        }
    }
    
    return passed;
}

// Comprehensive test with known values
fn test_comprehensive() -> usize {
    let test_limits = [10, 100, 1_000, 10_000, 100_000];
    let mut passed = 0;
    
    for limit in test_limits {
        let result = murphy_sieve_true(limit);
        let expected = known_prime_count(limit);
        
        if result == expected {
            passed += 1;
            // Print success (in a real implementation)
        } else {
            // Print failure with details
        }
    }
    
    return passed;
}

// Test edge cases
fn test_edge_cases() -> usize {
    let mut passed = 0;
    
    // Test exact prime boundaries
    // 2 is prime
    if murphy_sieve_true(2) == 1 {
        passed += 1;
    }
    
    // 3 is prime
    if murphy_sieve_true(3) == 2 { // primes: 2, 3
        passed += 1;
    }
    
    // 5 is prime
    if murphy_sieve_true(5) == 3 { // primes: 2, 3, 5
        passed += 1;
    }
    
    // Test non-prime boundaries
    // 4 is composite
    if murphy_sieve_true(4) == 2 { // primes: 2, 3
        passed += 1;
    }
    
    // 6 is composite
    if murphy_sieve_true(6) == 3 { // primes: 2, 3, 5
        passed += 1;
    }
    
    return passed;
}

// Performance test (measures correctness, not actual performance)
fn test_performance() -> usize {
    // Test with maximum limit
    let result = murphy_sieve_true(MAX_LIMIT);
    let expected = known_prime_count(MAX_LIMIT);
    
    if result == expected {
        return 1;
    } else {
        return 0;
    }
}

// Main test runner
fn main() -> usize {
    let mut total_passed = 0;
    let mut total_tests = 0;
    
    // Run basic tests
    let basic_passed = test_basic();
    total_passed += basic_passed;
    total_tests += 5; // 5 tests in test_basic
    
    // Run optimized tests
    let optimized_passed = test_optimized();
    total_passed += optimized_passed;
    total_tests += 4; // 4 tests in test_optimized
    
    // Run comprehensive tests
    let comprehensive_passed = test_comprehensive();
    total_passed += comprehensive_passed;
    total_tests += 5; // 5 tests in test_comprehensive
    
    // Run edge case tests
    let edge_passed = test_edge_cases();
    total_passed += edge_passed;
    total_tests += 6; // 6 tests in test_edge_cases
    
    // Run performance test
    let perf_passed = test_performance();
    total_passed += perf_passed;
    total_tests += 1; // 1 test in test_performance
    
    // Calculate success rate
    // In a real test framework, we'd return more detailed results
    // For now, return 1 if all tests passed, 0 otherwise
    
    if total_passed == total_tests {
        return 1;
    } else {
        return 0;
    }
}

// Quick verification function for specific limits
fn verify_limits() -> usize {
    let limits_to_verify = [
        (10, 4),
        (100, 25),
        (1000, 168),
        (10000, 1229),
        (100000, 9592),
    ];
    
    let mut correct = 0;
    
    for (limit, expected) in limits_to_verify {
        let result = murphy_sieve_true(limit);
        if result == expected {
            correct += 1;
        }
    }
    
    return correct;
}