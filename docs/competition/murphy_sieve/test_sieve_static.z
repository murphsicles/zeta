// Static array sieve implementation
// Uses fixed-size array to avoid dynamic array runtime functions

const MAX_LIMIT: i64 = 100;

fn simple_sieve_static(limit: i64) -> i64 {
    if limit < 2 {
        return 0;
    }
    
    if limit > MAX_LIMIT {
        return 0;  // Limit too large for this test
    }
    
    // Static array - fixed size known at compile time
    let mut is_prime: [i64; MAX_LIMIT + 1] = [1; MAX_LIMIT + 1];
    
    // Mark 0 and 1 as not prime
    is_prime[0] = 0;
    is_prime[1] = 0;
    
    // Simple sieve algorithm
    let mut p: i64 = 2;
    while p * p <= limit {
        if is_prime[p] == 1 {
            let mut multiple = p * p;
            while multiple <= limit {
                is_prime[multiple] = 0;
                multiple += p;
            }
        }
        p += 1;
    }
    
    // Count primes
    let mut count: i64 = 0;
    let mut i: i64 = 2;
    while i <= limit {
        if is_prime[i] == 1 {
            count += 1;
        }
        i += 1;
    }
    
    return count;
}

// Test function
fn test_sieve_static() -> i64 {
    // Test with limit = 10
    let result = simple_sieve_static(10);
    
    // Should be 4 primes under 10: 2, 3, 5, 7
    if result == 4 {
        return 0;  // Success
    } else {
        return 1;  // Failure
    }
}

// Main function
fn main() -> i64 {
    return test_sieve_static();
}