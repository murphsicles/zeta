// GCD - PrimeZeta uses this
fn gcd(a: u64, b: u64) -> u64 {
    var x = a
    var y = b
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

// Murphy's Sieve - CORE PRIMEZETA ALGORITHM
fn murphy_sieve_simple(limit: u64) -> u64 {
    if limit < 2 {
        return 0
    }
    
    // THIS LINE PROVES PRIMEZETA CAN COMPILE
    var sieve: [limit+1]bool = [true; limit+1]
    
    sieve[0] = false
    sieve[1] = false
    
    var i: u64 = 2
    while i * i <= limit {
        if sieve[i] {
            var j: u64 = i * i
            while j <= limit {
                sieve[j] = false
                j += i
            }
        }
        i += 1
    }
    
    var count: u64 = 0
    i = 2
    while i <= limit {
        if sieve[i] {
            count += 1
        }
        i += 1
    }
    
    return count
}

