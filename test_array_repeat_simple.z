// Test ArrayRepeat with constant size
fn main() -> i64 {
    let arr: [i64; 5] = [7; 5];  // ArrayRepeat with size 5
    
    // Sum all elements (should be 7 * 5 = 35)
    let mut sum: i64 = 0;
    let mut i: i64 = 0;
    while i < 5 {
        sum += arr[i as usize];
        i += 1;
    }
    
    sum
}