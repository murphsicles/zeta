// Test hybrid system: stack arrays vs heap arrays
fn main() -> i64 {
    // Test 1: Stack array (small size)
    let mut stack_arr: [i64; 5] = [0; 5];
    stack_arr[0] = 10;
    stack_arr[1] = 20;
    stack_arr[2] = 30;
    stack_arr[3] = 40;
    stack_arr[4] = 50;
    
    let stack_sum = stack_arr[0] + stack_arr[1] + stack_arr[2] + stack_arr[3] + stack_arr[4];
    
    // Test 2: Bool stack array
    let mut bool_arr: [bool; 4] = [false; 4];
    bool_arr[0] = true;
    bool_arr[1] = false;
    bool_arr[2] = true;
    bool_arr[3] = true;
    
    let mut bool_count = 0;
    let mut i = 0;
    while i < 4 {
        if bool_arr[i as usize] {
            bool_count += 1;
        }
        i += 1;
    }
    
    // Return combined result
    stack_sum + bool_count
}