// Test workaround for nested comparisons
// Use single-level logic instead of nested if

fn main() -> i64 {
    let a = 1
    let b = 2
    let c = 3
    let d = 4
    
    // Instead of: if (a < b) { if (c < d) { 123 } }
    // Use: if (a < b && c < d) { 123 }
    
    // But && might not work either...
    // Try: if ((a < b) * (c < d) != 0) { 123 }
    
    let cond1 = a < b  // Should be 1 (true)
    let cond2 = c < d  // Should be 1 (true)
    
    // Multiply conditions: 1 * 1 = 1 (true), 0 * anything = 0 (false)
    let both_true = cond1 * cond2
    
    if (both_true != 0) {
        123
    } else {
        0
    }
}