// Comprehensive bool stack array test
fn main() -> i64 {
    let mut arr: [bool; 5] = [false; 5];
    
    // Set some values
    arr[0] = true;
    arr[2] = true;
    arr[4] = true;
    
    // Read them back
    let mut sum = 0;
    let mut i = 0;
    while i < 5 {
        if arr[i as usize] {
            sum += 1;
        }
        i += 1;
    }
    
    // Also test direct boolean operations
    let b1 = arr[0] && arr[2];  // true && true = true
    let b2 = arr[1] || arr[3];  // false || false = false
    let b3 = !arr[4];  // !true = false
    
    sum + (b1 as i64) * 10 + (b2 as i64) * 100 + (b3 as i64) * 1000
}