// Simple bool stack array test
fn main() -> i64 {
    let mut arr: [bool; 3] = [false; 3];
    
    // Set values
    arr[0] = true;
    arr[1] = false;
    arr[2] = true;
    
    // Read them back
    let mut sum = 0;
    if arr[0] { sum += 1; }
    if arr[1] { sum += 10; }
    if arr[2] { sum += 100; }
    
    sum
}