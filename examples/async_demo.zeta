// examples/async_demo.zeta
// Demo of async/await functionality in Zeta v0.5.0

// Define an async function
async fn fetch_data() -> i64 {
    // Simulate some async work
    return 42;
}

// Main function using await
async fn main() -> i64 {
    let data = fetch_data().await;
    return data;
}

