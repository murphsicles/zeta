// Test 2: Bool return types
// Test case: fn test() -> bool

// Simple bool return
fn returns_true() -> bool {
    true
}

fn returns_false() -> bool {
    false
}

// Bool return with logical operations
fn logical_and(a: bool, b: bool) -> bool {
    a && b
}

fn logical_or(a: bool, b: bool) -> bool {
    a || b
}

fn logical_not(a: bool) -> bool {
    !a
}

// Bool return with comparisons
fn is_equal(a: u64, b: u64) -> bool {
    a == b
}

fn is_greater(a: u64, b: u64) -> bool {
    a > b
}

fn is_less(a: u64, b: u64) -> bool {
    a < b
}

// Complex bool expression
fn is_prime_candidate(n: u64) -> bool {
    if n < 2 {
        return false
    }
    if n == 2 || n == 3 {
        return true
    }
    if n % 2 == 0 || n % 3 == 0 {
        return false
    }
    true
}

// Main function to test bool returns
fn main() -> u64 {
    // Test simple bool returns
    if !returns_true() {
        return 1
    }
    if returns_false() {
        return 2
    }
    
    // Test logical operations
    if !logical_and(true, true) {
        return 3
    }
    if logical_and(true, false) {
        return 4
    }
    if !logical_or(false, true) {
        return 5
    }
    if logical_not(true) {
        return 6
    }
    if !logical_not(false) {
        return 7
    }
    
    // Test comparisons
    if !is_equal(5, 5) {
        return 8
    }
    if is_equal(5, 6) {
        return 9
    }
    if !is_greater(10, 5) {
        return 10
    }
    if is_greater(5, 10) {
        return 11
    }
    if !is_less(3, 7) {
        return 12
    }
    if is_less(7, 3) {
        return 13
    }
    
    // Test prime candidate function
    if is_prime_candidate(0) || is_prime_candidate(1) {
        return 14
    }
    if !is_prime_candidate(2) || !is_prime_candidate(3) {
        return 15
    }
    if is_prime_candidate(4) || is_prime_candidate(6) {
        return 16
    }
    if !is_prime_candidate(5) || !is_prime_candidate(7) {
        return 17
    }
    
    0  // Success
}